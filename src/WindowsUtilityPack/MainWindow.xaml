<Window x:Class="WindowsUtilityPack.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Windows Utility Pack"
        Icon="Assets/WindowsUtilityPackLogo.ico"
        Width="1280"
        Height="820"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        Background="{DynamicResource AppBackgroundBrush}"
        Closing="OnWindowClosing"
        Closed="OnWindowClosed">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Compact branding (left-aligned) -->
                <Button Style="{StaticResource TransparentButtonStyle}"
                        Command="{Binding NavigateHomeCommand}"
                        AutomationProperties.Name="Navigate to home">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="36"
                                Height="36"
                                CornerRadius="10"
                                Background="{DynamicResource AppSurfaceElevatedBrush}"
                                BorderBrush="{DynamicResource StrongBorderBrush}"
                                BorderThickness="1"
                                Margin="0,0,10,0">
                            <Image Source="/Assets/WindowsUtilityPackLogo.png"
                                   Width="22"
                                   Height="22"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>
                        <TextBlock Text="Windows Utility Pack"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Corner controls (right-aligned) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource ThemeToggleButtonStyle}"
                            Command="{Binding ToggleThemeCommand}"
                            FontFamily="Segoe MDL2 Assets"
                            Content="{Binding ThemeToggleIcon}"
                            ToolTip="Cycle theme"
                            Margin="0,0,8,0"
                            AutomationProperties.Name="Cycle theme"/>
                    <Button Style="{StaticResource IconButtonStyle}"
                            Command="{Binding OpenSettingsCommand}"
                            Content="&#xE713;"
                            ToolTip="Open settings"
                            AutomationProperties.Name="Open settings"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <ContentControl Content="{Binding CurrentView}" Margin="0"/>

            <Border VerticalAlignment="Top"
                    HorizontalAlignment="Stretch"
                    Style="{StaticResource InfoStatusSurfaceStyle}"
                    Margin="24,0,24,0"
                    Padding="16,12"
                    Visibility="{Binding IsNotificationVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="&#xE946;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="16"
                               Foreground="{DynamicResource InfoBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding NotificationText}"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               FontSize="13"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                    <Button Grid.Column="2"
                            Content="Dismiss"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Command="{Binding DismissNotificationCommand}"
                            Padding="10,6"
                            Margin="10,0,0,0"
                            AutomationProperties.Name="Dismiss notification"/>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource ElevatedSurfaceStyle}"
                Padding="14,10"
                Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="1"
                           Text="Theme-aware, DPI-aware shell"
                           Foreground="{DynamicResource TertiaryTextBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
