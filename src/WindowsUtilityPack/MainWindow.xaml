<Window x:Class="WindowsUtilityPack.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:WindowsUtilityPack.Controls"
        mc:Ignorable="d"
        Title="Windows Utility Pack"
        Icon="Assets/WindowsUtilityPackLogo.ico"
        Width="1280"
        Height="820"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        Background="{DynamicResource AppBackgroundBrush}"
        Closing="OnWindowClosing">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource HeroSurfaceStyle}"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <Button Style="{StaticResource TransparentButtonStyle}"
                            Command="{Binding NavigateHomeCommand}"
                            AutomationProperties.Name="Navigate to home">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="52"
                                    Height="52"
                                    CornerRadius="16"
                                    Background="{DynamicResource AppSurfaceElevatedBrush}"
                                    BorderBrush="{DynamicResource StrongBorderBrush}"
                                    BorderThickness="1"
                                    Margin="0,0,14,0">
                                <Image Source="/Assets/WindowsUtilityPackLogo.png"
                                       Width="30"
                                       Height="30"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Windows Utility Pack" Style="{StaticResource PrimaryHeadingTextStyle}"/>
                                <TextBlock Text="Unified desktop toolkit for system, file, network, security, developer, and image workflows"
                                           Style="{StaticResource MetadataTextStyle}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <WrapPanel Margin="0,18,0,0">
                        <Border Style="{StaticResource StatusSurfaceStyle}" Margin="0,0,10,0" Padding="12,8">
                            <StackPanel>
                                <TextBlock Text="Navigation" Style="{StaticResource MetadataTextStyle}"/>
                                <TextBlock Text="Category-driven and template-backed" Style="{StaticResource BodyTextStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatusSurfaceStyle}" Margin="0,0,10,0" Padding="12,8">
                            <StackPanel>
                                <TextBlock Text="Theme" Style="{StaticResource MetadataTextStyle}"/>
                                <TextBlock Text="{Binding ThemeSummary}" Style="{StaticResource BodyTextStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatusSurfaceStyle}" Padding="12,8">
                            <StackPanel>
                                <TextBlock Text="Status" Style="{StaticResource MetadataTextStyle}"/>
                                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource BodyTextStyle}" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button Style="{StaticResource ThemeToggleButtonStyle}"
                            Command="{Binding ToggleThemeCommand}"
                            FontFamily="Segoe MDL2 Assets"
                            Content="{Binding ThemeToggleIcon}"
                            ToolTip="Cycle theme"
                            Margin="0,0,8,0"
                            AutomationProperties.Name="Cycle theme"/>
                    <Button Style="{StaticResource IconButtonStyle}"
                            Command="{Binding OpenSettingsCommand}"
                            Content="&#xE713;"
                            ToolTip="Open settings"
                            AutomationProperties.Name="Open settings"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource ElevatedSurfaceStyle}"
                Padding="12"
                Margin="0,0,0,12">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Categories}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:CategoryMenuButton
                                Label="{Binding Label}"
                                Icon="{Binding Icon}"
                                NavigateCommand="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                ToolDefinitions="{Binding Tools}"
                                Margin="0,0,10,0"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2">
            <ContentControl Content="{Binding CurrentView}" Margin="0"/>

            <Border VerticalAlignment="Top"
                    HorizontalAlignment="Stretch"
                    Style="{StaticResource InfoStatusSurfaceStyle}"
                    Margin="24,0,24,0"
                    Padding="16,12"
                    Visibility="{Binding IsNotificationVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="&#xE946;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="16"
                               Foreground="{DynamicResource InfoBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding NotificationText}"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               FontSize="13"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                    <Button Grid.Column="2"
                            Content="Dismiss"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Command="{Binding DismissNotificationCommand}"
                            Padding="10,6"
                            Margin="10,0,0,0"
                            AutomationProperties.Name="Dismiss notification"/>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Style="{StaticResource ElevatedSurfaceStyle}"
                Padding="14,10"
                Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="1"
                           Text="Theme-aware, DPI-aware shell"
                           Foreground="{DynamicResource TertiaryTextBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
