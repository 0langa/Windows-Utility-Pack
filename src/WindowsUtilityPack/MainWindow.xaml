<Window x:Class="WindowsUtilityPack.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Windows Utility Pack"
        Icon="Assets/WindowsUtilityPackLogo.ico"
        Width="1280"
        Height="820"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        Background="{DynamicResource AppBackgroundBrush}"
        StateChanged="OnWindowStateChanged"
        Closing="OnWindowClosing"
        Closed="OnWindowClosed">

    <Window.Resources>

        <!-- ── Command palette list-item container style ─────────────────── -->
        <Style x:Key="PaletteItemContainerStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ListItemHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentCardBackgroundBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+K" Command="{Binding OpenCommandPaletteCommand}"/>
    </Window.InputBindings>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Shell header ─────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Branding / Home button -->
                <Button Style="{StaticResource TransparentButtonStyle}"
                        Command="{Binding NavigateHomeCommand}"
                        AutomationProperties.Name="Navigate to home">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="36" Height="36" CornerRadius="10"
                                Background="{DynamicResource AppSurfaceElevatedBrush}"
                                BorderBrush="{DynamicResource StrongBorderBrush}"
                                BorderThickness="1" Margin="0,0,10,0">
                            <Image Source="/Assets/WindowsUtilityPackLogo.png"
                                   Width="22" Height="22"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>
                        <TextBlock Text="Windows Utility Pack"
                                   FontSize="17" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Corner controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Command-palette trigger button -->
                    <Button Style="{StaticResource SecondaryActionButtonStyle}"
                            Command="{Binding OpenCommandPaletteCommand}"
                            ToolTip="Command palette (Ctrl+K)"
                            Margin="0,0,8,0"
                            Padding="10,6"
                            AutomationProperties.Name="Open command palette">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE721;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="13"
                                       Margin="0,0,6,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Ctrl+K"
                                       FontSize="12"
                                       Foreground="{DynamicResource TertiaryTextBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource IconButtonStyle}"
                            Command="{Binding PopOutCurrentToolCommand}"
                            Content="&#xE946;"
                            ToolTip="Open current tool in a new window"
                            Margin="0,0,8,0"
                            AutomationProperties.Name="Open current tool in detached window"/>

                    <Button Style="{StaticResource ThemeToggleButtonStyle}"
                            Command="{Binding ToggleThemeCommand}"
                            FontFamily="Segoe MDL2 Assets"
                            Content="{Binding ThemeToggleIcon}"
                            ToolTip="Cycle theme"
                            Margin="0,0,8,0"
                            AutomationProperties.Name="Cycle theme"/>

                    <Button Style="{StaticResource IconButtonStyle}"
                            Command="{Binding OpenSettingsCommand}"
                            Content="&#xE713;"
                            ToolTip="Open settings"
                            AutomationProperties.Name="Open settings"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Main content + overlays ──────────────────────────────────────── -->
        <Grid Grid.Row="1">
            <ContentControl Content="{Binding CurrentView}" Margin="0"/>

            <!-- Dimming backdrop -->
            <Border x:Name="PaletteBackdrop"
                    Panel.ZIndex="20"
                    Visibility="{Binding IsCommandPaletteOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                <Border.Background>
                    <SolidColorBrush Color="#000000" Opacity="0.55"/>
                </Border.Background>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCommandPaletteOpen}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="Opacity"
                                                From="0" To="1"
                                                Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>

            <!-- Command palette panel -->
            <Grid Panel.ZIndex="21"
                  VerticalAlignment="Top"
                  HorizontalAlignment="Center"
                  Width="720"
                  Margin="0,32,0,0"
                  Visibility="{Binding IsCommandPaletteOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.RenderTransform>
                    <ScaleTransform x:Name="PaletteScale" ScaleX="1" ScaleY="1"
                                    CenterX="360" CenterY="0"/>
                </Grid.RenderTransform>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCommandPaletteOpen}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="Opacity"
                                                From="0" To="1"
                                                Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                From="0.96" To="1"
                                                Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                From="0.96" To="1"
                                                Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Border Style="{StaticResource ElevatedSurfaceStyle}"
                        Padding="0"
                        CornerRadius="14"
                        BorderBrush="{DynamicResource StrongBorderBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Search bar row -->
                        <Border Grid.Row="0"
                                Padding="16,14"
                                BorderBrush="{DynamicResource SubtleBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Search icon -->
                                <TextBlock Grid.Column="0"
                                           Text="&#xE721;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="16"
                                           Foreground="{DynamicResource TertiaryTextBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,0"/>

                                <!-- Query input -->
                                <TextBox x:Name="CommandPaletteQueryBox"
                                         Grid.Column="1"
                                         Text="{Binding CommandPaletteQuery, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="15"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="{DynamicResource PrimaryTextBrush}"
                                         CaretBrush="{DynamicResource AccentBrush}"
                                         VerticalContentAlignment="Center"
                                         ToolTip="Search tools and actions"
                                         AutomationProperties.Name="Command palette search"/>

                                <!-- Escape hint -->
                                <Border Grid.Column="2"
                                        Background="{DynamicResource AppSurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="7,3"
                                        VerticalAlignment="Center"
                                        Margin="12,0,0,0">
                                    <TextBlock Text="Esc"
                                               FontSize="11"
                                               Foreground="{DynamicResource TertiaryTextBrush}"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Results list -->
                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding CommandPaletteItems}"
                                 SelectedItem="{Binding SelectedCommandPaletteItem, Mode=TwoWay}"
                                 MaxHeight="400"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Padding="8,6"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ItemContainerStyle="{StaticResource PaletteItemContainerStyle}"
                                 AutomationProperties.Name="Command palette results">

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Tool icon: glyph preferred, emoji fallback -->
                                        <TextBlock Grid.Column="0"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   FontSize="15">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Text" Value="{Binding IconGlyph}"/>
                                                    <Style.Triggers>
                                                        <!-- Fall back to emoji when no MDL2 glyph defined -->
                                                        <DataTrigger Binding="{Binding IconGlyph}" Value="">
                                                            <Setter Property="FontFamily" Value="Segoe UI Emoji"/>
                                                            <Setter Property="Text" Value="{Binding Icon}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- Title + subtitle -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,0,8,0">
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Subtitle}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,2,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <!-- Collapse subtitle row when empty -->
                                                            <DataTrigger Binding="{Binding Subtitle}" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Category pill -->
                                        <Border Grid.Column="2"
                                                Background="{DynamicResource AppSurfaceBrush}"
                                                BorderBrush="{DynamicResource SubtleBorderBrush}"
                                                BorderThickness="1"
                                                Padding="8,3"
                                                CornerRadius="10"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Category}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TertiaryTextBrush}"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>

                            <ListBox.InputBindings>
                                <MouseBinding Gesture="LeftDoubleClick"
                                              Command="{Binding DataContext.ExecuteCommandPaletteItemCommand,
                                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                              CommandParameter="{Binding SelectedItem,
                                                                          RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                            </ListBox.InputBindings>
                        </ListBox>

                        <!-- Footer keyboard hints -->
                        <Border Grid.Row="2"
                                Padding="16,9"
                                BorderBrush="{DynamicResource SubtleBorderBrush}"
                                BorderThickness="0,1,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74B;"
                                           FontSize="11" Foreground="{DynamicResource TertiaryTextBrush}"
                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="&#xE74A;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="11" Foreground="{DynamicResource TertiaryTextBrush}"
                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="Navigate"
                                           FontSize="11" Foreground="{DynamicResource TertiaryTextBrush}"
                                           VerticalAlignment="Center" Margin="0,0,16,0"/>

                                <Border Background="{DynamicResource AppSurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="4"
                                        Padding="5,2" Margin="0,0,4,0">
                                    <TextBlock Text="↵" FontSize="11"
                                               Foreground="{DynamicResource TertiaryTextBrush}"/>
                                </Border>
                                <TextBlock Text="Open"
                                           FontSize="11" Foreground="{DynamicResource TertiaryTextBrush}"
                                           VerticalAlignment="Center" Margin="0,0,16,0"/>

                                <Border Background="{DynamicResource AppSurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="4"
                                        Padding="5,2" Margin="0,0,4,0">
                                    <TextBlock Text="Esc" FontSize="11"
                                               Foreground="{DynamicResource TertiaryTextBrush}"/>
                                </Border>
                                <TextBlock Text="Dismiss"
                                           FontSize="11" Foreground="{DynamicResource TertiaryTextBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- In-app notification banner -->
            <Border VerticalAlignment="Top"
                    HorizontalAlignment="Stretch"
                    Style="{StaticResource InfoStatusSurfaceStyle}"
                    Margin="24,0,24,0"
                    Padding="16,12"
                    Panel.ZIndex="22"
                    Visibility="{Binding IsNotificationVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="&#xE946;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="16"
                               Foreground="{DynamicResource InfoBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding NotificationText}"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               FontSize="13"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                    <Button Grid.Column="2"
                            Content="Dismiss"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Command="{Binding DismissNotificationCommand}"
                            Padding="10,6"
                            Margin="10,0,0,0"
                            AutomationProperties.Name="Dismiss notification"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ── Status bar ────────────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Style="{StaticResource ElevatedSurfaceStyle}"
                Padding="14,10"
                Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding ThemeSummary}"
                           Foreground="{DynamicResource TertiaryTextBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
