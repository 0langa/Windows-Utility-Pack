<Window x:Class="WindowsUtilityPack.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Windows Utility Pack"
        Icon="Assets/WindowsUtilityPackLogo.ico"
        Width="1280"
        Height="820"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        Background="{DynamicResource AppBackgroundBrush}"
        PreviewKeyDown="OnPreviewKeyDown"
        StateChanged="OnWindowStateChanged"
        Closing="OnWindowClosing"
        Closed="OnWindowClosed">

    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+K" Command="{Binding OpenCommandPaletteCommand}"/>
        <KeyBinding Gesture="Escape" Command="{Binding CloseCommandPaletteCommand}"/>
    </Window.InputBindings>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Compact branding (left-aligned) -->
                <Button Style="{StaticResource TransparentButtonStyle}"
                        Command="{Binding NavigateHomeCommand}"
                        AutomationProperties.Name="Navigate to home">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="36"
                                Height="36"
                                CornerRadius="10"
                                Background="{DynamicResource AppSurfaceElevatedBrush}"
                                BorderBrush="{DynamicResource StrongBorderBrush}"
                                BorderThickness="1"
                                Margin="0,0,10,0">
                            <Image Source="/Assets/WindowsUtilityPackLogo.png"
                                   Width="22"
                                   Height="22"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>
                        <TextBlock Text="Windows Utility Pack"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Corner controls (right-aligned) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource IconButtonStyle}"
                        Command="{Binding PopOutCurrentToolCommand}"
                        Content="&#xE946;"
                        ToolTip="Open current tool in a new window"
                        Margin="0,0,8,0"
                        AutomationProperties.Name="Open current tool in detached window"/>
                    <Button Style="{StaticResource ThemeToggleButtonStyle}"
                            Command="{Binding ToggleThemeCommand}"
                            FontFamily="Segoe MDL2 Assets"
                            Content="{Binding ThemeToggleIcon}"
                            ToolTip="Cycle theme"
                            Margin="0,0,8,0"
                            AutomationProperties.Name="Cycle theme"/>
                    <Button Style="{StaticResource IconButtonStyle}"
                            Command="{Binding OpenSettingsCommand}"
                            Content="&#xE713;"
                            ToolTip="Open settings"
                            AutomationProperties.Name="Open settings"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <ContentControl Content="{Binding CurrentView}" Margin="0"/>

            <Border Background="#88000000"
                    Visibility="{Binding IsCommandPaletteOpen, Converter={StaticResource BoolToVisibilityConverter}}"
                    Panel.ZIndex="20"/>

            <Border Style="{StaticResource ElevatedSurfaceStyle}"
                    Width="760"
                    MaxHeight="540"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Center"
                    Margin="0,26,0,0"
                    Padding="16"
                    Panel.ZIndex="21"
                    Visibility="{Binding IsCommandPaletteOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Command Palette"
                               Style="{StaticResource SectionHeadingTextStyle}"/>

                    <TextBox x:Name="CommandPaletteQueryBox"
                             Grid.Row="1"
                             Margin="0,10,0,10"
                             Text="{Binding CommandPaletteQuery, UpdateSourceTrigger=PropertyChanged}"
                             MinHeight="40"
                             VerticalContentAlignment="Center"
                             FontSize="14"
                             ToolTip="Search tools and shell actions"/>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding CommandPaletteItems}"
                             SelectedItem="{Binding SelectedCommandPaletteItem, Mode=TwoWay}"
                             BorderThickness="1"
                             BorderBrush="{DynamicResource BorderBrush}"
                             Background="{DynamicResource AppSurfaceAltBrush}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" Style="{StaticResource PanelHeaderTextStyle}"/>
                                        <TextBlock Text="{Binding Subtitle}" Style="{StaticResource MetadataTextStyle}"/>
                                    </StackPanel>

                                    <Border Grid.Column="1"
                                            Background="{DynamicResource CardBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            Padding="8,3"
                                            CornerRadius="8"
                                            VerticalAlignment="Center"
                                            Margin="12,0,0,0">
                                        <TextBlock Text="{Binding Category}" Style="{StaticResource MetadataTextStyle}"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>

                        <ListBox.InputBindings>
                            <MouseBinding Gesture="LeftDoubleClick"
                                          Command="{Binding DataContext.ExecuteCommandPaletteItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                          CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                        </ListBox.InputBindings>
                    </ListBox>
                </Grid>
            </Border>

            <Border VerticalAlignment="Top"
                    HorizontalAlignment="Stretch"
                    Style="{StaticResource InfoStatusSurfaceStyle}"
                    Margin="24,0,24,0"
                    Padding="16,12"
                    Visibility="{Binding IsNotificationVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="&#xE946;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="16"
                               Foreground="{DynamicResource InfoBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding NotificationText}"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               FontSize="13"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                    <Button Grid.Column="2"
                            Content="Dismiss"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Command="{Binding DismissNotificationCommand}"
                            Padding="10,6"
                            Margin="10,0,0,0"
                            AutomationProperties.Name="Dismiss notification"/>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource ElevatedSurfaceStyle}"
                Padding="14,10"
                Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="1"
                           Text="Theme-aware, DPI-aware shell"
                           Foreground="{DynamicResource TertiaryTextBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
