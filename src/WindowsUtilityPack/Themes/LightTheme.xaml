<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background Colors -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="NavBarBackgroundBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PopupBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AccentCardBackgroundBrush" Color="#EFF6FF"/>

    <!-- Text Colors -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#1A1A2E"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#6B6B7B"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#1D4ED8"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E8"/>

    <!-- Button States -->
    <SolidColorBrush x:Key="CategoryButtonBackgroundBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="CategoryButtonHoverBrush" Color="#1D4ED8"/>
    <SolidColorBrush x:Key="CategoryButtonPressedBrush" Color="#1E40AF"/>
    <SolidColorBrush x:Key="MenuItemHoverBrush" Color="#EFF6FF"/>

    <!-- Theme Toggle -->
    <SolidColorBrush x:Key="ThemeToggleBackgroundBrush" Color="#E0E0E8"/>
    <SolidColorBrush x:Key="ThemeToggleHoverBrush" Color="#2563EB"/>

</ResourceDictionary>
