<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Backgrounds ── -->
    <SolidColorBrush x:Key="AppBackgroundBrush"        Color="#F3F3F3"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="NavBarBackgroundBrush"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardBackgroundBrush"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PopupBackgroundBrush"       Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AccentCardBackgroundBrush"  Color="#F0F6FF"/>
    <SolidColorBrush x:Key="PreviewBackgroundBrush"     Color="#FAFAFA"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush"       Color="#F5F5F5"/>

    <!-- ── Text ── -->
    <SolidColorBrush x:Key="PrimaryTextBrush"    Color="#1A1A1A"/>
    <SolidColorBrush x:Key="SecondaryTextBrush"  Color="#616161"/>

    <!-- ── Accent ── -->
    <SolidColorBrush x:Key="AccentBrush"         Color="#005FB8"/>
    <SolidColorBrush x:Key="AccentHoverBrush"    Color="#004C99"/>

    <!-- ── Semantic ── -->
    <SolidColorBrush x:Key="SuccessBrush"        Color="#0F7B0F"/>
    <SolidColorBrush x:Key="SuccessSurfaceBrush" Color="#DFF6DD"/>
    <SolidColorBrush x:Key="WarningBrush"        Color="#9D5D00"/>
    <SolidColorBrush x:Key="WarningSurfaceBrush" Color="#FFF4CE"/>
    <SolidColorBrush x:Key="ErrorBrush"          Color="#C42B1C"/>
    <SolidColorBrush x:Key="ErrorSurfaceBrush"   Color="#FDE7E9"/>

    <!-- ── Borders ── -->
    <SolidColorBrush x:Key="BorderBrush"         Color="#E0E0E0"/>
    <SolidColorBrush x:Key="SubtleBorderBrush"   Color="#E8E8E8"/>

    <!-- ── Buttons ── -->
    <SolidColorBrush x:Key="CategoryButtonBackgroundBrush" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="CategoryButtonHoverBrush"      Color="#E2E2E2"/>
    <SolidColorBrush x:Key="CategoryButtonPressedBrush"    Color="#D0D0D0"/>
    <SolidColorBrush x:Key="MenuItemHoverBrush"            Color="#F0F0F0"/>

    <!-- ── Theme Toggle ── -->
    <SolidColorBrush x:Key="ThemeToggleBackgroundBrush" Color="#E8E8E8"/>
    <SolidColorBrush x:Key="ThemeToggleHoverBrush"      Color="#005FB8"/>

    <!-- ── Input Controls ── -->
    <SolidColorBrush x:Key="InputBackgroundBrush"       Color="#FFFFFF"/>
    <SolidColorBrush x:Key="InputBorderBrush"           Color="#CCCCCC"/>
    <SolidColorBrush x:Key="InputFocusBorderBrush"      Color="#005FB8"/>
    <SolidColorBrush x:Key="InputPlaceholderBrush"      Color="#999999"/>

    <!-- ── Table / Section Headers ── -->
    <SolidColorBrush x:Key="TableHeaderBackgroundBrush"  Color="#F0F0F0"/>

    <!-- ── Tabs ── -->
    <SolidColorBrush x:Key="TabItemHoverBrush"           Color="#E8E8E8"/>
    <SolidColorBrush x:Key="TabItemSelectedBrush"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TabBorderBrush"              Color="#E0E0E0"/>

    <!-- ── List / Grid ── -->
    <SolidColorBrush x:Key="ListItemHoverBrush"          Color="#F0F0F0"/>
    <SolidColorBrush x:Key="ListItemSelectedBrush"       Color="#F0F6FF"/>

    <!-- ── Slider ── -->
    <SolidColorBrush x:Key="SliderTrackBrush"            Color="#CCCCCC"/>
    <SolidColorBrush x:Key="SliderTrackFillBrush"        Color="#005FB8"/>
    <SolidColorBrush x:Key="SliderThumbBrush"            Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SliderThumbHoverBrush"       Color="#F0F0F0"/>

    <!-- ── Toggle Switch ── -->
    <SolidColorBrush x:Key="ToggleOffBackgroundBrush"    Color="#CCCCCC"/>
    <SolidColorBrush x:Key="ToggleOnBackgroundBrush"     Color="#005FB8"/>
    <SolidColorBrush x:Key="ToggleThumbBrush"            Color="#FFFFFF"/>

    <!-- ── Scrollbar ── -->
    <SolidColorBrush x:Key="ScrollBarThumbBrush"        Color="#CCCCCC"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush"   Color="#999999"/>
    <SolidColorBrush x:Key="ScrollBarTrackBrush"        Color="Transparent"/>

</ResourceDictionary>
