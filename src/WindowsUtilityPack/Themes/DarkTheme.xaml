<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Backgrounds ── -->
    <SolidColorBrush x:Key="AppBackgroundBrush"        Color="#202020"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush"      Color="#2D2D2D"/>
    <SolidColorBrush x:Key="NavBarBackgroundBrush"      Color="#2D2D2D"/>
    <SolidColorBrush x:Key="CardBackgroundBrush"        Color="#2D2D2D"/>
    <SolidColorBrush x:Key="PopupBackgroundBrush"       Color="#2D2D2D"/>
    <SolidColorBrush x:Key="AccentCardBackgroundBrush"  Color="#1A3350"/>
    <SolidColorBrush x:Key="PreviewBackgroundBrush"     Color="#1A1A1A"/>

    <!-- ── Text ── -->
    <SolidColorBrush x:Key="PrimaryTextBrush"    Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SecondaryTextBrush"  Color="#9E9E9E"/>

    <!-- ── Accent ── -->
    <SolidColorBrush x:Key="AccentBrush"         Color="#60CDFF"/>
    <SolidColorBrush x:Key="AccentHoverBrush"    Color="#98DDFF"/>

    <!-- ── Semantic ── -->
    <SolidColorBrush x:Key="SuccessBrush"        Color="#6CCB5F"/>
    <SolidColorBrush x:Key="SuccessSurfaceBrush" Color="#1D3A1A"/>
    <SolidColorBrush x:Key="WarningBrush"        Color="#FCE100"/>
    <SolidColorBrush x:Key="WarningSurfaceBrush" Color="#3A3517"/>
    <SolidColorBrush x:Key="ErrorBrush"          Color="#FF99A4"/>
    <SolidColorBrush x:Key="ErrorSurfaceBrush"   Color="#442726"/>

    <!-- ── Borders ── -->
    <SolidColorBrush x:Key="BorderBrush"         Color="#3D3D3D"/>

    <!-- ── Buttons ── -->
    <SolidColorBrush x:Key="CategoryButtonBackgroundBrush" Color="#383838"/>
    <SolidColorBrush x:Key="CategoryButtonHoverBrush"      Color="#4A4A4A"/>
    <SolidColorBrush x:Key="CategoryButtonPressedBrush"    Color="#555555"/>
    <SolidColorBrush x:Key="MenuItemHoverBrush"            Color="#383838"/>

    <!-- ── Theme Toggle ── -->
    <SolidColorBrush x:Key="ThemeToggleBackgroundBrush" Color="#383838"/>
    <SolidColorBrush x:Key="ThemeToggleHoverBrush"      Color="#60CDFF"/>

    <!-- ── Input Controls ── -->
    <SolidColorBrush x:Key="InputBackgroundBrush"       Color="#2D2D2D"/>
    <SolidColorBrush x:Key="InputBorderBrush"           Color="#555555"/>
    <SolidColorBrush x:Key="InputFocusBorderBrush"      Color="#60CDFF"/>
    <SolidColorBrush x:Key="InputPlaceholderBrush"      Color="#777777"/>

    <!-- ── Table / Section Headers ── -->
    <SolidColorBrush x:Key="TableHeaderBackgroundBrush"  Color="#383838"/>

    <!-- ── Tabs ── -->
    <SolidColorBrush x:Key="TabItemHoverBrush"           Color="#383838"/>
    <SolidColorBrush x:Key="TabItemSelectedBrush"        Color="#2D2D2D"/>
    <SolidColorBrush x:Key="TabBorderBrush"              Color="#3D3D3D"/>

    <!-- ── List / Grid ── -->
    <SolidColorBrush x:Key="ListItemHoverBrush"          Color="#383838"/>
    <SolidColorBrush x:Key="ListItemSelectedBrush"       Color="#1A3350"/>

    <!-- ── Slider ── -->
    <SolidColorBrush x:Key="SliderTrackBrush"            Color="#555555"/>
    <SolidColorBrush x:Key="SliderTrackFillBrush"        Color="#60CDFF"/>
    <SolidColorBrush x:Key="SliderThumbBrush"            Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SliderThumbHoverBrush"       Color="#E0E0E0"/>

    <!-- ── Toggle Switch ── -->
    <SolidColorBrush x:Key="ToggleOffBackgroundBrush"    Color="#555555"/>
    <SolidColorBrush x:Key="ToggleOnBackgroundBrush"     Color="#60CDFF"/>
    <SolidColorBrush x:Key="ToggleThumbBrush"            Color="#FFFFFF"/>

    <!-- ── Scrollbar ── -->
    <SolidColorBrush x:Key="ScrollBarThumbBrush"        Color="#555555"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush"   Color="#777777"/>
    <SolidColorBrush x:Key="ScrollBarTrackBrush"        Color="Transparent"/>

</ResourceDictionary>
