<UserControl x:Class="WindowsUtilityPack.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:WindowsUtilityPack.Converters"
             xmlns:models="clr-namespace:WindowsUtilityPack.Models">
    <Grid Style="{StaticResource PageRootStyle}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="4,0">

                <!-- ── Search / Quick Launcher ────────────────────────── -->
                <Grid Margin="0,0,0,18">
                    <TextBox Style="{StaticResource SearchBoxStyle}"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             AutomationProperties.Name="Search tools"/>
                    <TextBlock Text="&#xE721;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="15"
                               Foreground="{DynamicResource InputPlaceholderBrush}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               Margin="12,0,0,0"
                               IsHitTestVisible="False"/>
                    <Button Content="&#xE711;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="12"
                            Style="{StaticResource SectionActionLinkStyle}"
                            Command="{Binding ClearSearchCommand}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0"
                            Visibility="{Binding HasSearchQuery, Converter={StaticResource BoolToVisibilityConverter}}"
                            AutomationProperties.Name="Clear search"/>
                </Grid>

                <!-- ── Search Results ─────────────────────────────────── -->
                <StackPanel Visibility="{Binding ShowSearchResults, Converter={StaticResource BoolToVisibilityConverter}}"
                            Margin="0,0,0,20">
                    <DockPanel Margin="0,0,0,0">
                        <TextBlock Text="&#xE721;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="15"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock Text="Search Results"
                                   Style="{StaticResource DashboardSectionHeaderStyle}"/>
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding SearchResults}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding Key}"
                                        Style="{StaticResource CompactCardButtonStyle}"
                                        Width="260"
                                        Margin="0,0,10,10"
                                        AutomationProperties.Name="{Binding Name}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="36"
                                                Height="36"
                                                CornerRadius="10"
                                                Background="{DynamicResource AppSurfaceElevatedBrush}"
                                                BorderBrush="{DynamicResource StrongBorderBrush}"
                                                BorderThickness="1"
                                                Margin="0,0,10,0">
                                            <TextBlock Text="{Binding IconGlyph}"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="16"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Category}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- ── Favourites ─────────────────────────────────────── -->
                <StackPanel Margin="0,0,0,20">
                    <DockPanel Margin="0,0,0,0">
                        <TextBlock Text="&#xE735;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="15"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock Text="Favourites"
                                   Style="{StaticResource DashboardSectionHeaderStyle}"/>
                    </DockPanel>

                    <!-- Empty state -->
                    <TextBlock Text="Pin your most-used tools for quick access by clicking the ☆ star on any tool card below."
                               Style="{StaticResource EmptyStateTextStyle}"
                               Visibility="{Binding HasFavorites, Converter={StaticResource InvertedBoolToVisibilityConverter}}"/>

                    <!-- Favourite tool cards (compact horizontal) -->
                    <ItemsControl ItemsSource="{Binding FavoriteTools}"
                                  Visibility="{Binding HasFavorites, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding Key}"
                                        Style="{StaticResource CompactCardButtonStyle}"
                                        Width="260"
                                        Margin="0,0,10,10"
                                        AutomationProperties.Name="{Binding Name}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="36"
                                                Height="36"
                                                CornerRadius="10"
                                                Background="{DynamicResource AppSurfaceElevatedBrush}"
                                                BorderBrush="{DynamicResource StrongBorderBrush}"
                                                BorderThickness="1"
                                                Margin="0,0,10,0">
                                            <TextBlock Text="{Binding IconGlyph}"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="16"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Category}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- ── Recently Used ──────────────────────────────────── -->
                <StackPanel Margin="0,0,0,20">
                    <DockPanel Margin="0,0,0,0">
                        <TextBlock Text="&#xE81C;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="15"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock Text="Recently Used"
                                   Style="{StaticResource DashboardSectionHeaderStyle}"/>
                        <Button Content="Clear"
                                Style="{StaticResource SectionActionLinkStyle}"
                                Command="{Binding ClearRecentCommand}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Visibility="{Binding HasRecents, Converter={StaticResource BoolToVisibilityConverter}}"
                                AutomationProperties.Name="Clear recent tools"/>
                    </DockPanel>

                    <!-- Empty state -->
                    <TextBlock Text="Tools you open will appear here."
                               Style="{StaticResource EmptyStateTextStyle}"
                               Visibility="{Binding HasRecents, Converter={StaticResource InvertedBoolToVisibilityConverter}}"/>

                    <!-- Recent tool cards (compact horizontal) -->
                    <ItemsControl ItemsSource="{Binding RecentTools}"
                                  Visibility="{Binding HasRecents, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding Key}"
                                        Style="{StaticResource CompactCardButtonStyle}"
                                        Width="260"
                                        Margin="0,0,10,10"
                                        AutomationProperties.Name="{Binding Name}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="36"
                                                Height="36"
                                                CornerRadius="10"
                                                Background="{DynamicResource AppSurfaceElevatedBrush}"
                                                BorderBrush="{DynamicResource StrongBorderBrush}"
                                                BorderThickness="1"
                                                Margin="0,0,10,0">
                                            <TextBlock Text="{Binding IconGlyph}"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="16"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Category}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- ── Browse by Category ─────────────────────────────── -->
                <StackPanel Margin="0,0,0,20">
                    <DockPanel Margin="0,0,0,0">
                        <TextBlock Text="&#xE8FD;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="15"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock Text="Browse by Category"
                                   Style="{StaticResource DashboardSectionHeaderStyle}"/>
                    </DockPanel>

                    <!-- Category tab bar (wrapping, no horizontal scroll) -->
                    <ItemsControl ItemsSource="{Binding Categories}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:CategoryItem}">
                                <Button Style="{StaticResource CategoryTabButtonStyle}"
                                        Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        AutomationProperties.Name="{Binding Label}">
                                    <Button.Tag>
                                        <MultiBinding Converter="{StaticResource EqualityToTagConverter}">
                                            <Binding/>
                                            <Binding Path="DataContext.SelectedCategory"
                                                     RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                        </MultiBinding>
                                    </Button.Tag>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Icon}"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Label}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="10.5"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="220"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Selected category tool panel -->
                    <Border Visibility="{Binding HasSelectedCategory, Converter={StaticResource BoolToVisibilityConverter}}"
                            Style="{StaticResource SurfaceCardStyle}"
                            Padding="14"
                            Margin="0,8,0,0">
                        <ItemsControl ItemsSource="{Binding SelectedCategoryTools}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,10,10" Width="280">
                                        <Button Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Key}"
                                                Style="{StaticResource CategoryToolCardStyle}"
                                                HorizontalAlignment="Stretch"
                                                AutomationProperties.Name="{Binding Name}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="34"
                                                        Height="34"
                                                        CornerRadius="9"
                                                        Background="{DynamicResource AppSurfaceElevatedBrush}"
                                                        BorderBrush="{DynamicResource StrongBorderBrush}"
                                                        BorderThickness="1"
                                                        Margin="0,0,10,0">
                                                    <TextBlock Text="{Binding IconGlyph}"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="15"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Description}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                                               TextTrimming="CharacterEllipsis"
                                                               TextWrapping="NoWrap"/>
                                                </StackPanel>
                                            </Grid>
                                        </Button>
                                        <ToggleButton HorizontalAlignment="Right"
                                                      VerticalAlignment="Top"
                                                      Margin="0,4,4,0"
                                                      Style="{StaticResource FavoriteToggleButtonStyle}"
                                                      Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding Key}"
                                                      AutomationProperties.Name="Toggle favourite">
                                            <ToggleButton.IsChecked>
                                                <MultiBinding Converter="{StaticResource FavoriteCheckConverter}" Mode="OneWay">
                                                    <Binding Path="Key"/>
                                                    <Binding Path="DataContext.FavoriteTools"
                                                             RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                </MultiBinding>
                                            </ToggleButton.IsChecked>
                                        </ToggleButton>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>

                <!-- ── All Tools ──────────────────────────────────────── -->
                <StackPanel>
                    <DockPanel Margin="0,0,0,0">
                        <TextBlock Text="&#xE71D;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="15"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock Text="All Tools"
                                   Style="{StaticResource DashboardSectionHeaderStyle}"/>
                    </DockPanel>

                    <ItemsControl ItemsSource="{Binding AllTools}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,14,14" Width="280">
                                    <Button Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Key}"
                                            Style="{StaticResource CardButtonStyle}"
                                            HorizontalAlignment="Stretch"
                                            Padding="16,14"
                                            AutomationProperties.Name="{Binding Name}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <Border Width="36"
                                                        Height="36"
                                                        CornerRadius="10"
                                                        Background="{DynamicResource AppSurfaceElevatedBrush}"
                                                        BorderBrush="{DynamicResource StrongBorderBrush}"
                                                        BorderThickness="1"
                                                        HorizontalAlignment="Left"
                                                        Margin="0,0,0,10">
                                                    <TextBlock Text="{Binding IconGlyph}"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="17"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="{Binding Name}" Style="{StaticResource CardTitleStyle}" FontSize="14"/>
                                                <TextBlock Text="{Binding Description}"
                                                           Style="{StaticResource CardDescriptionStyle}"
                                                           MaxHeight="36"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <ToggleButton Grid.Column="1"
                                                          Style="{StaticResource FavoriteToggleButtonStyle}"
                                                          VerticalAlignment="Top"
                                                          Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding Key}"
                                                          AutomationProperties.Name="Toggle favourite">
                                                <ToggleButton.IsChecked>
                                                    <MultiBinding Converter="{StaticResource FavoriteCheckConverter}" Mode="OneWay">
                                                        <Binding Path="Key"/>
                                                        <Binding Path="DataContext.FavoriteTools"
                                                                 RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                    </MultiBinding>
                                                </ToggleButton.IsChecked>
                                            </ToggleButton>
                                        </Grid>
                                    </Button>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
