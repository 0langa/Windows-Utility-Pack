<UserControl x:Class="WindowsUtilityPack.Views.HomeView" x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="clr-namespace:WindowsUtilityPack.Models">
    <UserControl.Resources>
        <Style x:Key="HomeToolHoverLiftButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactCardButtonStyle}"/>
        <Style x:Key="HomeCategoryCardButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactCardButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}"
                                Effect="{StaticResource DropShadowEffect}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource AccentCardBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Selected">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource AccentCardBackgroundBrush}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource DisabledForegroundBrush}"/>
                                <Setter TargetName="Border" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HeaderToggleIconButtonStyle" TargetType="Button" BasedOn="{StaticResource SectionActionLinkStyle}">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SectionHeaderTitleButtonStyle" TargetType="Button" BasedOn="{StaticResource SectionActionLinkStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>
        <Style x:Key="SectionHeaderGridStyle" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="MinHeight" Value="50"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SectionHeaderTitleTextStyle" TargetType="TextBlock" BasedOn="{StaticResource DashboardSectionHeaderStyle}">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SectionHeaderSubtitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
        <Style x:Key="SectionHeaderClearButtonStyle" TargetType="Button" BasedOn="{StaticResource SectionActionLinkStyle}">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Style="{StaticResource PageRootStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="270"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="4,0,4,10">
            <Border Style="{StaticResource SurfaceCardStyle}" Padding="14,10" Margin="0,0,0,10">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="{Binding GreetingText}" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding FormattedDate}" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Margin="0,0,0,0">
                <TextBox x:Name="SearchBox" Style="{StaticResource SearchBoxStyle}" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" GotKeyboardFocus="SearchBox_OnGotKeyboardFocus" LostKeyboardFocus="SearchBox_OnLostKeyboardFocus"/>
                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="{DynamicResource InputPlaceholderBrush}" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="12,0,0,0" IsHitTestVisible="False"/>
                <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12" Style="{StaticResource SectionActionLinkStyle}" Command="{Binding ClearSearchCommand}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Visibility="{Binding HasSearchQuery, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <Popup IsOpen="{Binding ShowSearchDropdown, Mode=OneWay}" PlacementTarget="{Binding ElementName=SearchBox}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" VerticalOffset="6">
                    <Border Background="{DynamicResource PopupBackgroundBrush}" BorderBrush="{DynamicResource StrongBorderBrush}" BorderThickness="1" CornerRadius="10" Padding="8" Width="{Binding ActualWidth, ElementName=SearchBox}" MaxHeight="260">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <ItemsControl ItemsSource="{Binding SearchResults}" Visibility="{Binding HasSearchQuery, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ItemsControl.ItemTemplate><DataTemplate>
                                        <Button Command="{Binding DataContext.NavigateCommand, ElementName=Root}" CommandParameter="{Binding Key}" Style="{StaticResource HomeToolHoverLiftButtonStyle}" Margin="0,0,0,6" Padding="10,8">
                                            <StackPanel><TextBlock Text="{Binding Name}" FontWeight="SemiBold"/><TextBlock Text="{Binding Description}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" TextTrimming="CharacterEllipsis"/></StackPanel>
                                        </Button>
                                    </DataTemplate></ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <DockPanel Margin="0,4,0,6" Visibility="{Binding HasSearchQuery, Converter={StaticResource InvertedBoolToVisibilityConverter}}">
                                    <TextBlock Text="Recent Searches" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <Button DockPanel.Dock="Right"
                                            Style="{StaticResource SectionActionLinkStyle}"
                                            Command="{Binding ClearRecentSearchesCommand}"
                                            ToolTip="Clear recent searches"
                                            Padding="6,2"
                                            MinHeight="0">
                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                    </Button>
                                </DockPanel>
                                <ItemsControl ItemsSource="{Binding RecentSearches}" Visibility="{Binding HasSearchQuery, Converter={StaticResource InvertedBoolToVisibilityConverter}}">
                                    <ItemsControl.ItemTemplate><DataTemplate>
                                        <Button Command="{Binding DataContext.ExecuteRecentSearchCommand, ElementName=Root}" CommandParameter="{Binding}" Style="{StaticResource SecondaryActionButtonStyle}" Margin="0,0,0,6" Padding="10,7" HorizontalContentAlignment="Left"><TextBlock Text="{Binding}"/></Button>
                                    </DataTemplate></ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Popup>
            </Grid>
        </StackPanel>

        <ScrollViewer Grid.Row="1" Grid.Column="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Margin="4,0,4,0">
            <StackPanel Margin="0,0,0,8"
                        Width="{Binding ViewportWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">

                <StackPanel Margin="0,0,0,12">
                    <Grid Style="{StaticResource SectionHeaderGridStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Style="{StaticResource HeaderToggleIconButtonStyle}"
                                Command="{Binding ToggleFavoritesExpandedCommand}"
                                ToolTip="Expand or collapse Favorites">
                            <TextBlock Text="&#xE735;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="{DynamicResource AccentBrush}"/>
                        </Button>
                        <Button Grid.Column="1"
                                Style="{StaticResource SectionHeaderTitleButtonStyle}"
                                Command="{Binding ToggleFavoritesExpandedCommand}"
                                ToolTip="Expand or collapse Favorites">
                            <TextBlock Text="Favorites" Style="{StaticResource SectionHeaderTitleTextStyle}"/>
                        </Button>
                    </Grid>
                    <StackPanel Visibility="{Binding FavoritesExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid Visibility="{Binding HasFavorites, Converter={StaticResource InvertedBoolToVisibilityConverter}}">
                            <Rectangle RadiusX="10" RadiusY="10" Stroke="{DynamicResource StrongBorderBrush}" StrokeThickness="1" StrokeDashArray="4 3"/>
                            <StackPanel Margin="14"><TextBlock Text="No favorites yet" FontWeight="SemiBold"/><TextBlock Text="Star tools to pin them here for one-click access." FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"/></StackPanel>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding FavoriteTools}" Visibility="{Binding HasFavorites, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="3"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate><DataTemplate>
                                <Button Style="{StaticResource HomeToolHoverLiftButtonStyle}" Margin="0,0,8,8" Tag="{Binding Key}" Command="{Binding DataContext.NavigateCommand, ElementName=Root}" CommandParameter="{Binding Key}">
                                    <Button.ContextMenu><ContextMenu>
                                        <MenuItem Header="Open" Command="{Binding DataContext.NavigateCommand, ElementName=Root}" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="Add/Remove Favorite" Command="{Binding DataContext.ToggleFavoriteCommand, ElementName=Root}" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="Copy tool name" Command="{Binding DataContext.CopyToolNameCommand, ElementName=Root}" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="View description" Command="{Binding DataContext.ViewDescriptionCommand, ElementName=Root}" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    </ContextMenu></Button.ContextMenu>
                                    <DockPanel><TextBlock Text="{Binding IconGlyph}" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0" Foreground="{DynamicResource AccentBrush}"/><StackPanel><TextBlock Text="{Binding Name}" FontWeight="SemiBold"/><TextBlock Text="{Binding Category}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/></StackPanel></DockPanel>
                                </Button>
                            </DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>

                <StackPanel Margin="0,0,0,12">
                    <Grid Style="{StaticResource SectionHeaderGridStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Style="{StaticResource HeaderToggleIconButtonStyle}"
                                Command="{Binding ToggleRecentsExpandedCommand}"
                                ToolTip="Expand or collapse Recently Used">
                            <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="{DynamicResource AccentBrush}"/>
                        </Button>
                        <Button Grid.Column="1"
                                Style="{StaticResource SectionHeaderTitleButtonStyle}"
                                Command="{Binding ToggleRecentsExpandedCommand}"
                                ToolTip="Expand or collapse Recently Used">
                            <TextBlock Text="Recently Used" Style="{StaticResource SectionHeaderTitleTextStyle}"/>
                        </Button>
                        <Button Grid.Column="2"
                                Command="{Binding ClearRecentCommand}"
                                ToolTip="Clear recently used tools">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SectionHeaderClearButtonStyle}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding HasRecents}" Value="True"/>
                                                <Condition Binding="{Binding RecentsExpanded}" Value="True"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                        </Button>
                    </Grid>
                    <StackPanel Visibility="{Binding RecentsExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid Visibility="{Binding HasRecents, Converter={StaticResource InvertedBoolToVisibilityConverter}}">
                            <Rectangle RadiusX="10" RadiusY="10" Stroke="{DynamicResource StrongBorderBrush}" StrokeThickness="1" StrokeDashArray="4 3"/>
                            <StackPanel Margin="14"><TextBlock Text="No recent tools yet" FontWeight="SemiBold"/><TextBlock Text="Opened tools automatically appear here." FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"/></StackPanel>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding RecentTools}" Visibility="{Binding HasRecents, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="3"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate><DataTemplate>
                                <Button Style="{StaticResource HomeToolHoverLiftButtonStyle}" Margin="0,0,8,8" Tag="{Binding Key}" Command="{Binding DataContext.NavigateCommand, ElementName=Root}" CommandParameter="{Binding Key}">
                                    <Button.ContextMenu><ContextMenu>
                                        <MenuItem Header="Open" Command="{Binding DataContext.NavigateCommand, ElementName=Root}" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="Add/Remove Favorite" Command="{Binding DataContext.ToggleFavoriteCommand, ElementName=Root}" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="Copy tool name" Command="{Binding DataContext.CopyToolNameCommand, ElementName=Root}" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="View description" Command="{Binding DataContext.ViewDescriptionCommand, ElementName=Root}" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    </ContextMenu></Button.ContextMenu>
                                    <DockPanel><TextBlock Text="{Binding IconGlyph}" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0" Foreground="{DynamicResource AccentBrush}"/><StackPanel><TextBlock Text="{Binding Name}" FontWeight="SemiBold"/><TextBlock Text="{Binding Category}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/></StackPanel></DockPanel>
                                </Button>
                            </DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
                <StackPanel Margin="0,0,0,12" Visibility="{Binding HasRecommendations, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid Style="{StaticResource SectionHeaderGridStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Style="{StaticResource HeaderToggleIconButtonStyle}"
                                Command="{Binding ToggleRecommendedExpandedCommand}"
                                ToolTip="Expand or collapse Recommended Next Tools">
                            <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="{DynamicResource AccentBrush}"/>
                        </Button>
                        <Button Grid.Column="1"
                                Style="{StaticResource SectionHeaderTitleButtonStyle}"
                                Command="{Binding ToggleRecommendedExpandedCommand}"
                                ToolTip="Expand or collapse Recommended Next Tools">
                            <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                <TextBlock Text="Recommended Next Tools" Style="{StaticResource SectionHeaderTitleTextStyle}"/>
                                <TextBlock Text="Based on your usage patterns"
                                           Style="{StaticResource SectionHeaderSubtitleTextStyle}"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding RecommendedTools}" Visibility="{Binding RecommendedExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="3"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate><DataTemplate>
                            <Button Style="{StaticResource HomeToolHoverLiftButtonStyle}" Margin="0,0,8,8" Tag="{Binding Key}" Command="{Binding DataContext.NavigateCommand, ElementName=Root}" CommandParameter="{Binding Key}">
                                <Button.ContextMenu><ContextMenu>
                                    <MenuItem Header="Open" Command="{Binding DataContext.NavigateCommand, ElementName=Root}" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="Add/Remove Favorite" Command="{Binding DataContext.ToggleFavoriteCommand, ElementName=Root}" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="Copy tool name" Command="{Binding DataContext.CopyToolNameCommand, ElementName=Root}" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="View description" Command="{Binding DataContext.ViewDescriptionCommand, ElementName=Root}" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                </ContextMenu></Button.ContextMenu>
                                <DockPanel>
                                    <TextBlock Text="{Binding IconGlyph}" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0" Foreground="{DynamicResource AccentBrush}"/>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DockPanel>
                            </Button>
                        </DataTemplate></ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                <StackPanel Margin="0,0,0,12">
                    <Grid Style="{StaticResource SectionHeaderGridStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Style="{StaticResource HeaderToggleIconButtonStyle}"
                                Command="{Binding ToggleCategoryBrowserExpandedCommand}"
                                ToolTip="Expand or collapse Browse by Category">
                            <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="{DynamicResource AccentBrush}"/>
                        </Button>
                        <Button Grid.Column="1"
                                Style="{StaticResource SectionHeaderTitleButtonStyle}"
                                Command="{Binding ToggleCategoryBrowserExpandedCommand}"
                                ToolTip="Expand or collapse Browse by Category">
                            <TextBlock Text="Browse by Category" Style="{StaticResource SectionHeaderTitleTextStyle}"/>
                        </Button>
                    </Grid>
                    <StackPanel Visibility="{Binding CategoryBrowserExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsControl ItemsSource="{Binding CategorySummaries}">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="3"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:HomeCategorySummary}">
                                    <Button x:Name="CatButton" Margin="0,0,8,8" Style="{StaticResource HomeCategoryCardButtonStyle}" Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding Category}">
                                        <Button.Tag>
                                            <MultiBinding Converter="{StaticResource EqualityToTagConverter}">
                                                <Binding Path="Category"/>
                                                <Binding Path="DataContext.SelectedCategory" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                            </MultiBinding>
                                        </Button.Tag>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="4"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="{DynamicResource AccentBrush}" CornerRadius="3" Margin="0,0,8,0"/>
                                            <StackPanel Grid.Column="1">
                                                <DockPanel><TextBlock Text="{Binding Category.Icon}" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/><TextBlock Text="{Binding Category.Label}" FontWeight="SemiBold"/><TextBlock Text="{Binding ToolCount, StringFormat={}({0} tools)}" Margin="8,0,0,0" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/></DockPanel>
                                                <TextBlock Text="{Binding MostUsedToolName, StringFormat={}Most used: {0}}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,4,0,0"/>
                                                <ItemsControl x:Name="PreviewList" ItemsSource="{Binding TopToolNames}" Margin="0,4,0,0" Visibility="Collapsed">
                                                    <ItemsControl.ItemTemplate><DataTemplate><TextBlock Text="{Binding StringFormat=• {0}}" FontSize="11" Foreground="{DynamicResource TertiaryTextBrush}"/></DataTemplate></ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Border Style="{StaticResource SurfaceCardStyle}"
                                Padding="12"
                                Margin="0,2,0,0"
                                Visibility="{Binding HasSelectedCategory, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,8">
                                    <TextBlock Text="{Binding SelectedCategory.Label, StringFormat={}Tools in {0}}"
                                               FontWeight="SemiBold"/>
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding SelectedCategoryTools.Count, StringFormat={}{0} tools}"
                                               FontSize="11"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                </DockPanel>
                                <ItemsControl ItemsSource="{Binding SelectedCategoryTools}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="3"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Margin="0,0,8,8"
                                                    Style="{StaticResource HomeToolHoverLiftButtonStyle}"
                                                    Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Key}">
                                                <DockPanel>
                                                    <TextBlock Text="{Binding IconGlyph}"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               Margin="0,0,10,0"
                                                               Foreground="{DynamicResource AccentBrush}"/>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding Description}"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </DockPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <StackPanel>
                    <Grid Style="{StaticResource SectionHeaderGridStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Style="{StaticResource HeaderToggleIconButtonStyle}"
                                Command="{Binding ToggleAllToolsExpandedCommand}"
                                ToolTip="Expand or collapse All Tools">
                            <TextBlock Text="&#xE71D;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="{DynamicResource AccentBrush}"/>
                        </Button>
                        <Button Grid.Column="1"
                                Style="{StaticResource SectionHeaderTitleButtonStyle}"
                                Command="{Binding ToggleAllToolsExpandedCommand}"
                                ToolTip="Expand or collapse All Tools">
                            <TextBlock Text="All Tools" Style="{StaticResource SectionHeaderTitleTextStyle}"/>
                        </Button>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding AllTools}" Visibility="{Binding AllToolsExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><UniformGrid Columns="3"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate><DataTemplate>
                            <Border x:Name="ToolCardBorder" Margin="0,0,8,8">
                                <Button Style="{StaticResource HomeToolHoverLiftButtonStyle}" Tag="{Binding Key}" Command="{Binding DataContext.NavigateCommand, ElementName=Root}" CommandParameter="{Binding Key}">
                                    <Button.ContextMenu><ContextMenu>
                                        <MenuItem Header="Open" Command="{Binding DataContext.NavigateCommand, ElementName=Root}" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="Add/Remove Favorite" Command="{Binding DataContext.ToggleFavoriteCommand, ElementName=Root}" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="Copy tool name" Command="{Binding DataContext.CopyToolNameCommand, ElementName=Root}" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="View description" Command="{Binding DataContext.ViewDescriptionCommand, ElementName=Root}" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    </ContextMenu></Button.ContextMenu>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <DockPanel><TextBlock Text="{Binding Name}" FontWeight="SemiBold"/><Border Background="{DynamicResource AccentCardBackgroundBrush}" CornerRadius="6" Padding="5,1" Margin="6,0,0,0" Visibility="{Binding DateAdded, Converter={StaticResource IsNewToolConverter}}"><TextBlock Text="New" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"/></Border></DockPanel>
                                            <TextBlock x:Name="ToolDescription" Text="{Binding Description}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock x:Name="UsageDots" FontSize="12" Foreground="{DynamicResource TertiaryTextBrush}" Margin="0,4,0,0"><TextBlock.Text><MultiBinding Converter="{StaticResource UsageDotsConverter}"><Binding Path="Key"/><Binding Path="DataContext.ToolLaunchCounts" ElementName="Root"/></MultiBinding></TextBlock.Text></TextBlock>
                                        </StackPanel>
                                        <ToggleButton Grid.Column="1" Style="{StaticResource FavoriteToggleButtonStyle}" Command="{Binding DataContext.ToggleFavoriteCommand, ElementName=Root}" CommandParameter="{Binding Key}">
                                            <ToggleButton.IsChecked><MultiBinding Converter="{StaticResource FavoriteCheckConverter}" Mode="OneWay"><Binding Path="Key"/><Binding Path="DataContext.FavoriteTools" ElementName="Root"/></MultiBinding></ToggleButton.IsChecked>
                                        </ToggleButton>
                                    </Grid>
                                </Button>
                            </Border>
                        </DataTemplate></ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel x:Name="UtilityOverlay"
                    Grid.Row="1" Grid.Column="1"
                    VerticalAlignment="Bottom"
                    Margin="0,0,4,8">
            <Border Style="{StaticResource SurfaceCardStyle}" Padding="8" Margin="0,0,0,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="PC Specs" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}" Margin="2,0,0,6"/>

                        <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource AppSurfaceBrush}" BorderBrush="{DynamicResource StrongBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="6" Margin="0,0,4,4">
                        <StackPanel>
                                <TextBlock Text="CPU" FontSize="9" Foreground="{DynamicResource TertiaryTextBrush}"/>
                                <TextBlock Text="{Binding CpuDisplay}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="1" Background="{DynamicResource AppSurfaceBrush}" BorderBrush="{DynamicResource StrongBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="6" Margin="4,0,0,4">
                            <StackPanel>
                                <TextBlock Text="RAM" FontSize="9" Foreground="{DynamicResource TertiaryTextBrush}"/>
                                <TextBlock Text="{Binding RamDisplay}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Grid.Column="0" Background="{DynamicResource AppSurfaceBrush}" BorderBrush="{DynamicResource StrongBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="6" Margin="0,4,4,0">
                            <StackPanel>
                                <TextBlock Text="Disk" FontSize="9" Foreground="{DynamicResource TertiaryTextBrush}"/>
                                <TextBlock Text="{Binding DiskDisplay}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Grid.Column="1" Background="{DynamicResource AppSurfaceBrush}" BorderBrush="{DynamicResource StrongBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="6" Margin="4,4,0,0">
                            <StackPanel>
                                <TextBlock Text="Network" FontSize="9" Foreground="{DynamicResource TertiaryTextBrush}"/>
                                <TextBlock Text="{Binding NetworkDisplay}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Style="{StaticResource SurfaceCardStyle}" Padding="8">
                    <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                        <Button Grid.Row="0" Grid.Column="0" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding QuickGeneratePasswordCommand}" Margin="0,0,4,4" Padding="6,5">
                            <StackPanel>
                                <TextBlock Text="Password" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="Generate" FontSize="9" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding QuickGenerateUuidCommand}" Margin="4,0,0,4" Padding="6,5">
                            <StackPanel>
                                <TextBlock Text="GUID" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="Generate" FontSize="9" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding InspectClipboardCommand}" Margin="0,4,4,0" Padding="6,5">
                            <StackPanel>
                                <TextBlock Text="Clipboard" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding ClipboardSummary}" FontSize="9" Foreground="{DynamicResource SecondaryTextBrush}" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding QuickPingHostCommand}" Margin="4,4,0,0" Padding="6,5">
                            <StackPanel>
                                <TextBlock Text="Ping Host" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding QuickPingStatus}" FontSize="9" Foreground="{DynamicResource SecondaryTextBrush}" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>
            </StackPanel>
    </Grid>
</UserControl>
