<UserControl x:Class="WindowsUtilityPack.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Style="{StaticResource PageRootStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource HeroSurfaceStyle}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Welcome back" Style="{StaticResource MetadataTextStyle}"/>
                    <TextBlock Text="Everything in one polished desktop workspace"
                               Style="{StaticResource PrimaryHeadingTextStyle}"
                               Margin="0,4,0,10"/>
                    <TextBlock Text="Browse by category above or jump directly into a tool card below. Every tool is theme-aware, registered dynamically, and available from the shared shell."
                               Style="{StaticResource BodyTextStyle}"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Style="{StaticResource StatusSurfaceStyle}"
                        Padding="16"
                        Margin="18,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Quick Start" Style="{StaticResource SectionHeadingTextStyle}" FontSize="16"/>
                        <TextBlock Text="1. Choose a category from the top workspace bar." Style="{StaticResource MetadataTextStyle}" Margin="0,10,0,0"/>
                        <TextBlock Text="2. Open a tool card below for direct access." Style="{StaticResource MetadataTextStyle}" Margin="0,6,0,0"/>
                        <TextBlock Text="3. Use the theme control in the header to preview the app across styles." Style="{StaticResource MetadataTextStyle}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding DisplayTools}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding Key}"
                                Style="{StaticResource CardButtonStyle}"
                                Width="320"
                                Margin="0,0,14,14"
                                AutomationProperties.Name="{Binding Name}">
                            <StackPanel>
                                <Border Width="48"
                                        Height="48"
                                        CornerRadius="14"
                                        Background="{DynamicResource AppSurfaceElevatedBrush}"
                                        BorderBrush="{DynamicResource StrongBorderBrush}"
                                        BorderThickness="1"
                                        Margin="0,0,0,14">
                                    <TextBlock Text="{Binding IconGlyph}"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="22"
                                               Foreground="{DynamicResource AccentBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding Name}" Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock Text="{Binding Description}" Style="{StaticResource CardDescriptionStyle}"/>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
