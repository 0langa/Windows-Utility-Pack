<UserControl x:Class="WindowsUtilityPack.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WindowsUtilityPack.ViewModels">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Welcome Banner -->
        <Border Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="8" Padding="24,20" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Welcome to Windows Utility Pack"
                           FontSize="22" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8"/>
                <TextBlock Text="Select a category from the top navigation or click a card below to get started."
                           FontSize="14" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Feature Cards -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <UniformGrid Columns="3">
                <Button Command="{Binding NavigateCommand}" CommandParameter="storage-master"
                        Style="{StaticResource CardButtonStyle}" Margin="0,0,8,8">
                    <StackPanel>
                        <TextBlock Text="💽" FontSize="32" Margin="0,0,0,10"/>
                        <TextBlock Text="Storage Master" Style="{StaticResource CardTitleStyle}"/>
                        <TextBlock Text="Analyse storage, find duplicates, and clean up space."
                                   Style="{StaticResource CardDescriptionStyle}"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding NavigateCommand}" CommandParameter="bulk-renamer"
                        Style="{StaticResource CardButtonStyle}" Margin="4,0,4,8">
                    <StackPanel>
                        <TextBlock Text="📁" FontSize="32" Margin="0,0,0,10"/>
                        <TextBlock Text="Bulk File Renamer" Style="{StaticResource CardTitleStyle}"/>
                        <TextBlock Text="Rename files with prefix, suffix, or find-replace."
                                   Style="{StaticResource CardDescriptionStyle}"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding NavigateCommand}" CommandParameter="password-generator"
                        Style="{StaticResource CardButtonStyle}" Margin="8,0,0,8">
                    <StackPanel>
                        <TextBlock Text="🔒" FontSize="32" Margin="0,0,0,10"/>
                        <TextBlock Text="Password Generator" Style="{StaticResource CardTitleStyle}"/>
                        <TextBlock Text="Generate strong, random passwords instantly."
                                   Style="{StaticResource CardDescriptionStyle}"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding NavigateCommand}" CommandParameter="ping-tool"
                        Style="{StaticResource CardButtonStyle}" Margin="0,0,8,8">
                    <StackPanel>
                        <TextBlock Text="🌐" FontSize="32" Margin="0,0,0,10"/>
                        <TextBlock Text="Ping Tool" Style="{StaticResource CardTitleStyle}"/>
                        <TextBlock Text="Test network connectivity and measure latency."
                                   Style="{StaticResource CardDescriptionStyle}"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding NavigateCommand}" CommandParameter="regex-tester"
                        Style="{StaticResource CardButtonStyle}" Margin="4,0,4,8">
                    <StackPanel>
                        <TextBlock Text="💻" FontSize="32" Margin="0,0,0,10"/>
                        <TextBlock Text="Regex Tester" Style="{StaticResource CardTitleStyle}"/>
                        <TextBlock Text="Test and debug regular expressions interactively."
                                   Style="{StaticResource CardDescriptionStyle}"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding NavigateCommand}" CommandParameter="text-format-converter"
                        Style="{StaticResource CardButtonStyle}" Margin="8,0,0,8">
                    <StackPanel>
                        <TextBlock Text="🧾" FontSize="32" Margin="0,0,0,10"/>
                        <TextBlock Text="Text Format Converter" Style="{StaticResource CardTitleStyle}"/>
                        <TextBlock Text="Convert, format, preview, and export text across seven supported formats."
                                   Style="{StaticResource CardDescriptionStyle}"/>
                    </StackPanel>
                </Button>
            </UniformGrid>
        </ScrollViewer>
    </Grid>
</UserControl>
