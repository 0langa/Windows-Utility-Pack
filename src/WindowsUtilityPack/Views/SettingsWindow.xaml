<Window x:Class="WindowsUtilityPack.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="clr-namespace:WindowsUtilityPack.Services"
        Title="Settings"
        Width="720"
        Height="560"
        MinWidth="620"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        UseLayoutRounding="True"
        Background="{DynamicResource AppBackgroundBrush}">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeroSurfaceStyle}" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Settings" Style="{StaticResource PrimaryHeadingTextStyle}"/>
                    <TextBlock Text="Adjust appearance and shell behavior without leaving the current workflow."
                               Style="{StaticResource MetadataTextStyle}"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <Border Grid.Column="1" Style="{StaticResource StatusSurfaceStyle}" Margin="16,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Available Themes" Style="{StaticResource PanelHeaderTextStyle}"/>
                        <TextBlock Text="Dark" Style="{StaticResource MetadataTextStyle}" Margin="0,8,0,0"/>
                        <TextBlock Text="Light" Style="{StaticResource MetadataTextStyle}" Margin="0,4,0,0"/>
                        <TextBlock Text="Aurora" Style="{StaticResource MetadataTextStyle}" Margin="0,4,0,0"/>
                        <TextBlock Text="System" Style="{StaticResource MetadataTextStyle}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.3*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource ElevatedSurfaceStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Appearance" Style="{StaticResource SectionHeadingTextStyle}"/>
                        <TextBlock Text="Choose the global look and feel for the application shell and every tool page."
                                   Style="{StaticResource MetadataTextStyle}"
                                   Margin="0,4,0,12"/>

                        <RadioButton Content="Dark"
                                     IsChecked="{Binding SelectedTheme, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static svc:AppTheme.Dark}}"
                                     Margin="0,0,0,10"/>
                        <RadioButton Content="Light"
                                     IsChecked="{Binding SelectedTheme, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static svc:AppTheme.Light}}"
                                     Margin="0,0,0,10"/>
                        <RadioButton Content="Aurora"
                                     IsChecked="{Binding SelectedTheme, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static svc:AppTheme.Aurora}}"
                                     Margin="0,0,0,10"/>
                        <RadioButton Content="Use system setting"
                                     IsChecked="{Binding SelectedTheme, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static svc:AppTheme.System}}"/>

                        <Separator Margin="0,18,0,18"/>

                        <TextBlock Text="Shell Behavior" Style="{StaticResource SectionHeadingTextStyle}"/>
                        <TextBlock Text="These settings control how the main window remembers and restores its workspace."
                                   Style="{StaticResource MetadataTextStyle}"
                                   Margin="0,4,0,12"/>

                        <CheckBox Content="Remember window position and size"
                                  IsChecked="{Binding RememberWindowPosition}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource ElevatedSurfaceStyle}">
                <StackPanel>
                    <TextBlock Text="Preview Notes" Style="{StaticResource SectionHeadingTextStyle}"/>
                    <TextBlock Text="Dark is optimized for dense technical work, Light is balanced for daytime readability, and Aurora adds a more premium gradient-driven identity while keeping utility-first contrast."
                               Style="{StaticResource MetadataTextStyle}"
                               Margin="0,8,0,12"/>

                    <Border Style="{StaticResource StatusSurfaceStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Theme switching is live." Style="{StaticResource PanelHeaderTextStyle}"/>
                            <TextBlock Text="Changes apply immediately across shell, controls, surfaces, selections, menus, and tool pages."
                                       Style="{StaticResource MetadataTextStyle}"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatusSurfaceStyle}">
                        <StackPanel>
                            <TextBlock Text="Design-system direction" Style="{StaticResource PanelHeaderTextStyle}"/>
                            <TextBlock Text="All themes share the same semantic tokens, so future pages and future color schemes inherit the same spacing, states, and control quality automatically."
                                       Style="{StaticResource MetadataTextStyle}"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Close" Style="{StaticResource PrimaryActionButtonStyle}" Width="100" Click="OnCloseClick"/>
        </StackPanel>
    </Grid>
</Window>
