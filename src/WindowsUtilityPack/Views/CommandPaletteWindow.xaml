<Window x:Class="WindowsUtilityPack.Views.CommandPaletteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Command Palette"
        Width="760"
        Height="540"
        MinWidth="560"
        MinHeight="420"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackgroundBrush}"
        KeyDown="OnWindowKeyDown">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Command Palette"
                   Style="{StaticResource SectionHeadingTextStyle}"/>

        <TextBox x:Name="QueryBox"
                 Grid.Row="1"
                 Margin="0,10,0,10"
                 Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}"
                 MinHeight="40"
                 VerticalContentAlignment="Center"
                 FontSize="14"
                 ToolTip="Search tools and shell actions"/>

        <ListBox x:Name="ItemsList"
                 Grid.Row="2"
                 ItemsSource="{Binding Items}"
                 SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                 BorderThickness="1"
                 BorderBrush="{DynamicResource BorderBrush}"
                 Background="{DynamicResource AppSurfaceAltBrush}"
                 MouseDoubleClick="OnListDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding Title}" Style="{StaticResource PanelHeaderTextStyle}"/>
                            <TextBlock Text="{Binding Subtitle}" Style="{StaticResource MetadataTextStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="{DynamicResource CardBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    Padding="8,3"
                                    CornerRadius="8"
                                    Margin="0,0,6,0">
                                <TextBlock Text="{Binding Category}" Style="{StaticResource MetadataTextStyle}"/>
                            </Border>
                            <Border Background="{DynamicResource StatusSurfaceBrush}"
                                    BorderBrush="{DynamicResource StrongBorderBrush}"
                                    BorderThickness="1"
                                    Padding="8,3"
                                    CornerRadius="8">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShortcutHint}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding ShortcutHint}" Style="{StaticResource MetadataTextStyle}"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
