<UserControl x:Class="WindowsUtilityPack.Tools.DeveloperProductivity.DiffTool.DiffToolView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WindowsUtilityPack.Tools.DeveloperProductivity.DiffTool">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Diff Tool" FontSize="20" FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12"/>

        <!-- Controls -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <CheckBox Content="Ignore Whitespace" IsChecked="{Binding IgnoreWhitespace}"
                      Margin="0,0,16,0" VerticalAlignment="Center"/>
            <CheckBox Content="Ignore Case" IsChecked="{Binding IgnoreCase}"
                      Margin="0,0,16,0" VerticalAlignment="Center"/>
            <Button Content="⇅ Swap" Command="{Binding SwapCommand}"
                    Style="{StaticResource SecondaryActionButtonStyle}" Margin="0,0,8,0"/>
            <Button Content="Load Left File" Command="{Binding LoadLeftFileCommand}"
                    Style="{StaticResource SecondaryActionButtonStyle}" Margin="0,0,8,0"/>
            <Button Content="Load Right File" Command="{Binding LoadRightFileCommand}"
                    Style="{StaticResource SecondaryActionButtonStyle}" Margin="0,0,8,0"/>
            <Button Content="Copy Diff" Command="{Binding CopyDiffCommand}"
                    Style="{StaticResource SecondaryActionButtonStyle}" Margin="0,0,8,0"/>
            <Button Content="Clear" Command="{Binding ClearCommand}"
                    Style="{StaticResource SecondaryActionButtonStyle}"/>
        </StackPanel>

        <!-- Input panes -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource ToolPanelBorderStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="160"/>
                    </Grid.RowDefinitions>
                    <Border Background="{DynamicResource PanelBackgroundBrush}"
                            BorderBrush="{DynamicResource SubtleBorderBrush}" BorderThickness="0,0,0,1"
                            Padding="10,6">
                        <TextBlock Text="{Binding LeftLabel}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </Border>
                    <TextBox Grid.Row="1" Text="{Binding LeftText, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="12"
                             Foreground="{DynamicResource PrimaryTextBrush}"
                             BorderThickness="0" Padding="10"/>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource ToolPanelBorderStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="160"/>
                    </Grid.RowDefinitions>
                    <Border Background="{DynamicResource PanelBackgroundBrush}"
                            BorderBrush="{DynamicResource SubtleBorderBrush}" BorderThickness="0,0,0,1"
                            Padding="10,6">
                        <TextBlock Text="{Binding RightLabel}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </Border>
                    <TextBox Grid.Row="1" Text="{Binding RightText, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="12"
                             Foreground="{DynamicResource PrimaryTextBrush}"
                             BorderThickness="0" Padding="10"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Diff Result (unified view) -->
        <Border Grid.Row="3" Style="{StaticResource ToolPanelBorderStyle}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Background="{DynamicResource PanelBackgroundBrush}"
                        BorderBrush="{DynamicResource SubtleBorderBrush}" BorderThickness="0,0,0,1"
                        Padding="10,6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Diff Result" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,16,0"/>
                        <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11">
                            <Run Text="{Binding AddedCount, Mode=OneWay}" Foreground="Green"/>
                            <Run Text=" added  "/>
                            <Run Text="{Binding RemovedCount, Mode=OneWay}" Foreground="Red"/>
                            <Run Text=" removed  "/>
                            <Run Text="{Binding UnchangedCount, Mode=OneWay}"/>
                            <Run Text=" unchanged"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding DiffLines}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="{x:Static local:DiffType.Added}">
                                                    <Setter Property="Background" Value="#1A00AA00"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="{x:Static local:DiffType.Removed}">
                                                    <Setter Property="Background" Value="#1AAA0000"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <TextBlock Padding="2,1" FontFamily="Consolas" FontSize="12" FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value=" "/>
                                                <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Type}" Value="{x:Static local:DiffType.Added}">
                                                        <Setter Property="Text" Value="+"/>
                                                        <Setter Property="Foreground" Value="Green"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}" Value="{x:Static local:DiffType.Removed}">
                                                        <Setter Property="Text" Value="-"/>
                                                        <Setter Property="Foreground" Value="Red"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Grid.Column="1" Text="{Binding Content}"
                                               FontFamily="Consolas" FontSize="12" Padding="4,1"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Status -->
        <TextBlock Grid.Row="4" Text="{Binding StatusMessage}"
                   Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,6,0,0"/>
    </Grid>
</UserControl>
