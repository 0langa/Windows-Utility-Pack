<UserControl x:Class="WindowsUtilityPack.Tools.DeveloperProductivity.UuidGenerator.UuidGeneratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="8" MaxWidth="900">
            <TextBlock Text="UUID / GUID Generator" FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,16"/>

            <!-- Format and Count Settings -->
            <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Settings" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Format:" Width="80" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <ComboBox ItemsSource="{Binding Formats}"
                                  SelectedItem="{Binding Format}"
                                  Width="160" Padding="8,4"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Count:" Width="80" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding GenerateCount, UpdateSourceTrigger=PropertyChanged}"
                                 Width="80" Padding="6,4"
                                 Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="(max 1000)" VerticalAlignment="Center" Margin="8,0,0,0"
                                   Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Single UUID -->
            <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Single UUID" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12"/>
                    <TextBox Text="{Binding SingleId, Mode=OneWay}" IsReadOnly="True"
                             FontFamily="Consolas" FontSize="16" FontWeight="SemiBold"
                             Foreground="{DynamicResource AccentBrush}" Padding="10,8"
                             Margin="0,0,0,10" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Generate New" Command="{Binding GenerateSingleCommand}"
                                Style="{StaticResource PrimaryActionButtonStyle}"/>
                        <Button Content="Copy" Command="{Binding CopySingleCommand}"
                                Style="{StaticResource SecondaryActionButtonStyle}" Margin="8,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Bulk Generation -->
            <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Bulk Generation" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                        <Button Content="Generate Bulk" Command="{Binding GenerateBulkCommand}"
                                Style="{StaticResource PrimaryActionButtonStyle}" Margin="16,0,8,0"/>
                        <Button Content="Copy All" Command="{Binding CopyAllCommand}"
                                Style="{StaticResource SecondaryActionButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="Clear" Command="{Binding ClearCommand}"
                                Style="{StaticResource SecondaryActionButtonStyle}"/>
                    </StackPanel>

                    <Border BorderBrush="{DynamicResource SubtleBorderBrush}" BorderThickness="1"
                            CornerRadius="4" MaxHeight="300">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding GeneratedIds}" Padding="4">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Id}" FontFamily="Consolas" FontSize="12"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   Padding="6,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
