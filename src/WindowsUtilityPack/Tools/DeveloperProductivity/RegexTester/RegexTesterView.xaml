<UserControl x:Class="WindowsUtilityPack.Tools.DeveloperProductivity.RegexTester.RegexTesterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="{StaticResource IconRegex}"
                       FontFamily="Segoe MDL2 Assets" FontSize="20"
                       Foreground="{DynamicResource AccentBrush}"
                       VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock Text="Regex Tester" FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Pattern input and options -->
        <Border Grid.Row="1" Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="8" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Pattern:" Foreground="{DynamicResource SecondaryTextBrush}"
                               VerticalAlignment="Center" Width="70"/>
                    <TextBox Text="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}"
                             Width="350" FontFamily="Consolas" FontSize="13"
                             Foreground="{DynamicResource AccentBrush}"
                             Padding="8,6"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource SecondaryTextBrush}"
                               VerticalAlignment="Center" Margin="16,0,0,0" FontStyle="Italic"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Orientation="Horizontal">
                    <TextBlock Text="Options:" Foreground="{DynamicResource SecondaryTextBrush}"
                               VerticalAlignment="Center" Width="70"/>
                    <CheckBox Content="Ignore Case" IsChecked="{Binding IgnoreCase}"
                              Margin="0,0,16,0" VerticalAlignment="Center"/>
                    <CheckBox Content="Multiline" IsChecked="{Binding Multiline}"
                              Margin="0,0,16,0" VerticalAlignment="Center"/>
                    <CheckBox Content="Single Line" IsChecked="{Binding SingleLine}"
                              VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Input text -->
        <Border Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="8" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Style="{StaticResource TableHeaderBorderStyle}">
                    <TextBlock Text="Input Text" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                </Border>
                <TextBox Grid.Row="1" Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="12"
                         BorderThickness="0" Padding="12"/>
            </Grid>
        </Border>

        <!-- Match count header -->
        <TextBlock Grid.Row="3" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="13" Margin="0,0,0,8">
            <Run Text="Matches: "/>
            <Run Text="{Binding MatchCount}" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"/>
        </TextBlock>

        <!-- Match results -->
        <Border Grid.Row="4" Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Style="{StaticResource TableHeaderBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Index" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Grid.Column="1" Text="Length" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Grid.Column="2" Text="Match" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Grid.Column="3" Text="Groups" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </Grid>
                </Border>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Matches}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="12,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Index}" Foreground="{DynamicResource SecondaryTextBrush}" FontFamily="Consolas"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Length}" Foreground="{DynamicResource SecondaryTextBrush}" FontFamily="Consolas"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Value}" Foreground="{DynamicResource AccentBrush}" FontFamily="Consolas" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Groups}" Foreground="{DynamicResource PrimaryTextBrush}" FontFamily="Consolas" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
