<UserControl x:Class="WindowsUtilityPack.Tools.DeveloperProductivity.TimestampConverter.TimestampConverterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="4" MaxWidth="900">
            <TextBlock Text="Timestamp Converter" Style="{StaticResource ToolTitleTextStyle}" Margin="0,0,0,16"/>

            <!-- Use Now Button -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="Use Current Time" Command="{Binding UseNowCommand}"
                        Style="{StaticResource PrimaryActionButtonStyle}"/>
            </StackPanel>

            <!-- Unix → Human Section -->
            <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Unix → Human" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12"/>

                    <!-- Unix seconds input -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Unix Seconds:" Width="120" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding UnixSeconds, UpdateSourceTrigger=PropertyChanged}"
                                 Width="200" FontFamily="Consolas" FontSize="14"
                                 Foreground="{DynamicResource PrimaryTextBrush}" Padding="6,4"/>
                        <Button Content="Copy" Command="{Binding CopyUnixCommand}"
                                Style="{StaticResource SecondaryActionButtonStyle}" Margin="8,0,0,0"/>
                    </StackPanel>

                    <!-- Results grid -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Text="Unix Milliseconds:" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,4"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding UnixMilliseconds, Mode=OneWay}"
                                 IsReadOnly="True" FontFamily="Consolas"
                                 Foreground="{DynamicResource PrimaryTextBrush}" Padding="6,4" Margin="0,4"/>

                        <TextBlock Grid.Row="1" Text="UTC (ISO 8601):" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,4"/>
                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
                            <TextBox Text="{Binding HumanReadableUtc, Mode=OneWay}" IsReadOnly="True"
                                     Width="240" FontFamily="Consolas"
                                     Foreground="{DynamicResource PrimaryTextBrush}" Padding="6,4"/>
                            <Button Content="Copy" Command="{Binding CopyHumanCommand}"
                                    Style="{StaticResource SecondaryActionButtonStyle}" Margin="8,0,0,0"/>
                        </StackPanel>

                        <TextBlock Grid.Row="2" Text="Local Time:" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,4"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding HumanReadableLocal, Mode=OneWay}"
                                 IsReadOnly="True" FontFamily="Consolas"
                                 Foreground="{DynamicResource PrimaryTextBrush}" Padding="6,4" Margin="0,4"/>

                        <TextBlock Grid.Row="3" Text="Relative:" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,4"/>
                        <TextBlock Grid.Row="3" Grid.Column="1"
                                   Text="{Binding RelativeTime}" VerticalAlignment="Center"
                                   Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" Margin="6,4"/>

                        <TextBlock Grid.Row="4" Text="Custom Format:" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,4"/>
                        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
                            <TextBox Text="{Binding CustomFormat, UpdateSourceTrigger=PropertyChanged}"
                                     Width="160" FontFamily="Consolas"
                                     Foreground="{DynamicResource PrimaryTextBrush}" Padding="6,4"/>
                            <TextBox Text="{Binding CustomFormatResult, Mode=OneWay}" IsReadOnly="True"
                                     Width="200" FontFamily="Consolas"
                                     Foreground="{DynamicResource PrimaryTextBrush}" Padding="6,4" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Human → Unix Section -->
            <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Human → Unix" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Date/Time String:" Width="120" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding DateInput, UpdateSourceTrigger=PropertyChanged}"
                                 Width="280" FontFamily="Consolas"
                                 Foreground="{DynamicResource PrimaryTextBrush}" Padding="6,4"/>
                        <Button Content="Parse" Command="{Binding ParseDateCommand}"
                                Style="{StaticResource PrimaryActionButtonStyle}" Margin="8,0,0,0"/>
                    </StackPanel>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Text="Unix Seconds:" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,4"/>
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
                            <TextBox Text="{Binding ParsedUnixSeconds, Mode=OneWay}" IsReadOnly="True"
                                     Width="200" FontFamily="Consolas"
                                     Foreground="{DynamicResource PrimaryTextBrush}" Padding="6,4"/>
                            <Button Content="Copy" Command="{Binding CopyParsedUnixCommand}"
                                    Style="{StaticResource SecondaryActionButtonStyle}" Margin="8,0,0,0"/>
                        </StackPanel>

                        <TextBlock Grid.Row="1" Text="Unix Milliseconds:" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,4"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ParsedUnixMs, Mode=OneWay}"
                                 IsReadOnly="True" Width="200" FontFamily="Consolas"
                                 Foreground="{DynamicResource PrimaryTextBrush}" Padding="6,4" Margin="0,4"
                                 HorizontalAlignment="Left"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
