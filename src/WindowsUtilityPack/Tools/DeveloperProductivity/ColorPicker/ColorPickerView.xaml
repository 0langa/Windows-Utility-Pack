<UserControl x:Class="WindowsUtilityPack.Tools.DeveloperProductivity.ColorPicker.ColorPickerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="8" MaxWidth="900">
            <TextBlock Text="Color Picker" FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,16"/>

            <!-- Color Preview and Hex Input -->
            <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="16" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Large color swatch -->
                    <Border Grid.Column="0" Width="100" Height="100" CornerRadius="8"
                            BorderBrush="{DynamicResource SubtleBorderBrush}" BorderThickness="1"
                            Margin="0,0,16,0" VerticalAlignment="Top">
                        <Rectangle Fill="{Binding PreviewBrush}" RadiusX="7" RadiusY="7"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <!-- HEX -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="HEX" Width="60" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding HexColor, UpdateSourceTrigger=PropertyChanged}"
                                     Width="120" FontFamily="Consolas" FontSize="14"
                                     Foreground="{DynamicResource PrimaryTextBrush}" Padding="6,4"/>
                            <Button Content="Copy HEX" Command="{Binding CopyHexCommand}"
                                    Style="{StaticResource SecondaryActionButtonStyle}" Margin="8,0,0,0"/>
                        </StackPanel>

                        <!-- CSS RGB -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="CSS RGB" Width="60" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding CssRgb, Mode=OneWay}" IsReadOnly="True"
                                     Width="180" FontFamily="Consolas" FontSize="13"
                                     Foreground="{DynamicResource PrimaryTextBrush}" Padding="6,4"/>
                            <Button Content="Copy RGB" Command="{Binding CopyRgbCommand}"
                                    Style="{StaticResource SecondaryActionButtonStyle}" Margin="8,0,0,0"/>
                        </StackPanel>

                        <!-- CSS HSL -->
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="CSS HSL" Width="60" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding CssHsl, Mode=OneWay}" IsReadOnly="True"
                                     Width="180" FontFamily="Consolas" FontSize="13"
                                     Foreground="{DynamicResource PrimaryTextBrush}" Padding="6,4"/>
                            <Button Content="Copy HSL" Command="{Binding CopyHslCommand}"
                                    Style="{StaticResource SecondaryActionButtonStyle}" Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- RGB Sliders -->
            <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="RGB Channels" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12"/>

                    <!-- R -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="R" Foreground="Red" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" Minimum="0" Maximum="255" SmallChange="1" LargeChange="16"
                                Value="{Binding R}" VerticalAlignment="Center" Margin="8,0"/>
                        <TextBox Grid.Column="2" Text="{Binding R, UpdateSourceTrigger=PropertyChanged}"
                                 TextAlignment="Right" Padding="4,2"
                                 Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </Grid>

                    <!-- G -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="G" Foreground="Green" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" Minimum="0" Maximum="255" SmallChange="1" LargeChange="16"
                                Value="{Binding G}" VerticalAlignment="Center" Margin="8,0"/>
                        <TextBox Grid.Column="2" Text="{Binding G, UpdateSourceTrigger=PropertyChanged}"
                                 TextAlignment="Right" Padding="4,2"
                                 Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </Grid>

                    <!-- B -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="B" Foreground="Blue" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" Minimum="0" Maximum="255" SmallChange="1" LargeChange="16"
                                Value="{Binding B}" VerticalAlignment="Center" Margin="8,0"/>
                        <TextBox Grid.Column="2" Text="{Binding B, UpdateSourceTrigger=PropertyChanged}"
                                 TextAlignment="Right" Padding="4,2"
                                 Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- HSL Display (read-only) -->
            <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="HSL Values (computed)" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="H:" Width="24" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding H, Mode=OneWay, StringFormat={}{0:F1}°}" IsReadOnly="True"
                                 Width="80" FontFamily="Consolas" Padding="6,4"
                                 Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,16,0"/>
                        <TextBlock Text="S:" Width="24" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding S, Mode=OneWay, StringFormat={}{0:F1}%}" IsReadOnly="True"
                                 Width="80" FontFamily="Consolas" Padding="6,4"
                                 Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,16,0"/>
                        <TextBlock Text="L:" Width="24" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding L, Mode=OneWay, StringFormat={}{0:F1}%}" IsReadOnly="True"
                                 Width="80" FontFamily="Consolas" Padding="6,4"
                                 Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Palette -->
            <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Color Palette" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12"/>

                    <!-- Add to Palette -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBox Text="{Binding PaletteName, UpdateSourceTrigger=PropertyChanged}"
                                 Width="200" Padding="6,4"
                                 Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <Button Content="Add to Palette" Command="{Binding AddToPaletteCommand}"
                                Style="{StaticResource PrimaryActionButtonStyle}" Margin="8,0,0,0"/>
                        <Button Content="Clear All" Command="{Binding ClearPaletteCommand}"
                                Style="{StaticResource SecondaryActionButtonStyle}" Margin="8,0,0,0"/>
                    </StackPanel>

                    <!-- Palette items -->
                    <ItemsControl ItemsSource="{Binding Palette}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="80" Margin="4" CornerRadius="6"
                                        BorderBrush="{DynamicResource SubtleBorderBrush}" BorderThickness="1"
                                        Cursor="Hand">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.SelectPaletteColorCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <StackPanel>
                                        <Border Height="40" CornerRadius="6,6,0,0">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding Color}"/>
                                            </Border.Background>
                                        </Border>
                                        <StackPanel Margin="4,2">
                                            <TextBlock Text="{Binding Name}" FontSize="10"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Hex}" FontSize="10" FontFamily="Consolas"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            <Button Content="Remove"
                                                    Command="{Binding DataContext.RemoveFromPaletteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    FontSize="9" Padding="2,1"
                                                    Style="{StaticResource SecondaryActionButtonStyle}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
