<UserControl x:Class="WindowsUtilityPack.Tools.DeveloperProductivity.ApiMockServer.ApiMockServerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="API Mock Server" Style="{StaticResource ToolTitleTextStyle}" Margin="0,0,0,12"/>

        <Border Grid.Row="1" Style="{StaticResource ToolPanelBorderStyle}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" Margin="0,0,8,0" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center"/>
                <Button Grid.Column="1" Margin="0,0,8,0" Content="Start" Command="{Binding StartCommand}" Style="{StaticResource PrimaryActionButtonStyle}"/>
                <Button Grid.Column="2" Margin="0,0,8,0" Content="Stop" Command="{Binding StopCommand}" Style="{StaticResource SecondaryActionButtonStyle}"/>
                <Button Grid.Column="3" Margin="0,0,8,0" Content="Save Endpoints" Command="{Binding SaveEndpointsCommand}" Style="{StaticResource SecondaryActionButtonStyle}"/>
                <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="{Binding BaseUrl}" Style="{StaticResource MetadataTextStyle}"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource ToolPanelBorderStyle}" Margin="0,0,0,12">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,8">
                    <Button Content="Add Endpoint" Command="{Binding AddEndpointCommand}" Margin="0,0,8,0" Style="{StaticResource SecondaryActionButtonStyle}"/>
                    <Button Content="Remove Selected" Command="{Binding RemoveEndpointCommand}" Style="{StaticResource DangerActionButtonStyle}"/>
                </StackPanel>

                <DataGrid ItemsSource="{Binding Endpoints}"
                          SelectedItem="{Binding SelectedEndpoint, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="False"
                          GridLinesVisibility="Horizontal"
                          RowHeaderWidth="0">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding Enabled, Mode=TwoWay}" Width="80"/>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                        <DataGridTextColumn Header="Method" Binding="{Binding Method, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                        <DataGridTextColumn Header="Path" Binding="{Binding Path, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="170"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding StatusCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                        <DataGridTextColumn Header="Content Type" Binding="{Binding ContentType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="160"/>
                        <DataGridTextColumn Header="Response Body" Binding="{Binding ResponseBody, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource ToolPanelBorderStyle}">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,8">
                    <Button Content="Refresh Log" Command="{Binding RefreshLogCommand}" Margin="0,0,8,0" Style="{StaticResource SecondaryActionButtonStyle}"/>
                    <Button Content="Clear Log" Command="{Binding ClearLogCommand}" Style="{StaticResource SecondaryActionButtonStyle}"/>
                </StackPanel>

                <DataGrid ItemsSource="{Binding RequestLog}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          RowHeaderWidth="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time (UTC)" Binding="{Binding TimestampUtc, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="170"/>
                        <DataGridTextColumn Header="Method" Binding="{Binding Method}" Width="80"/>
                        <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="200"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding StatusCode}" Width="80"/>
                        <DataGridTextColumn Header="Endpoint" Binding="{Binding EndpointName}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <Border Grid.Row="4" Margin="0,12,0,0" Style="{StaticResource StatusSurfaceStyle}">
            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource MetadataTextStyle}"/>
        </Border>
    </Grid>
</UserControl>