<UserControl x:Class="WindowsUtilityPack.Tools.ImageTools.ImageFormatConverter.ImageFormatConverterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Image Format Converter"
                   Style="{StaticResource ToolTitleTextStyle}"
                   Margin="0,0,0,12"/>

        <Border Grid.Row="1" Style="{StaticResource ToolPanelBorderStyle}" Margin="0,0,0,10">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="Add Files" Command="{Binding AddFilesCommand}" Style="{StaticResource SecondaryActionButtonStyle}" Margin="0,0,8,0"/>
                    <Button Content="Remove Selected" Command="{Binding RemoveSelectedFileCommand}" Style="{StaticResource SecondaryActionButtonStyle}" Margin="0,0,8,0"/>
                    <Button Content="Clear" Command="{Binding ClearFilesCommand}" Style="{StaticResource SecondaryActionButtonStyle}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Content="Browse Output Folder" Command="{Binding BrowseOutputDirectoryCommand}" Style="{StaticResource SecondaryActionButtonStyle}" Margin="0,0,8,0"/>
                    <Button Content="Convert" Command="{Binding ConvertCommand}" Style="{StaticResource PrimaryActionButtonStyle}" Margin="0,0,8,0"/>
                    <Button Content="Cancel" Command="{Binding CancelCommand}" Style="{StaticResource SecondaryActionButtonStyle}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource ToolPanelBorderStyle}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding OutputDirectory}" IsReadOnly="True" Margin="0,0,10,0"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,0" VerticalAlignment="Center">
                    <TextBlock Text="Format:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox Width="100" ItemsSource="{Binding TargetFormats}" SelectedItem="{Binding TargetFormat}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,10,0" VerticalAlignment="Center">
                    <TextBlock Text="Quality:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox Width="50" Text="{Binding Quality, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <CheckBox Grid.Column="3" Content="Overwrite Existing" IsChecked="{Binding OverwriteExisting}" VerticalAlignment="Center"/>
                <Button Grid.Column="4" Content="Copy Summary" Command="{Binding CopySummaryCommand}" Style="{StaticResource SecondaryActionButtonStyle}" Margin="10,0,0,0"/>
            </Grid>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource ToolPanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Input Files" Style="{StaticResource PanelHeaderTextStyle}" Margin="0,0,0,8"/>
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding InputFiles}"
                             SelectedItem="{Binding SelectedInputFile, Mode=TwoWay}"
                             FontFamily="Consolas"
                             FontSize="12"/>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource ToolPanelBorderStyle}">
                <DataGrid ItemsSource="{Binding Results}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="OK" Binding="{Binding Success}" Width="50"/>
                        <DataGridTextColumn Header="Input" Binding="{Binding Input}" Width="180"/>
                        <DataGridTextColumn Header="Output" Binding="{Binding Output}" Width="*"/>
                        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="220"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <Border Grid.Row="4" Style="{StaticResource ToolPanelBorderStyle}" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}"/>
        </Border>
    </Grid>
</UserControl>

