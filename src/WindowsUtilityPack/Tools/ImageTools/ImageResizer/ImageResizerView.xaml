<UserControl x:Class="WindowsUtilityPack.Tools.ImageTools.ImageResizer.ImageResizerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Image Resizer &amp; Compressor"
                   Style="{StaticResource ToolTitleTextStyle}"
                   Margin="0,0,0,12"/>

        <Border Grid.Row="1" Style="{StaticResource ToolPanelBorderStyle}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <DockPanel>
                    <Button Content="Add Files" Command="{Binding AddFilesCommand}" Style="{StaticResource SecondaryActionButtonStyle}" Margin="0,0,8,0"/>
                    <Button Content="Remove Selected" Command="{Binding RemoveSelectedFileCommand}" Style="{StaticResource SecondaryActionButtonStyle}" Margin="0,0,8,0"/>
                    <Button Content="Clear" Command="{Binding ClearFilesCommand}" Style="{StaticResource SecondaryActionButtonStyle}"/>
                </DockPanel>
                <DockPanel Grid.Column="1">
                    <Button Content="Browse Output Folder" Command="{Binding BrowseOutputDirectoryCommand}" Style="{StaticResource SecondaryActionButtonStyle}" Margin="0,0,8,0"/>
                    <Button Content="Start Resize" Command="{Binding ResizeCommand}" Style="{StaticResource PrimaryActionButtonStyle}" Margin="0,0,8,0"/>
                    <Button Content="Cancel" Command="{Binding CancelCommand}" Style="{StaticResource SecondaryActionButtonStyle}"/>
                </DockPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource ToolPanelBorderStyle}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" Text="{Binding OutputDirectory}" IsReadOnly="True" Margin="0,0,10,0"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,0" VerticalAlignment="Center">
                    <TextBlock Text="W:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox Width="70" Text="{Binding Width, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,10,0" VerticalAlignment="Center">
                    <TextBlock Text="H:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox Width="70" Text="{Binding Height, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <ComboBox Grid.Column="3" Width="90" Margin="0,0,10,0" ItemsSource="{Binding Formats}" SelectedItem="{Binding Format}"/>
                <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="0,0,10,0" VerticalAlignment="Center">
                    <TextBlock Text="Quality:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox Width="50" Text="{Binding Quality, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox Content="Keep aspect" IsChecked="{Binding KeepAspectRatio}" Margin="0,0,8,0"/>
                    <CheckBox Content="Overwrite" IsChecked="{Binding OverwriteExisting}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource ToolPanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Input Files" Style="{StaticResource PanelHeaderTextStyle}" Margin="0,0,0,8"/>
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding InputFiles}"
                             SelectedItem="{Binding SelectedInputFile, Mode=TwoWay}"
                             FontFamily="Consolas"
                             FontSize="12"/>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource ToolPanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="Output Summary" Style="{StaticResource PanelHeaderTextStyle}" DockPanel.Dock="Left"/>
                        <Button Content="Copy Summary" Command="{Binding CopySummaryCommand}" DockPanel.Dock="Right" Style="{StaticResource SecondaryActionButtonStyle}"/>
                    </DockPanel>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Results}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="OK" Binding="{Binding Success}" Width="50"/>
                            <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="160"/>
                            <DataGridTextColumn Header="Details" Binding="{Binding SizeSummary}" Width="*"/>
                            <DataGridTextColumn Header="Error" Binding="{Binding Error}" Width="220"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="4" Style="{StaticResource ToolPanelBorderStyle}" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
        </Border>
    </Grid>
</UserControl>

