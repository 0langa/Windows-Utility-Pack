<UserControl x:Class="WindowsUtilityPack.Tools.ImageTools.ScreenshotAnnotator.ScreenshotAnnotatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:WindowsUtilityPack.Converters"
             PreviewKeyDown="OnRootPreviewKeyDown">
    <UserControl.Resources>
        <converters:ArrowHeadPointsConverter x:Key="ArrowHeadPointsConverter"/>
    </UserControl.Resources>
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Screenshot Annotator"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryTextBrush}"
                   Margin="0,0,0,12"/>

        <Border Grid.Row="1" Style="{StaticResource ToolPanelBorderStyle}" Margin="0,0,0,10">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="Capture Screenshot" Command="{Binding CaptureScreenshotCommand}" Style="{StaticResource PrimaryActionButtonStyle}" Margin="0,0,8,0"/>
                    <Button Content="Load Image" Command="{Binding LoadImageCommand}" Style="{StaticResource SecondaryActionButtonStyle}" Margin="0,0,8,0"/>
                    <Button Content="Save Annotated" Command="{Binding SaveAnnotatedImageCommand}" Style="{StaticResource PrimaryActionButtonStyle}" Margin="0,0,8,0"/>
                    <Button Content="Copy Output Path" Command="{Binding CopyOutputPathCommand}" Style="{StaticResource SecondaryActionButtonStyle}"/>
                    <Button Content="Open Output Folder" Command="{Binding OpenOutputFolderCommand}" Style="{StaticResource SecondaryActionButtonStyle}" Margin="8,0,0,0"/>
                </StackPanel>
                <Button Content="Browse Output..." Command="{Binding BrowseOutputCommand}" DockPanel.Dock="Right" Style="{StaticResource SecondaryActionButtonStyle}"/>
            </DockPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource ToolPanelBorderStyle}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding ImagePath}" IsReadOnly="True" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" Text="{Binding OutputPath}" IsReadOnly="True"/>
            </Grid>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource ToolPanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Preview" Style="{StaticResource PanelHeaderTextStyle}" Margin="0,0,0,8"/>
                    <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Background="{DynamicResource PanelBackgroundBrush}">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <Grid x:Name="PreviewSurface"
                                  Width="{Binding PreviewPixelWidth}"
                                  Height="{Binding PreviewPixelHeight}"
                                  Background="Transparent"
                                  MouseLeftButtonDown="OnPreviewSurfaceMouseLeftButtonDown"
                                  MouseMove="OnPreviewSurfaceMouseMove"
                                  MouseLeftButtonUp="OnPreviewSurfaceMouseLeftButtonUp"
                                  MouseLeave="OnPreviewSurfaceMouseLeave">
                                <Image Source="{Binding PreviewImage}" Stretch="None" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                                <ItemsControl ItemsSource="{Binding Annotations}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                            <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="OnAnnotationMouseLeftButtonDown"/>
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Width="{Binding Width}" Height="{Binding Height}">
                                                <Border x:Name="ShapeBorder"
                                                        Width="{Binding Width}"
                                                        Height="{Binding Height}"
                                                        BorderThickness="{Binding Thickness}"
                                                        BorderBrush="{Binding Color}"
                                                        Background="#20FFFFFF"/>
                                                <TextBlock x:Name="ShapeText"
                                                           Text="{Binding Text}"
                                                           Foreground="{Binding Color}"
                                                           FontWeight="SemiBold"
                                                           Margin="6,4,6,4"
                                                           TextWrapping="Wrap"
                                                           Visibility="Collapsed"/>
                                                <TextBox x:Name="EditTextBox"
                                                         Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                                         Foreground="{Binding Color}"
                                                         FontWeight="SemiBold"
                                                         Background="#AA000000"
                                                         BorderBrush="{Binding Color}"
                                                         BorderThickness="1"
                                                         Padding="6,4,6,4"
                                                         TextWrapping="Wrap"
                                                         Visibility="Collapsed"
                                                         LostFocus="OnTextEditorLostFocus"
                                                         KeyDown="OnTextEditorKeyDown"/>
                                                <Grid x:Name="ArrowGrid" Visibility="Collapsed">
                                                    <Line X1="{Binding ArrowStartLocalX}" Y1="{Binding ArrowStartLocalY}"
                                                          X2="{Binding ArrowEndLocalX}"
                                                          Y2="{Binding ArrowEndLocalY}"
                                                          Stroke="{Binding Color}"
                                                          StrokeThickness="{Binding Thickness}"/>
                                                    <Polygon Fill="{Binding Color}">
                                                        <Polygon.Points>
                                                            <MultiBinding Converter="{StaticResource ArrowHeadPointsConverter}">
                                                                <Binding Path="ArrowStartLocalX"/>
                                                                <Binding Path="ArrowStartLocalY"/>
                                                                <Binding Path="ArrowEndLocalX"/>
                                                                <Binding Path="ArrowEndLocalY"/>
                                                            </MultiBinding>
                                                        </Polygon.Points>
                                                    </Polygon>
                                                </Grid>
                                            </Grid>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="Text">
                                                    <Setter TargetName="ShapeBorder" Property="BorderThickness" Value="1"/>
                                                    <Setter TargetName="ShapeBorder" Property="Background" Value="#22000000"/>
                                                    <Setter TargetName="ShapeText" Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter TargetName="ShapeText" Property="Visibility" Value="Collapsed"/>
                                                    <Setter TargetName="EditTextBox" Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="Redaction">
                                                    <Setter TargetName="ShapeBorder" Property="Background" Value="#CC000000"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="Blur">
                                                    <Setter TargetName="ShapeBorder" Property="Background" Value="#88A0A0A0"/>
                                                    <Setter TargetName="ShapeBorder" Property="BorderBrush" Value="#FFFFFFFF"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="Arrow">
                                                    <Setter TargetName="ShapeBorder" Property="Visibility" Value="Collapsed"/>
                                                    <Setter TargetName="ShapeText" Property="Visibility" Value="Collapsed"/>
                                                    <Setter TargetName="ArrowGrid" Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <ContentControl Content="{Binding DragPreviewAnnotation}" IsHitTestVisible="False">
                                    <ContentControl.ContentTemplate>
                                        <DataTemplate>
                                            <Grid Width="{Binding Width}" Height="{Binding Height}">
                                                <Grid.RenderTransform>
                                                    <TranslateTransform X="{Binding X}" Y="{Binding Y}"/>
                                                </Grid.RenderTransform>
                                                <Rectangle Stroke="{Binding Color}"
                                                           StrokeThickness="{Binding Thickness}"
                                                           StrokeDashArray="4,3"
                                                           Fill="#12FFFFFF"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ContentControl.ContentTemplate>
                                </ContentControl>

                                <Canvas IsHitTestVisible="True" Visibility="Visible">
                                    <Canvas.Style>
                                        <Style TargetType="Canvas">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedAnnotation}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Canvas.Style>

                                    <!-- Box selection outline (non-arrow) -->
                                    <Rectangle Stroke="{DynamicResource AccentBrush}"
                                               StrokeThickness="1"
                                               Fill="#00000000"
                                               Width="{Binding SelectedAnnotation.Width}"
                                               Height="{Binding SelectedAnnotation.Height}"
                                               Canvas.Left="{Binding SelectedAnnotation.X}"
                                               Canvas.Top="{Binding SelectedAnnotation.Y}">
                                        <Rectangle.Style>
                                            <Style TargetType="Rectangle">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedAnnotation.Type}" Value="Arrow">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Rectangle.Style>
                                    </Rectangle>

                                    <!-- Arrow selection line (arrow only) -->
                                    <Line Stroke="{DynamicResource AccentBrush}"
                                          StrokeThickness="2"
                                          X1="{Binding SelectedAnnotation.StartX}"
                                          Y1="{Binding SelectedAnnotation.StartY}"
                                          X2="{Binding SelectedAnnotation.EndX}"
                                          Y2="{Binding SelectedAnnotation.EndY}">
                                        <Line.Style>
                                            <Style TargetType="Line">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedAnnotation.Type}" Value="Arrow">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Line.Style>
                                    </Line>

                                    <!-- Corner resize handles (non-arrow) -->
                                    <Canvas>
                                        <Canvas.Style>
                                            <Style TargetType="Canvas">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedAnnotation.Type}" Value="Arrow">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Canvas.Style>

                                        <Rectangle Width="10" Height="10" Fill="{DynamicResource AccentBrush}"
                                                   Canvas.Left="{Binding SelectedAnnotation.X}"
                                                   Canvas.Top="{Binding SelectedAnnotation.Y}"
                                                   Cursor="SizeNWSE"
                                                   MouseLeftButtonDown="OnResizeHandleMouseLeftButtonDown"
                                                   Tag="TopLeft">
                                            <Rectangle.RenderTransform>
                                                <TranslateTransform X="-5" Y="-5"/>
                                            </Rectangle.RenderTransform>
                                        </Rectangle>
                                        <Rectangle Width="10" Height="10" Fill="{DynamicResource AccentBrush}"
                                                   Canvas.Left="{Binding SelectedAnnotation.X}"
                                                   Canvas.Top="{Binding SelectedAnnotation.Y}"
                                                   Cursor="SizeNESW"
                                                   MouseLeftButtonDown="OnResizeHandleMouseLeftButtonDown"
                                                   Tag="TopRight">
                                            <Rectangle.RenderTransform>
                                                <TranslateTransform X="{Binding SelectedAnnotation.Width}" Y="-5"/>
                                            </Rectangle.RenderTransform>
                                        </Rectangle>
                                        <Rectangle Width="10" Height="10" Fill="{DynamicResource AccentBrush}"
                                                   Canvas.Left="{Binding SelectedAnnotation.X}"
                                                   Canvas.Top="{Binding SelectedAnnotation.Y}"
                                                   Cursor="SizeNESW"
                                                   MouseLeftButtonDown="OnResizeHandleMouseLeftButtonDown"
                                                   Tag="BottomLeft">
                                            <Rectangle.RenderTransform>
                                                <TranslateTransform X="-5" Y="{Binding SelectedAnnotation.Height}"/>
                                            </Rectangle.RenderTransform>
                                        </Rectangle>
                                        <Rectangle Width="10" Height="10" Fill="{DynamicResource AccentBrush}"
                                                   Canvas.Left="{Binding SelectedAnnotation.X}"
                                                   Canvas.Top="{Binding SelectedAnnotation.Y}"
                                                   Cursor="SizeNWSE"
                                                   MouseLeftButtonDown="OnResizeHandleMouseLeftButtonDown"
                                                   Tag="BottomRight">
                                            <Rectangle.RenderTransform>
                                                <TranslateTransform X="{Binding SelectedAnnotation.Width}" Y="{Binding SelectedAnnotation.Height}"/>
                                            </Rectangle.RenderTransform>
                                        </Rectangle>
                                    </Canvas>

                                    <!-- Arrow endpoint handles (arrow only) -->
                                    <Canvas>
                                        <Canvas.Style>
                                            <Style TargetType="Canvas">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedAnnotation.Type}" Value="Arrow">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Canvas.Style>

                                        <Ellipse Width="12" Height="12" Fill="{DynamicResource AccentBrush}"
                                                 Canvas.Left="{Binding SelectedAnnotation.StartX}"
                                                 Canvas.Top="{Binding SelectedAnnotation.StartY}"
                                                 Cursor="Pen"
                                                 MouseLeftButtonDown="OnResizeHandleMouseLeftButtonDown"
                                                 Tag="ArrowStart">
                                            <Ellipse.RenderTransform>
                                                <TranslateTransform X="-6" Y="-6"/>
                                            </Ellipse.RenderTransform>
                                        </Ellipse>
                                        <Ellipse Width="12" Height="12" Fill="{DynamicResource AccentBrush}"
                                                 Canvas.Left="{Binding SelectedAnnotation.EndX}"
                                                 Canvas.Top="{Binding SelectedAnnotation.EndY}"
                                                 Cursor="Pen"
                                                 MouseLeftButtonDown="OnResizeHandleMouseLeftButtonDown"
                                                 Tag="ArrowEnd">
                                            <Ellipse.RenderTransform>
                                                <TranslateTransform X="-6" Y="-6"/>
                                            </Ellipse.RenderTransform>
                                        </Ellipse>
                                    </Canvas>
                                </Canvas>
                            </Grid>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource ToolPanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Annotation Builder" Style="{StaticResource PanelHeaderTextStyle}" Margin="0,0,0,8"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Type" Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding AnnotationTypes}" SelectedItem="{Binding AnnotationType}" Margin="0,0,0,8"/>

                        <TextBlock Text="X" Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AnnotationType}" Value="Arrow">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding X, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AnnotationType}" Value="Arrow">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <TextBlock Text="Start X" Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AnnotationType}" Value="Arrow">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ArrowStartX, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AnnotationType}" Value="Arrow">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <TextBlock Text="Y" Grid.Row="2" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AnnotationType}" Value="Arrow">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Y, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AnnotationType}" Value="Arrow">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <TextBlock Text="Start Y" Grid.Row="2" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AnnotationType}" Value="Arrow">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ArrowStartY, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AnnotationType}" Value="Arrow">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <TextBlock Text="Width" Grid.Row="3" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AnnotationType}" Value="Arrow">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Width, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AnnotationType}" Value="Arrow">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <TextBlock Text="End X" Grid.Row="3" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AnnotationType}" Value="Arrow">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding ArrowEndX, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AnnotationType}" Value="Arrow">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <TextBlock Text="Height" Grid.Row="4" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AnnotationType}" Value="Arrow">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Height, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AnnotationType}" Value="Arrow">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <TextBlock Text="End Y" Grid.Row="4" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AnnotationType}" Value="Arrow">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding ArrowEndY, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AnnotationType}" Value="Arrow">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                            <TextBlock Text="Color" Grid.Row="5" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding AnnotationColor, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                        <TextBlock Text="Thickness" Grid.Row="6" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding AnnotationThickness, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                        <TextBlock Text="Text" Grid.Row="7" Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding AnnotationText, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Grid.Row="0">
                            <Button Content="Add Annotation" Command="{Binding AddAnnotationCommand}" Style="{StaticResource PrimaryActionButtonStyle}" Margin="0,0,8,0"/>
                            <Button Content="Apply to Selected" Command="{Binding ApplyEditorToSelectedCommand}" Style="{StaticResource SecondaryActionButtonStyle}" Margin="0,0,8,0"/>
                            <Button Content="Duplicate Selected" Command="{Binding DuplicateSelectedAnnotationCommand}" Style="{StaticResource SecondaryActionButtonStyle}" Margin="0,0,8,0"/>
                            <Button Content="Undo" Command="{Binding UndoCommand}" Style="{StaticResource SecondaryActionButtonStyle}" Margin="0,0,8,0"/>
                            <Button Content="Redo" Command="{Binding RedoCommand}" Style="{StaticResource SecondaryActionButtonStyle}" Margin="0,0,8,0"/>
                            <Button Content="Remove Selected" Command="{Binding RemoveSelectedAnnotationCommand}" Style="{StaticResource SecondaryActionButtonStyle}" Margin="0,0,8,0"/>
                            <Button Content="Clear" Command="{Binding ClearAnnotationsCommand}" Style="{StaticResource SecondaryActionButtonStyle}"/>
                        </StackPanel>
                        <TextBlock Grid.Row="1" Text="Tip: coordinates are pixel positions in the source image, and the preview now shows annotation overlays at native image size." Margin="0,6,0,6" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                        <DataGrid Grid.Row="2"
                                  ItemsSource="{Binding Annotations}"
                                  SelectedItem="{Binding SelectedAnnotation, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="80"/>
                                <DataGridTextColumn Header="X" Binding="{Binding X}" Width="52"/>
                                <DataGridTextColumn Header="Y" Binding="{Binding Y}" Width="52"/>
                                <DataGridTextColumn Header="W" Binding="{Binding Width}" Width="52"/>
                                <DataGridTextColumn Header="H" Binding="{Binding Height}" Width="52"/>
                                <DataGridTextColumn Header="Color" Binding="{Binding Color}" Width="90"/>
                                <DataGridTextColumn Header="Text" Binding="{Binding Text}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="4" Style="{StaticResource ToolPanelBorderStyle}" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}"/>
        </Border>
    </Grid>
</UserControl>
