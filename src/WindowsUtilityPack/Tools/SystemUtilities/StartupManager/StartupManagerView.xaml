<UserControl x:Class="WindowsUtilityPack.Tools.SystemUtilities.StartupManager.StartupManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             >
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="8" MaxWidth="900">

            <!-- Header -->
            <TextBlock Text="Startup Manager" FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,4"/>
            <TextBlock Text="Programs that launch when Windows starts"
                       FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,16"/>

            <!-- Loading indicator -->
            <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="8"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                    Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Loading…" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource WarningStatusSurfaceStyle}"
                    Padding="10,8"
                    Margin="0,0,0,8"
                    Visibility="{Binding HklmEntriesSkipped, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="Some HKLM startup entries could not be read. Run as Administrator for full visibility."
                           Foreground="{DynamicResource WarningBrush}"
                           TextWrapping="Wrap"
                           FontSize="12"/>
            </Border>

            <!-- DataGrid panel -->
            <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="0" Margin="0,0,0,12">
                <DataGrid ItemsSource="{Binding Entries}"
                          SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          Background="{DynamicResource CardBackgroundBrush}"
                          RowBackground="{DynamicResource CardBackgroundBrush}"
                          AlternatingRowBackground="{DynamicResource PanelBackgroundBrush}"
                          BorderThickness="0"
                          MinHeight="200"
                          MaxHeight="450">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name"    Binding="{Binding Name}"    Width="180"/>
                        <DataGridTextColumn Header="Command" Binding="{Binding Command}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Source"  Binding="{Binding Source}"  Width="70"/>
                        <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding IsEnabled}" Width="70"/>
                        <DataGridCheckBoxColumn Header="Target Exists" Binding="{Binding TargetExists}" Width="95"/>
                        <DataGridCheckBoxColumn Header="Risk" Binding="{Binding IsPotentiallyRisky}" Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Toolbar -->
            <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="12" Margin="0,0,0,8">
                <WrapPanel Orientation="Horizontal">
                    <Button Content="Enable / Disable"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Command="{Binding ToggleCommand}"
                            Margin="0,0,8,0"/>
                    <Button Content="Remove"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Command="{Binding RemoveCommand}"
                            Margin="0,0,8,0"/>
                    <Button Content="Refresh"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Command="{Binding RefreshCommand}" Margin="0,0,8,0"/>
                        <Button Content="Export CSV"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Command="{Binding ExportCsvCommand}" Margin="0,0,8,0"/>
                        <Button Content="Copy Diagnostics"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Command="{Binding CopyDiagnosticsCommand}"/>
                </WrapPanel>
            </Border>

                    <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="8,6" Margin="0,0,0,8">
                    <TextBlock Text="{Binding EntryDiagnosticsSummary}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="12"/>
                    </Border>

            <!-- Status bar -->
            <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="8,6">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="12"/>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
