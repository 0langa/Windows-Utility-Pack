<UserControl x:Class="WindowsUtilityPack.Tools.SystemUtilities.BackgroundTaskMonitor.BackgroundTaskMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Background Task Monitor"
                   Style="{StaticResource PrimaryHeadingTextStyle}"
                   Margin="0,0,0,12"/>

        <Border Grid.Row="1" Style="{StaticResource ToolPanelBorderStyle}" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <Button Content="Refresh"
                        Command="{Binding RefreshCommand}"
                        Margin="0,0,8,0"
                        Style="{StaticResource SecondaryActionButtonStyle}"/>
                <Button Content="Cancel Selected"
                        Command="{Binding CancelSelectedCommand}"
                        Style="{StaticResource DangerActionButtonStyle}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource ToolPanelBorderStyle}">
            <ListView ItemsSource="{Binding TaskItems}"
                      SelectedItem="{Binding SelectedTask, Mode=TwoWay}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Name" Width="210" DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="State" Width="110" DisplayMemberBinding="{Binding State}"/>
                        <GridViewColumn Header="Progress" Width="90" DisplayMemberBinding="{Binding Percent}"/>
                        <GridViewColumn Header="Message" Width="280" DisplayMemberBinding="{Binding Message}"/>
                        <GridViewColumn Header="Detail" Width="300" DisplayMemberBinding="{Binding Detail}"/>
                        <GridViewColumn Header="Started" Width="190" DisplayMemberBinding="{Binding StartedUtc}"/>
                        <GridViewColumn Header="Finished" Width="190" DisplayMemberBinding="{Binding FinishedUtc}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <Border Grid.Row="3" Margin="0,12,0,0" Style="{StaticResource StatusSurfaceStyle}">
            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource MetadataTextStyle}"/>
        </Border>
    </Grid>
</UserControl>