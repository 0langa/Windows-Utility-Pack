<UserControl x:Class="WindowsUtilityPack.Tools.SystemUtilities.HostsFileEditor.HostsFileEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             >
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="8" MaxWidth="900">

            <!-- Header -->
            <TextBlock Text="Hosts File Editor" FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,4"/>

            <!-- Admin warning banner -->
            <Border Background="#FFF3CD" BorderBrush="#FFEEBA" BorderThickness="1"
                    CornerRadius="4" Padding="12,8" Margin="0,0,0,12">
                <TextBlock TextWrapping="Wrap" FontSize="12">
                    <Run FontWeight="SemiBold" Text="Note: "/>
                    <Run Text="Editing the hosts file requires Administrator privileges. The file is located at C:\Windows\System32\drivers\etc\hosts"/>
                </TextBlock>
            </Border>

            <!-- Action toolbar -->
            <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="12" Margin="0,0,0,8">
                <WrapPanel Orientation="Horizontal">
                    <Button Content="Load"   Style="{StaticResource SecondaryActionButtonStyle}"
                            Command="{Binding LoadCommand}"         Margin="0,0,8,0"/>
                    <Button Content="Save"   Style="{StaticResource PrimaryActionButtonStyle}"
                            Command="{Binding SaveCommand}"         Margin="0,0,8,0"/>
                    <Button Content="Restore Backup"   Style="{StaticResource SecondaryActionButtonStyle}"
                            Command="{Binding RestoreBackupCommand}"         Margin="0,0,8,0"/>
                    <Button Content="Toggle Selected" Style="{StaticResource SecondaryActionButtonStyle}"
                            Command="{Binding ToggleEntryCommand}"  Margin="0,0,8,0"/>
                    <Button Content="Add Blocklist Presets" Style="{StaticResource SecondaryActionButtonStyle}"
                            Command="{Binding AddBlocklistCommand}"/>
                </WrapPanel>
            </Border>

            <!-- DataGrid -->
            <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="0" Margin="0,0,0,8">
                <DataGrid ItemsSource="{Binding Entries}"
                          SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          Background="{DynamicResource CardBackgroundBrush}"
                          RowBackground="{DynamicResource CardBackgroundBrush}"
                          AlternatingRowBackground="{DynamicResource PanelBackgroundBrush}"
                          BorderThickness="0"
                          MinHeight="220"
                          MaxHeight="400">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                    <Setter Property="Opacity" Value="0.45"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn    Header="IP Address" Binding="{Binding IpAddress}" Width="140"/>
                        <DataGridTextColumn    Header="Hostname"   Binding="{Binding Hostname}"  Width="200"/>
                        <DataGridTextColumn    Header="Comment"    Binding="{Binding Comment}"   Width="*"/>
                        <DataGridCheckBoxColumn Header="Enabled"   Binding="{Binding IsEnabled}" Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Add new entry form -->
            <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="16" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Add New Entry" FontWeight="SemiBold" FontSize="13"
                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding NewIp, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="6,4" VerticalContentAlignment="Center">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <VisualBrush Stretch="None" AlignmentX="Left">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text=" IP Address" Foreground="Gray"/>
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        <TextBox Grid.Column="2"
                                 Text="{Binding NewHostname, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="6,4" VerticalContentAlignment="Center"/>
                        <TextBox Grid.Column="4"
                                 Text="{Binding NewComment, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="6,4" VerticalContentAlignment="Center"/>
                        <Button  Grid.Column="6"
                                 Content="Add"
                                 Style="{StaticResource PrimaryActionButtonStyle}"
                                 Command="{Binding AddEntryCommand}"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="IP Address" Width="140" FontSize="11"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Width="8"/>
                        <TextBlock Text="Hostname" Width="200" FontSize="11"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Width="8"/>
                        <TextBlock Text="Comment (optional)" FontSize="11"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Delete button row -->
            <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="12" Margin="0,0,0,8">
                <Button Content="Delete Selected" Style="{StaticResource SecondaryActionButtonStyle}"
                        Command="{Binding DeleteEntryCommand}" HorizontalAlignment="Left"/>
            </Border>

            <!-- Status bar -->
            <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="8,6">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
