<UserControl x:Class="WindowsUtilityPack.Tools.SystemUtilities.EnvVarsEditor.EnvVarsEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="4" MaxWidth="1200">

            <Border Style="{StaticResource HeroSurfaceStyle}" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="240"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Environment Variables" Style="{StaticResource PrimaryHeadingTextStyle}" FontSize="24"/>
                        <TextBlock Text="View, filter, edit, and safely manage user and machine environment variables from one responsive workspace."
                                   Style="{StaticResource MetadataTextStyle}"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="1" Style="{StaticResource StatusSurfaceStyle}" Margin="16,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Workflow" Style="{StaticResource PanelHeaderTextStyle}"/>
                            <TextBlock Text="Filter left, inspect and edit right, then save or revert your staged changes."
                                       Style="{StaticResource MetadataTextStyle}"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Style="{StaticResource ElevatedSurfaceStyle}" Margin="0,0,0,12">
                <WrapPanel>
                    <TextBlock Text="Scope" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <ComboBox SelectedValue="{Binding ScopeFilter}" Width="140" Margin="0,0,18,0">
                        <ComboBoxItem Content="All" IsSelected="True"/>
                        <ComboBoxItem Content="User"/>
                        <ComboBoxItem Content="Machine"/>
                    </ComboBox>
                    <TextBlock Text="Search" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Width="260"/>
                    <Button Content="Refresh"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Command="{Binding LoadCommand}"
                            Margin="12,0,0,0"/>
                </WrapPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.8*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource ElevatedSurfaceStyle}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Style="{StaticResource TableHeaderBorderStyle}">
                            <TextBlock Text="Variables" Style="{StaticResource PanelHeaderTextStyle}"/>
                        </Border>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding FilteredEntries}"
                                  SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  MinHeight="420">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Refresh" Command="{Binding LoadCommand}"/>
                                    <MenuItem Header="Copy value" Command="{Binding CopyValueCommand}"/>
                                    <MenuItem Header="New variable" Command="{Binding NewCommand}"/>
                                    <MenuItem Header="Revert editor" Command="{Binding RevertCommand}"/>
                                    <MenuItem Header="Delete selected" Command="{Binding DeleteCommand}"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="180"/>
                                <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Scope" Binding="{Binding Scope}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource ElevatedSurfaceStyle}">
                    <StackPanel>
                        <TextBlock Text="Edit Variable" Style="{StaticResource SectionHeadingTextStyle}" FontSize="18"/>
                        <TextBlock Text="Use the editor to add a new variable or update the currently selected entry."
                                   Style="{StaticResource MetadataTextStyle}"
                                   Margin="0,4,0,14"/>

                        <TextBlock Text="Name" Style="{StaticResource MetadataTextStyle}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14"/>

                        <TextBlock Text="Value" Style="{StaticResource MetadataTextStyle}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding EditValue, UpdateSourceTrigger=PropertyChanged}"
                                 MinHeight="120"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,14"/>

                        <WrapPanel Margin="0,0,0,8">
                            <Button Content="Save" Style="{StaticResource PrimaryActionButtonStyle}" Command="{Binding SaveCommand}" Margin="0,0,8,8"/>
                            <Button Content="New" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding NewCommand}" Margin="0,0,8,8"/>
                            <Button Content="Revert" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding RevertCommand}" Margin="0,0,8,8"/>
                        </WrapPanel>
                        <WrapPanel>
                            <Button Content="Copy Value" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding CopyValueCommand}" Margin="0,0,8,8"/>
                            <Button Content="Delete" Style="{StaticResource DangerActionButtonStyle}" Command="{Binding DeleteCommand}" Margin="0,0,8,8"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource StatusSurfaceStyle}" Margin="0,12,0,0">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="12"/>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
