<UserControl x:Class="WindowsUtilityPack.Tools.SystemUtilities.EnvVarsEditor.EnvVarsEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="8" MaxWidth="1000">

            <!-- Header -->
            <TextBlock Text="Environment Variables" FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,4"/>
            <TextBlock Text="View and edit User and Machine environment variables"
                       FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,16"/>

            <!-- Filter bar -->
            <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="12" Margin="0,0,0,8">
                <WrapPanel Orientation="Horizontal">
                    <TextBlock Text="Scope:" VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <ComboBox SelectedValue="{Binding ScopeFilter}" Width="110" Margin="0,0,16,0">
                        <ComboBoxItem Content="All"     IsSelected="True"/>
                        <ComboBoxItem Content="User"/>
                        <ComboBoxItem Content="Machine"/>
                    </ComboBox>
                    <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Width="240" VerticalContentAlignment="Center"
                             Padding="6,4"/>
                    <Button Content="Refresh" Style="{StaticResource SecondaryActionButtonStyle}"
                            Command="{Binding LoadCommand}" Margin="12,0,0,0"/>
                </WrapPanel>
            </Border>

            <!-- Main split: list + editor -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <!-- Variable list -->
                <Border Grid.Column="0" Style="{StaticResource ToolPanelBorderStyle}" Padding="0">
                    <DataGrid ItemsSource="{Binding FilteredEntries}"
                              SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              Background="{DynamicResource CardBackgroundBrush}"
                              RowBackground="{DynamicResource CardBackgroundBrush}"
                              AlternatingRowBackground="{DynamicResource PanelBackgroundBrush}"
                              BorderThickness="0"
                              MinHeight="300"
                              MaxHeight="480">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name"  Binding="{Binding Name}"  Width="160"/>
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Scope" Binding="{Binding Scope}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Editor panel -->
                <Border Grid.Column="2" Style="{StaticResource ToolPanelBorderStyle}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Edit Variable" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,12"/>

                        <TextBlock Text="Name:" Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontSize="12" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="6,4" Margin="0,0,0,12"/>

                        <TextBlock Text="Value:" Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontSize="12" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding EditValue, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="6,4" MinHeight="80" TextWrapping="Wrap"
                                 AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,16"/>

                        <Button Content="Save" Style="{StaticResource PrimaryActionButtonStyle}"
                                Command="{Binding SaveCommand}" Margin="0,0,0,6"/>
                        <Button Content="New"  Style="{StaticResource SecondaryActionButtonStyle}"
                                Command="{Binding NewCommand}"  Margin="0,0,0,6"/>
                        <Button Content="Revert"  Style="{StaticResource SecondaryActionButtonStyle}"
                                Command="{Binding RevertCommand}"  Margin="0,0,0,6"/>
                        <Button Content="Copy Value" Style="{StaticResource SecondaryActionButtonStyle}"
                                Command="{Binding CopyValueCommand}" Margin="0,0,0,6"/>
                        <Button Content="Delete" Style="{StaticResource SecondaryActionButtonStyle}"
                                Command="{Binding DeleteCommand}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Status bar -->
            <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="8,6" Margin="0,8,0,0">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
