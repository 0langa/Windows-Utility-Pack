<UserControl x:Class="WindowsUtilityPack.Tools.SystemUtilities.EventLogViewer.EventLogViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Event Log Viewer" Style="{StaticResource PrimaryHeadingTextStyle}" Margin="0,0,0,12"/>

        <Border Grid.Row="1" Style="{StaticResource ToolPanelBorderStyle}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ComboBox Grid.Column="0" Margin="0,0,8,0" ItemsSource="{Binding LogNames}" SelectedItem="{Binding SelectedLogName, Mode=TwoWay}"/>
                <TextBox Grid.Column="1" Margin="0,0,8,0" Text="{Binding SourceFilter, UpdateSourceTrigger=PropertyChanged}" ToolTip="Source contains"/>
                <TextBox Grid.Column="2" Margin="0,0,8,0" Text="{Binding LevelFilter, UpdateSourceTrigger=PropertyChanged}" ToolTip="Level contains"/>
                <TextBox Grid.Column="3" Margin="0,0,8,0" Text="{Binding EventIdFilterText, UpdateSourceTrigger=PropertyChanged}" ToolTip="Event ID"/>
                <TextBox Grid.Column="4" Margin="0,0,8,0" Text="{Binding Limit, UpdateSourceTrigger=PropertyChanged}" ToolTip="Result limit"/>
                <Button Grid.Column="5" Margin="0,0,8,0" Content="Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryActionButtonStyle}"/>
                <Button Grid.Column="6" Content="Copy CSV" Command="{Binding CopyCsvCommand}" Style="{StaticResource PrimaryActionButtonStyle}"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource ToolPanelBorderStyle}">
            <ListView ItemsSource="{Binding Entries}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Time (UTC)" Width="190" DisplayMemberBinding="{Binding TimestampUtc}"/>
                        <GridViewColumn Header="Source" Width="180" DisplayMemberBinding="{Binding Source}"/>
                        <GridViewColumn Header="Event ID" Width="90" DisplayMemberBinding="{Binding EventId}"/>
                        <GridViewColumn Header="Level" Width="120" DisplayMemberBinding="{Binding Level}"/>
                        <GridViewColumn Header="Message" Width="690" DisplayMemberBinding="{Binding Message}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <Border Grid.Row="3" Margin="0,12,0,0" Style="{StaticResource StatusSurfaceStyle}">
            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource MetadataTextStyle}"/>
        </Border>
    </Grid>
</UserControl>