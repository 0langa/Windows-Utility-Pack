<UserControl x:Class="WindowsUtilityPack.Tools.SystemUtilities.RegistryEditor.RegistryEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Registry Editor (HKCU\\Software)" Style="{StaticResource PrimaryHeadingTextStyle}" Margin="0,0,0,12"/>

        <Border Grid.Row="1" Style="{StaticResource ToolPanelBorderStyle}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" Margin="0,0,8,0" Text="{Binding KeyPath, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center"/>
                <Button Grid.Column="1" Margin="0,0,8,0" Content="Load" Command="{Binding LoadKeyCommand}" Style="{StaticResource SecondaryActionButtonStyle}"/>
                <Button Grid.Column="2" Margin="0,0,8,0" Content="Backup" Command="{Binding BackupCommand}" Style="{StaticResource SecondaryActionButtonStyle}"/>
                <Button Grid.Column="3" Margin="0,0,8,0" Content="Restore" Command="{Binding RestoreCommand}" Style="{StaticResource SecondaryActionButtonStyle}"/>
                <Button Grid.Column="4" Content="Save Value" Command="{Binding SaveValueCommand}" Style="{StaticResource PrimaryActionButtonStyle}"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource ToolPanelBorderStyle}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListBox Grid.Row="0"
                             Margin="0,0,0,8"
                             ItemsSource="{Binding SubKeys}"
                             SelectedItem="{Binding SelectedSubKey, Mode=TwoWay}"/>
                    <Button Grid.Row="1"
                            Content="Open Subkey"
                            Command="{Binding NavigateSubKeyCommand}"
                            Style="{StaticResource SecondaryActionButtonStyle}"/>
                </Grid>

                <Border Grid.Column="2" Style="{StaticResource ToolPanelBorderStyle}">
                    <DataGrid ItemsSource="{Binding Values}"
                              SelectedItem="{Binding SelectedValue, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="220"/>
                            <DataGridTextColumn Header="Kind" Binding="{Binding Kind}" Width="120"/>
                            <DataGridTextColumn Header="Data" Binding="{Binding DisplayData}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource ToolPanelBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" Margin="0,0,8,0" Text="{Binding EditValueName, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center"/>
                <ComboBox Grid.Column="1" Margin="0,0,8,0" ItemsSource="{Binding SupportedKinds}" SelectedItem="{Binding EditValueKind, Mode=TwoWay}"/>
                <TextBox Grid.Column="2" Margin="0,0,8,0" Text="{Binding EditValueData, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center"/>
                <Button Grid.Column="3" Content="Delete Value" Command="{Binding DeleteValueCommand}" Style="{StaticResource DangerActionButtonStyle}"/>
            </Grid>
        </Border>

        <Border Grid.Row="4" Margin="0,12,0,0" Style="{StaticResource StatusSurfaceStyle}">
            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource MetadataTextStyle}"/>
        </Border>
    </Grid>
</UserControl>