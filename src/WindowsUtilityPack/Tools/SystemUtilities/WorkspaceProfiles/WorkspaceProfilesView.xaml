<UserControl x:Class="WindowsUtilityPack.Tools.SystemUtilities.WorkspaceProfiles.WorkspaceProfilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Workspace Profiles"
                   Style="{StaticResource PrimaryHeadingTextStyle}"
                   Margin="0,0,0,12"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource ToolPanelBorderStyle}">
                <DockPanel>
                    <Button DockPanel.Dock="Top"
                            Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            Margin="0,0,0,8"
                            Style="{StaticResource SecondaryActionButtonStyle}"/>
                    <ListView ItemsSource="{Binding Profiles}"
                              SelectedItem="{Binding SelectedProfile, Mode=TwoWay}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Name" Width="160" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="Startup" Width="140" DisplayMemberBinding="{Binding StartupToolKey}"/>
                                <GridViewColumn Header="Updated" Width="180" DisplayMemberBinding="{Binding UpdatedUtc}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource ToolPanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Profile Details" Style="{StaticResource SectionHeadingTextStyle}" Margin="0,0,0,8"/>

                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Name" VerticalAlignment="Center" Style="{StaticResource MetadataTextStyle}"/>
                        <TextBox Grid.Column="1" Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Description" VerticalAlignment="Center" Style="{StaticResource MetadataTextStyle}"/>
                        <TextBox Grid.Column="1" Text="{Binding ProfileDescription, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <Grid Grid.Row="3" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Startup Tool" VerticalAlignment="Center" Style="{StaticResource MetadataTextStyle}"/>
                        <ComboBox Grid.Column="1"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Key"
                                  SelectedValue="{Binding StartupToolKey, Mode=TwoWay}"
                                  ItemsSource="{Binding AvailableTools}"/>
                    </Grid>

                    <Grid Grid.Row="4" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Pinned Keys" VerticalAlignment="Center" Style="{StaticResource MetadataTextStyle}"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding PinnedToolsCsv, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Comma-separated tool keys (example: storage-master,port-scanner)"/>
                    </Grid>

                    <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="Save"
                                Command="{Binding SaveProfileCommand}"
                                Margin="0,0,8,0"
                                Style="{StaticResource PrimaryActionButtonStyle}"/>
                        <Button Content="Apply"
                                Command="{Binding ApplyProfileCommand}"
                                Margin="0,0,8,0"
                                Style="{StaticResource SecondaryActionButtonStyle}"/>
                        <Button Content="Delete"
                                Command="{Binding DeleteProfileCommand}"
                                Style="{StaticResource DangerActionButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Margin="0,12,0,0" Style="{StaticResource StatusSurfaceStyle}">
            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource MetadataTextStyle}"/>
        </Border>
    </Grid>
</UserControl>