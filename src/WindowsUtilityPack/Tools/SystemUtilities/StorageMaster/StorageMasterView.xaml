<UserControl x:Class="WindowsUtilityPack.Tools.SystemUtilities.StorageMaster.StorageMasterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.4"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="{DynamicResource NavBarBackgroundBrush}"/>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Header toolbar -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,6" Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#x1F4BD;" FontSize="26" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock Text="Storage Master" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="Storage analysis, cleanup &amp; optimization" FontSize="11"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Refresh Drives" Style="{StaticResource SecondaryButton}"
                            Command="{Binding RefreshDrivesCommand}" Margin="0,0,6,0"/>
                    <Button Content="Scan Duplicates" Style="{StaticResource SecondaryButton}"
                            Command="{Binding ScanDuplicatesCommand}" Margin="0,0,6,0"
                            Visibility="{Binding HasScanResult, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <Button Content="Analyse Cleanup" Style="{StaticResource SecondaryButton}"
                            Command="{Binding AnalyseCleanupCommand}" Margin="0,0,6,0"
                            Visibility="{Binding HasScanResult, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <Button Content="Save Snapshot" Style="{StaticResource SecondaryButton}"
                            Command="{Binding SaveSnapshotCommand}"
                            Visibility="{Binding HasScanResult, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </Grid>
        </Border>
        <!-- Elevation banner (shown when NOT elevated) -->
        <Border Grid.Row="1" Margin="0,0,0,6" CornerRadius="6" Padding="12,7"
                Background="#261A00"
                Visibility="{Binding IsElevated, Converter={StaticResource InvertedBoolToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding ElevationStatusText}" Foreground="#FF9800"
                           VerticalAlignment="Center" FontSize="12"/>
                <Button Grid.Column="1" Content="Run as Administrator" Style="{StaticResource SecondaryButton}"
                        Command="{Binding ElevateCommand}" Padding="10,4" FontSize="11"/>
            </Grid>
        </Border>
        <!-- Scan path bar -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Margin="0,0,0,6" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Scan target:" VerticalAlignment="Center" Margin="0,0,10,0"
                           Foreground="{DynamicResource SecondaryTextBrush}" FontSize="13"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding Drives}"
                          SelectedValuePath="RootPath" SelectedValue="{Binding SelectedScanPath}"
                          Margin="0,0,8,0" Padding="8,5" FontSize="13"
                          Background="{DynamicResource CardBackgroundBrush}"
                          Foreground="{DynamicResource PrimaryTextBrush}"
                          BorderBrush="{DynamicResource BorderBrush}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding DriveTypeIcon}" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding DisplayLabel}" Margin="0,0,8,0"/>
                                <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} free / {1}">
                                            <Binding Path="FreeFormatted"/>
                                            <Binding Path="TotalFormatted"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBox Grid.Column="2" Text="{Binding SelectedScanPath, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8,5" Margin="0,0,6,0" FontSize="13"
                         Background="{DynamicResource CardBackgroundBrush}"
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"/>
                <Button Grid.Column="3" Content="Browse..." Style="{StaticResource SecondaryButton}"
                        Command="{Binding BrowseFolderCommand}" Margin="0,0,6,0" Padding="10,5"/>
                <Button Grid.Column="4" Content="Scan" Style="{StaticResource ActionButton}"
                        Command="{Binding ScanCommand}" Padding="18,7" FontWeight="SemiBold"/>
            </Grid>
        </Border>
        <!-- Progress bar (shown during scan) -->
        <Grid Grid.Row="3" Margin="0,0,0,6"
              Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ProgressBar Value="{Binding ScanProgressValue, Mode=OneWay}" Maximum="100" Height="6"
                         Background="{DynamicResource BorderBrush}" Foreground="{DynamicResource AccentBrush}"
                         BorderThickness="0"/>
            <Button Grid.Column="1" Content="Cancel" Style="{StaticResource SecondaryButton}"
                    Command="{Binding CancelScanCommand}" Padding="10,4" Margin="8,0,0,0" FontSize="11"/>
        </Grid>
        <!-- Main content TabControl -->
        <TabControl Grid.Row="4" SelectedIndex="{Binding SelectedTabIndex}"
                    Background="{DynamicResource AppBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <!-- Tab 0: Overview -->
            <TabItem Header="Overview">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8,0,0">
                        <!-- Summary cards row -->
                        <UniformGrid Rows="1" Columns="4" Margin="0,0,0,12">
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="Total Size" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding TotalScanSize}" FontSize="22" FontWeight="Bold"
                                               Foreground="{DynamicResource AccentBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="Files Found" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding TotalFileCount, StringFormat='{}{0:N0}'}" FontSize="22" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="Duplicate Waste" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding TotalDuplicateWastedFormatted}" FontSize="22" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardBorder}">
                                <StackPanel>
                                    <TextBlock Text="Cleanup Savings" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding TotalCleanupSavingsFormatted}" FontSize="22" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                        <!-- Drives + Extension breakdown -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Drives -->
                            <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                                <StackPanel>
                                    <TextBlock Text="Drives" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10"/>
                                    <ItemsControl ItemsSource="{Binding Drives}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,0,0,10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding DriveTypeIcon}" Margin="0,0,6,0" FontSize="14"/>
                                                            <TextBlock Text="{Binding DisplayLabel}" FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                            <TextBlock Text="{Binding MediaTypeDisplay}" FontSize="11" Margin="0,0,6,0"
                                                                       Foreground="{DynamicResource AccentBrush}"/>
                                                            <TextBlock FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}">
                                                                <TextBlock.Text>
                                                                    <MultiBinding StringFormat="{}{0} free / {1}">
                                                                        <Binding Path="FreeFormatted"/>
                                                                        <Binding Path="TotalFormatted"/>
                                                                    </MultiBinding>
                                                                </TextBlock.Text>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Grid>
                                                    <ProgressBar Value="{Binding UsedPercent, Mode=OneWay}" Maximum="100"
                                                                 Height="6" Margin="0,4,0,0"
                                                                 Background="{DynamicResource BorderBrush}"
                                                                 Foreground="{DynamicResource AccentBrush}" BorderThickness="0"/>
                                                    <TextBlock Text="{Binding OptimizationAdvice}" FontSize="10"
                                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                                               Margin="0,3,0,0" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                            <!-- Extension breakdown -->
                            <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                                <StackPanel>
                                    <TextBlock Text="File Type Breakdown" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10"/>
                                    <TextBlock Text="Run a scan to see extension breakdown."
                                               Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"
                                               Visibility="{Binding HasScanResult, Converter={StaticResource InvertedBoolToVisibilityConverter}}"/>
                                    <ItemsControl ItemsSource="{Binding ExtensionSummary}"
                                                  Visibility="{Binding HasScanResult, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,5">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="70"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="60"/>
                                                        <ColumnDefinition Width="50"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Extension}" FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                                    <ProgressBar Grid.Column="1" Value="{Binding Percentage}" Maximum="100"
                                                                 Height="10" Margin="4,0" VerticalAlignment="Center"
                                                                 Background="{DynamicResource BorderBrush}"
                                                                 Foreground="{DynamicResource AccentBrush}" BorderThickness="0"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding TotalSize}" FontSize="11"
                                                               Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding PercentFormatted}" FontSize="11"
                                                               Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"
                                                               HorizontalAlignment="Right"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <!-- Tab 1: Storage Tree -->
            <TabItem Header="Storage Tree">
                <Grid>
                    <TextBlock Text="Scan a folder or drive to see the storage tree."
                               Foreground="{DynamicResource SecondaryTextBrush}" FontSize="14"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding HasScanResult, Converter={StaticResource InvertedBoolToVisibilityConverter}}"/>
                    <TreeView ItemsSource="{Binding TreeRoots}"
                              Background="{DynamicResource AppBackgroundBrush}"
                              BorderThickness="0"
                              Visibility="{Binding HasScanResult, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TreeView.Resources>
                            <HierarchicalDataTemplate DataType="{x:Type storageMaster:StorageTreeNodeViewModel}"
                                                      ItemsSource="{Binding Children}"
                                                      xmlns:storageMaster="clr-namespace:WindowsUtilityPack.Tools.SystemUtilities.StorageMaster">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding DisplayText}"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               FontSize="13" Margin="0,2"/>
                                    <ProgressBar Grid.Column="1" Value="{Binding PercentOfParent}"
                                                 Maximum="100" Height="8" VerticalAlignment="Center" Margin="4,0,0,0"
                                                 Background="{DynamicResource BorderBrush}"
                                                 Foreground="{DynamicResource AccentBrush}" BorderThickness="0"/>
                                </Grid>
                            </HierarchicalDataTemplate>
                        </TreeView.Resources>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </Grid>
            </TabItem>
            <!-- Tab 2: Files -->
            <TabItem Header="Files">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- Filter bar -->
                    <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,6" Padding="10,8">
                        <WrapPanel>
                            <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,6,0"
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Width="180" Padding="6,4" Margin="0,0,12,0"
                                     Background="{DynamicResource CardBackgroundBrush}"
                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}"/>
                            <TextBlock Text="Ext:" VerticalAlignment="Center" Margin="0,0,6,0"
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBox Text="{Binding ExtensionFilter, UpdateSourceTrigger=PropertyChanged}"
                                     Width="70" Padding="6,4" Margin="0,0,12,0"
                                     Background="{DynamicResource CardBackgroundBrush}"
                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     ToolTip="e.g. .mp4 or mp4"/>
                            <TextBlock Text="Min MB:" VerticalAlignment="Center" Margin="0,0,6,0"
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBox Width="60" Padding="6,4" Margin="0,0,12,0"
                                     Background="{DynamicResource CardBackgroundBrush}"
                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}">
                                <TextBox.Text>
                                    <Binding Path="MinSizeFilterMb" UpdateSourceTrigger="PropertyChanged" ValidatesOnExceptions="True"/>
                                </TextBox.Text>
                            </TextBox>
                            <CheckBox Content="Hidden" IsChecked="{Binding ShowHiddenFiles}"
                                      Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <CheckBox Content="System" IsChecked="{Binding ShowSystemFiles}"
                                      Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"
                                       VerticalAlignment="Center" Margin="8,0,0,0">
                                <TextBlock.Text>
                                    <Binding Path="FilteredFiles.Count" StringFormat="{}{0} files"/>
                                </TextBlock.Text>
                            </TextBlock>
                        </WrapPanel>
                    </Border>
                    <!-- File list -->
                    <ListView Grid.Row="1" ItemsSource="{Binding FilteredFiles}"
                              Background="{DynamicResource AppBackgroundBrush}"
                              Foreground="{DynamicResource PrimaryTextBrush}"
                              BorderThickness="0"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Name" Width="250" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="Size" Width="90" DisplayMemberBinding="{Binding DisplaySize}"/>
                                <GridViewColumn Header="Ext" Width="70" DisplayMemberBinding="{Binding Extension}"/>
                                <GridViewColumn Header="Modified" Width="140" DisplayMemberBinding="{Binding LastModified, StringFormat=yyyy-MM-dd HH:mm}"/>
                                <GridViewColumn Header="Path" Width="400" DisplayMemberBinding="{Binding FullPath}"/>
                            </GridView>
                        </ListView.View>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Copy Path"
                                          Command="{Binding DataContext.CopyPathCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding}"/>
                                <MenuItem Header="Open Containing Folder"
                                          Command="{Binding DataContext.OpenInExplorerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding}"/>
                            </ContextMenu>
                        </ListView.ContextMenu>
                    </ListView>
                </Grid>
            </TabItem>
            <!-- Tab 3: Duplicates -->
            <TabItem Header="Duplicates">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,6" Padding="10,8">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Scan for Duplicates" Style="{StaticResource ActionButton}"
                                    Command="{Binding ScanDuplicatesCommand}" Margin="0,0,8,0"/>
                            <Button Content="Export CSV" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding ExportDuplicateCsvCommand}" Margin="0,0,8,0"/>
                            <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="8,0,0,0">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} groups  |  {1} wasted">
                                        <Binding Path="DuplicateGroups.Count"/>
                                        <Binding Path="TotalDuplicateWastedFormatted"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding DuplicateGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,8">
                                        <Expander Header="{Binding Header}" IsExpanded="False"
                                                  Foreground="{DynamicResource PrimaryTextBrush}">
                                            <ItemsControl ItemsSource="{Binding Files}" Margin="0,8,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,3">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="90"/>
                                                                <ColumnDefinition Width="80"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <CheckBox IsChecked="{Binding IsMarkedForDeletion}"
                                                                      Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding Badge}" FontSize="11"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding Size}" FontSize="12"
                                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                                       VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="3" Text="{Binding Path}" FontSize="11"
                                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                                                       ToolTip="{Binding Path}"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Expander>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>
            <!-- Tab 4: Cleanup Center -->
            <TabItem Header="Cleanup">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,6" Padding="10,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Analyse" Style="{StaticResource ActionButton}"
                                        Command="{Binding AnalyseCleanupCommand}" Margin="0,0,8,0"/>
                                <Button Content="Select All" Style="{StaticResource SecondaryButton}"
                                        Command="{Binding SelectAllCleanupCommand}" Margin="0,0,4,0"/>
                                <Button Content="Select None" Style="{StaticResource SecondaryButton}"
                                        Command="{Binding DeselectAllCleanupCommand}" Margin="0,0,12,0"/>
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} items  |  up to {1} recoverable">
                                            <Binding Path="CleanupItems.Count"/>
                                            <Binding Path="TotalCleanupSavingsFormatted"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="Send to Recycle Bin" Style="{StaticResource SecondaryButton}"
                                        Command="{Binding RecycleSelectedCleanupCommand}" Margin="0,0,6,0"/>
                                <Button Content="Delete Permanently" Style="{StaticResource ActionButton}"
                                        Command="{Binding DeleteSelectedCleanupCommand}"
                                        ToolTip="WARNING: Permanently deletes selected items"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ListView Grid.Row="1" ItemsSource="{Binding CleanupItems}"
                              Background="{DynamicResource AppBackgroundBrush}"
                              Foreground="{DynamicResource PrimaryTextBrush}"
                              BorderThickness="0"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="" Width="30">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Cat" Width="60" DisplayMemberBinding="{Binding CategoryIcon}"/>
                                <GridViewColumn Header="Name" Width="200" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="Savings" Width="90" DisplayMemberBinding="{Binding Size}"/>
                                <GridViewColumn Header="Reason" Width="280" DisplayMemberBinding="{Binding Rationale}"/>
                                <GridViewColumn Header="Path" Width="300" DisplayMemberBinding="{Binding ItemPath}"/>
                            </GridView>
                        </ListView.View>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </Grid>
            </TabItem>
            <!-- Tab 5: Reports -->
            <TabItem Header="Reports">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,6" Padding="10,8">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Export Files CSV" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding ExportFileCsvCommand}" Margin="0,0,8,0"/>
                            <Button Content="Export Duplicates CSV" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding ExportDuplicateCsvCommand}" Margin="0,0,8,0"/>
                            <Button Content="Save Summary Report" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding ExportSummaryCommand}"/>
                        </StackPanel>
                    </Border>
                    <TextBox Grid.Row="1" Text="{Binding ScanSummary, Mode=OneWay}"
                             IsReadOnly="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Background="{DynamicResource CardBackgroundBrush}"
                             Foreground="{DynamicResource PrimaryTextBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             FontFamily="Consolas" FontSize="12" Padding="12"/>
                </Grid>
            </TabItem>
            <!-- Tab 6: Snapshots -->
            <TabItem Header="Snapshots">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- Snapshot list -->
                    <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Saved Snapshots" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10"/>
                            <Grid Grid.Row="1" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding SnapshotLabel, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="6,4"
                                         Background="{DynamicResource AppBackgroundBrush}"
                                         Foreground="{DynamicResource PrimaryTextBrush}"
                                         BorderBrush="{DynamicResource BorderBrush}"
                                         ToolTip="Optional snapshot label"/>
                                <Button Grid.Column="1" Content="Save" Style="{StaticResource ActionButton}"
                                        Command="{Binding SaveSnapshotCommand}" Padding="10,4" Margin="6,0,0,0"/>
                            </Grid>
                            <ListBox Grid.Row="2" ItemsSource="{Binding Snapshots}"
                                     SelectedItem="{Binding SelectedSnapshot}"
                                     Background="{DynamicResource AppBackgroundBrush}"
                                     Foreground="{DynamicResource PrimaryTextBrush}" BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,4">
                                            <TextBlock Text="{Binding DisplayLabel}" FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                            <TextBlock FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0} files  |  {1}">
                                                        <Binding Path="FileCount" StringFormat='{}{0:N0}'/>
                                                        <Binding Path="RootPath"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Button Grid.Row="3" Content="Delete Selected" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding DeleteSnapshotCommand}" Margin="0,8,0,0"
                                    HorizontalAlignment="Stretch"/>
                        </Grid>
                    </Border>
                    <!-- Comparison panel -->
                    <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Compare Snapshots" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10"/>
                            <Grid Grid.Row="1" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0" ItemsSource="{Binding Snapshots}"
                                          SelectedItem="{Binding ComparisonBaseline}"
                                          DisplayMemberPath="DisplayLabel" Padding="6,4"
                                          Background="{DynamicResource CardBackgroundBrush}"
                                          Foreground="{DynamicResource PrimaryTextBrush}"
                                          BorderBrush="{DynamicResource BorderBrush}"
                                          ToolTip="Baseline snapshot"/>
                                <TextBlock Grid.Column="1" Text="vs" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <ComboBox Grid.Column="2" ItemsSource="{Binding Snapshots}"
                                          SelectedItem="{Binding SelectedSnapshot}"
                                          DisplayMemberPath="DisplayLabel" Padding="6,4"
                                          Background="{DynamicResource CardBackgroundBrush}"
                                          Foreground="{DynamicResource PrimaryTextBrush}"
                                          BorderBrush="{DynamicResource BorderBrush}"
                                          ToolTip="Current/comparison snapshot"/>
                                <Button Grid.Column="3" Content="Compare" Style="{StaticResource ActionButton}"
                                        Command="{Binding CompareSnapshotsCommand}" Padding="12,5" Margin="8,0,0,0"/>
                            </Grid>
                            <TextBox Grid.Row="2" Text="{Binding ScanSummary, Mode=OneWay}"
                                     IsReadOnly="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Background="{DynamicResource AppBackgroundBrush}"
                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     FontFamily="Consolas" FontSize="12" Padding="8"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
        <!-- Status bar -->
        <Border Grid.Row="5" Padding="12,5"
                Background="{DynamicResource HeaderBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding ScanStatusText}"
                           Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="1" Text="{Binding ElevationStatusText}"
                           FontSize="11" VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
