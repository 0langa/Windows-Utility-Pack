<UserControl x:Class="WindowsUtilityPack.Tools.SystemUtilities.ProcessExplorer.ProcessExplorerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Process Explorer" Style="{StaticResource PrimaryHeadingTextStyle}" Margin="0,0,0,12"/>

        <Border Grid.Row="1" Style="{StaticResource ToolPanelBorderStyle}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Margin="0,0,8,0"
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center"
                         ToolTip="Filter by process name, path, or PID"/>
                <Button Grid.Column="1" Content="Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryActionButtonStyle}" Margin="0,0,8,0"/>
                <Button Grid.Column="2" Content="Copy Details" Command="{Binding CopyDetailsCommand}" Style="{StaticResource SecondaryActionButtonStyle}" Margin="0,0,8,0"/>
                <Button Grid.Column="3" Content="Terminate" Command="{Binding TerminateCommand}" Style="{StaticResource DangerActionButtonStyle}"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource ToolPanelBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <DataGrid ItemsSource="{Binding Processes}"
                          SelectedItem="{Binding SelectedProcess, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          RowHeaderWidth="0"
                          CanUserSortColumns="True"
                          Margin="0,0,0,8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="220" SortMemberPath="Name"/>
                        <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="90" SortMemberPath="ProcessId"/>
                        <DataGridTextColumn Header="Memory (MB)" Binding="{Binding WorkingSetMb, StringFormat=F1}" Width="120" SortMemberPath="WorkingSetMb"/>
                        <DataGridTextColumn Header="CPU (%)" Binding="{Binding CpuPercent, StringFormat=F1}" Width="110" SortMemberPath="CpuPercent"/>
                        <DataGridTextColumn Header="CPU (s)" Binding="{Binding CpuTimeSeconds, StringFormat=F1}" Width="110" SortMemberPath="CpuTimeSeconds"/>
                        <DataGridCheckBoxColumn Header="Responding" Binding="{Binding IsResponding}" Width="95"/>
                        <DataGridTextColumn Header="Started" Binding="{Binding StartTimeLocal, StringFormat=G}" Width="150"/>
                        <DataGridTextColumn Header="Path" Binding="{Binding ExecutablePath}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
                <!-- Process detail panel -->
                <Border Grid.Row="1" Margin="0,4,0,0" Padding="8" Background="{DynamicResource PanelBackgroundBrush}" CornerRadius="4" Visibility="{Binding SelectedProcess, Converter={StaticResource NullToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Details" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SelectedProcess.Name}"/>
                        <TextBlock Text="PID: {Binding SelectedProcess.ProcessId}"/>
                        <TextBlock Text="Path: {Binding SelectedProcess.ExecutablePath}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="Memory: {Binding SelectedProcess.WorkingSetMb, StringFormat=F1} MB"/>
                        <TextBlock Text="CPU: {Binding SelectedProcess.CpuPercent, StringFormat=F1} % ({Binding SelectedProcess.CpuTimeSeconds, StringFormat=F1} s)"/>
                        <TextBlock Text="Responding: {Binding SelectedProcess.IsResponding}"/>
                        <TextBlock Text="Started: {Binding SelectedProcess.StartTimeLocal, StringFormat=G}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="3" Margin="0,12,0,0" Style="{StaticResource StatusSurfaceStyle}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource MetadataTextStyle}"/>
                <TextBlock Text="  |  Auto-refresh: " Style="{StaticResource MetadataTextStyle}" Margin="12,0,0,0"/>
                <CheckBox IsChecked="{Binding AutoRefreshEnabled, Mode=TwoWay}" VerticalAlignment="Center"/>
                <TextBlock Text="  Interval (s): " Style="{StaticResource MetadataTextStyle}" Margin="8,0,0,0"/>
                <TextBox Text="{Binding RefreshIntervalSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="32" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>