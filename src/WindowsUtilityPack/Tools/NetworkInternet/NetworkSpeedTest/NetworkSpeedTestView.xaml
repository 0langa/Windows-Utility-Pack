<UserControl x:Class="WindowsUtilityPack.Tools.NetworkInternet.NetworkSpeedTest.NetworkSpeedTestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="8" MaxWidth="800">

            <TextBlock Text="Network Speed Test" FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,16"/>

            <!-- Speed display -->
            <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="24" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- Download -->
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Download" Foreground="{DynamicResource SecondaryTextBrush}"
                                   HorizontalAlignment="Center" FontSize="13" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding DownloadSpeed}" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"/>
                        <ProgressBar Value="{Binding DownloadProgress}" Minimum="0" Maximum="100"
                                     Height="6" MinWidth="120" Margin="0,8,0,0" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                    <!-- Latency -->
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="Latency" Foreground="{DynamicResource SecondaryTextBrush}"
                                   HorizontalAlignment="Center" FontSize="13" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding Latency}" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <!-- Upload -->
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <TextBlock Text="Upload" Foreground="{DynamicResource SecondaryTextBrush}"
                                   HorizontalAlignment="Center" FontSize="13" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding UploadSpeed}" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"/>
                        <ProgressBar Value="{Binding UploadProgress}" Minimum="0" Maximum="100"
                                     Height="6" MinWidth="120" Margin="0,8,0,0" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Server URL + Controls -->
            <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Test Server URL" Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="12" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding ServerUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontFamily="Consolas" FontSize="12"
                                 IsEnabled="{Binding IsTesting, Converter={StaticResource BoolNegationConverter}}"
                                 AutomationProperties.Name="Speed test server URL"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Run Test"
                                Command="{Binding RunTestCommand}"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Margin="0,0,8,0"/>
                        <Button Content="Stop"
                                Command="{Binding StopCommand}"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Margin="0,0,8,0"/>
                        <Button Content="Copy Results"
                                Command="{Binding CopyResultsCommand}"
                                Style="{StaticResource SecondaryActionButtonStyle}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="12" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- History -->
            <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="History (last 10)" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8"/>
                    <DataGrid ItemsSource="{Binding History}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              MinHeight="60" MaxHeight="240"
                              Background="{DynamicResource CardBackgroundBrush}"
                              Foreground="{DynamicResource PrimaryTextBrush}"
                              BorderThickness="0"
                              CanUserResizeRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time"     Binding="{Binding Timestamp}" MinWidth="80" Width="Auto"/>
                            <DataGridTextColumn Header="Download" Binding="{Binding Download}"  Width="*"/>
                            <DataGridTextColumn Header="Upload"   Binding="{Binding Upload}"    Width="*"/>
                            <DataGridTextColumn Header="Latency"  Binding="{Binding Latency}"   MinWidth="80" Width="Auto"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
