<UserControl x:Class="WindowsUtilityPack.Tools.NetworkInternet.PingTool.PingToolView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8" MaxWidth="700" HorizontalAlignment="Left">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="🌐 Ping Tool" FontSize="20" FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,16"/>

        <!-- Input -->
        <Border Grid.Row="1" Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="8" Padding="16" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Host:" Foreground="{DynamicResource SecondaryTextBrush}"
                           VerticalAlignment="Center" Width="50"/>
                <TextBox Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" Width="250"
                         Background="{DynamicResource CardBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}"
                         BorderBrush="{DynamicResource BorderBrush}" Padding="8,6" Margin="0,0,16,0"/>
                <TextBlock Text="Count:" Foreground="{DynamicResource SecondaryTextBrush}"
                           VerticalAlignment="Center" Width="50"/>
                <TextBox Text="{Binding PingCount, UpdateSourceTrigger=PropertyChanged}" Width="50"
                         Background="{DynamicResource CardBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}"
                         BorderBrush="{DynamicResource BorderBrush}" Padding="8,6" Margin="0,0,16,0"/>
                <Button Content="▶ Ping" Command="{Binding PingCommand}"
                        Padding="16,6" Background="{DynamicResource AccentBrush}"
                        Foreground="White" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <TextBlock Text="Pinging…" Foreground="{DynamicResource SecondaryTextBrush}"
                           VerticalAlignment="Center" Margin="12,0,0,0"
                           Visibility="{Binding IsPinging, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>
        </Border>

        <!-- Results -->
        <Border Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Background="{DynamicResource NavBarBackgroundBrush}" CornerRadius="8,8,0,0" Padding="12,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="#" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Grid.Column="1" Text="Address" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Grid.Column="2" Text="Latency (ms)" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Grid.Column="3" Text="Status" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </Grid>
                </Border>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Results}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="12,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Attempt}" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Address}" Foreground="{DynamicResource PrimaryTextBrush}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2" Text="{Binding RoundtripMs}" FontFamily="Consolas">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                                        <Setter Property="Foreground" Value="#E94560"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Grid.Column="3" Text="{Binding Status}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                                        <Setter Property="Foreground" Value="#E94560"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <TextBlock Grid.Row="3" Text="{Binding Summary}" Foreground="{DynamicResource SecondaryTextBrush}"
                   FontSize="13" Margin="0,8,0,0"/>
    </Grid>
</UserControl>
