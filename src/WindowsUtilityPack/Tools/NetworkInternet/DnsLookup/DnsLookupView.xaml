<UserControl x:Class="WindowsUtilityPack.Tools.NetworkInternet.DnsLookup.DnsLookupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="4" MaxWidth="800">

            <TextBlock Text="DNS Lookup" Style="{StaticResource ToolTitleTextStyle}" Margin="0,0,0,16"/>

            <!-- Input -->
            <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Hostname or IP" Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="12" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding IsLooking, Converter={StaticResource BoolNegationConverter}}"
                                 FontSize="14" Padding="8,6" Margin="0,0,8,0"
                                 AutomationProperties.Name="Hostname to look up"/>
                        <Button Grid.Column="1" Content="Lookup"
                                Command="{Binding LookupCommand}"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                AutomationProperties.Name="Run DNS lookup"/>
                    </Grid>
                    <TextBlock Text="Looking up…"
                               Visibility="{Binding IsLooking, Converter={StaticResource BoolToVisibilityConverter}}"
                               Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Results -->
            <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Results" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8"/>
                    <DataGrid ItemsSource="{Binding Results}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              MinHeight="120" MaxHeight="320"
                              Background="{DynamicResource CardBackgroundBrush}"
                              Foreground="{DynamicResource PrimaryTextBrush}"
                              BorderThickness="0"
                              CanUserResizeRows="False"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Type"  Binding="{Binding Type}"  Width="120"/>
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*"/>
                            <DataGridTextColumn Header="TTL"   Binding="{Binding Ttl}"   Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- Actions + Status -->
            <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="16" Margin="0,0,0,12">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Copy Results"
                                Command="{Binding CopyResultsCommand}"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Margin="0,0,8,0"/>
                        <Button Content="Clear"
                                Command="{Binding ClearCommand}"
                                Style="{StaticResource SecondaryActionButtonStyle}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                </DockPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
