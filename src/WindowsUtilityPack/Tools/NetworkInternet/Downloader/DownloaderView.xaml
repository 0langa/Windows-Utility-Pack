<UserControl x:Class="WindowsUtilityPack.Tools.NetworkInternet.Downloader.DownloaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:WindowsUtilityPack.Tools.NetworkInternet.Downloader.Models"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1300">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="180"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource ToolPanelBorderStyle}" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Downloader Studio" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock Margin="0,4,0,0" Text="Premium queue manager, media acquisition, and asset extraction workspace" Foreground="{DynamicResource SecondaryTextBrush}"/>
                </StackPanel>
                <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="8,6" Margin="0,0,6,0"><TextBlock Text="{Binding QueuedCount, StringFormat=Queued: {0}}"/></Border>
                    <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="8,6" Margin="0,0,6,0"><TextBlock Text="{Binding ActiveCount, StringFormat=Active: {0}}"/></Border>
                    <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="8,6" Margin="0,0,6,0"><TextBlock Text="{Binding CompletedCount, StringFormat=Completed: {0}}"/></Border>
                    <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="8,6"><TextBlock Text="{Binding FailedCount, StringFormat=Failed: {0}}"/></Border>
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource ToolPanelBorderStyle}" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Mode" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <ComboBox Grid.Column="0" Margin="48,0,8,0" ItemsSource="{Binding Modes}" SelectedItem="{Binding SelectedMode}" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Margin="0,0,8,0" Padding="8,6" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="56" VerticalScrollBarVisibility="Auto" Text="{Binding QuickInput, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Grid.Column="2" Content="Add to Queue" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding AddToQueueCommand}" Margin="0,0,8,0"/>
                    <Button Grid.Column="3" Content="Download Now" Style="{StaticResource PrimaryActionButtonStyle}" Command="{Binding DownloadNowCommand}" Margin="0,0,8,0"/>
                    <Button Grid.Column="4" Content="Paste" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding PasteClipboardCommand}" Margin="0,0,8,0"/>
                    <Button Grid.Column="5" Content="Import" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding ImportLinksCommand}"/>
                </Grid>
                <WrapPanel Grid.Row="1" Margin="0,8,0,0" VerticalAlignment="Center">
                    <Button Content="Install Tools" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding InstallToolsCommand}" Margin="0,0,8,0"/>
                    <Button Content="Update yt-dlp" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding UpdateToolsCommand}" Margin="0,0,8,0"/>
                    <TextBlock Text="Dependencies:" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding DependenciesReady}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </WrapPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="2">
            <TabItem Header="Queue Manager">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <WrapPanel Margin="0,0,0,8">
                        <Button Content="Start" Style="{StaticResource PrimaryActionButtonStyle}" Command="{Binding StartQueueCommand}" Margin="0,0,6,0"/>
                        <Button Content="Pause" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding PauseQueueCommand}" Margin="0,0,6,0"/>
                        <Button Content="Stop" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding StopQueueCommand}" Margin="0,0,16,0"/>
                        <Button Content="Retry Failed" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding RetryFailedCommand}" Margin="0,0,6,0"/>
                        <Button Content="Clear Completed" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding ClearCompletedCommand}" Margin="0,0,6,0"/>
                        <Button Content="Clear Failed" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding ClearFailedCommand}" Margin="0,0,16,0"/>
                        <Button Content="Pause Selected" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding PauseSelectedCommand}" Margin="0,0,6,0"/>
                        <Button Content="Resume Selected" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding ResumeSelectedCommand}" Margin="0,0,6,0"/>
                        <Button Content="Cancel Selected" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding CancelSelectedCommand}" Margin="0,0,6,0"/>
                        <Button Content="Retry Selected" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding RetrySelectedCommand}" Margin="0,0,6,0"/>
                        <Button Content="Remove Selected" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding RemoveSelectedCommand}"/>
                    </WrapPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.6*"/>
                            <ColumnDefinition Width="1.2*"/>
                        </Grid.ColumnDefinitions>

                        <DataGrid x:Name="QueueGrid"
                                  Grid.Column="0"
                                  ItemsSource="{Binding Jobs}"
                                  SelectedItem="{Binding SelectedJob, Mode=TwoWay}"
                                  SelectionMode="Extended"
                                  SelectionUnit="FullRow"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionChanged="QueueGrid_OnSelectionChanged"
                                  HeadersVisibility="Column"
                                  CanUserSortColumns="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Title" Binding="{Binding DisplayTitle}" Width="2*"/>
                                <DataGridTextColumn Header="Engine" Binding="{Binding EngineType}" Width="90"/>
                                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="100"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                                <DataGridTemplateColumn Header="Progress" Width="180">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <ProgressBar Minimum="0" Maximum="100" Value="{Binding ProgressPercent}" Height="14"/>
                                                <TextBlock Text="{Binding ProgressPercent, StringFormat={}{0:F0}%}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10"/>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Speed" Binding="{Binding SpeedLabel}" Width="90"/>
                                <DataGridTextColumn Header="ETA" Binding="{Binding EtaLabel}" Width="80"/>
                                <DataGridTextColumn Header="Bytes" Binding="{Binding ProgressLabel}" Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Column="1" Style="{StaticResource ToolPanelBorderStyle}" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Inspector" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBlock Text="Source URL" Style="{StaticResource MetadataTextStyle}"/>
                                <TextBox Text="{Binding SelectedJob.SourceUrl}" IsReadOnly="True" TextWrapping="Wrap" MinHeight="48" Margin="0,2,0,8"/>
                                <TextBlock Text="Output" Style="{StaticResource MetadataTextStyle}"/>
                                <TextBox Text="{Binding SelectedJob.OutputFilePath}" IsReadOnly="True" TextWrapping="Wrap" MinHeight="48" Margin="0,2,0,8"/>
                                <TextBlock Text="Status Message" Style="{StaticResource MetadataTextStyle}"/>
                                <TextBox Text="{Binding SelectedJob.StatusMessage}" IsReadOnly="True" TextWrapping="Wrap" MinHeight="48" Margin="0,2,0,8"/>
                                <TextBlock Text="Error" Style="{StaticResource MetadataTextStyle}"/>
                                <TextBox Text="{Binding SelectedJob.ErrorSummary}" IsReadOnly="True" TextWrapping="Wrap" MinHeight="48" Margin="0,2,0,8"/>
                                <WrapPanel>
                                    <Button Content="Open Source" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding OpenSourceCommand}" Margin="0,0,6,6"/>
                                    <Button Content="Open Folder" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding OpenContainingFolderCommand}" Margin="0,0,6,6"/>
                                    <Button Content="Copy URL" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding CopySourceUrlCommand}" Margin="0,0,6,6"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Asset Grabber &amp; Crawl">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding ScanUrl, UpdateSourceTrigger=PropertyChanged}" Padding="8,6"/>
                        <Button Grid.Column="1" Content="Scan Page" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding ScanPageCommand}" Margin="8,0,0,0"/>
                        <Button Grid.Column="2" Content="Crawl Site" Style="{StaticResource PrimaryActionButtonStyle}" Command="{Binding CrawlSiteCommand}" Margin="8,0,0,0"/>
                        <Button Grid.Column="3" Content="Add Selected" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding AddSelectedAssetsCommand}" Margin="8,0,0,0"/>
                    </Grid>

                    <WrapPanel Grid.Row="1" Margin="0,8,0,8">
                        <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox Width="150" ItemsSource="{Binding AssetFilters}" SelectedItem="{Binding SelectedAssetFilter}" Margin="0,0,8,0"/>
                        <TextBox Width="220" Text="{Binding AssetSearchText, UpdateSourceTrigger=PropertyChanged}" Padding="6,4" Margin="0,0,8,0"/>
                        <Button Content="Select All" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding SelectAllAssetsCommand}" Margin="0,0,6,0"/>
                        <Button Content="Select Visible" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding SelectVisibleAssetsCommand}" Margin="0,0,6,0"/>
                        <Button Content="None" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding DeselectAllAssetsCommand}" Margin="0,0,6,0"/>
                        <Button Content="Invert" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding InvertAssetSelectionCommand}" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding ScanStatus}" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Margin="8,0,0,0"/>
                    </WrapPanel>

                    <DataGrid Grid.Row="2" ItemsSource="{Binding DiscoveredAssetsView}" AutoGenerateColumns="False" SelectionMode="Extended">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="Get" Binding="{Binding IsSelected, Mode=TwoWay}" Width="55"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding TypeLabel}" Width="90"/>
                            <DataGridTextColumn Header="Ext" Binding="{Binding Extension}" Width="70"/>
                            <DataGridTextColumn Header="Size" Binding="{Binding SizeLabel}" Width="90"/>
                            <DataGridTextColumn Header="Reachable" Binding="{Binding IsReachable}" Width="80"/>
                            <DataGridTextColumn Header="Warning" Binding="{Binding Warning}" Width="130"/>
                            <DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="History">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <WrapPanel Margin="0,0,0,8">
                        <Button Content="Clear History" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding ClearHistoryCommand}" Margin="0,0,8,0"/>
                    </WrapPanel>
                    <DataGrid x:Name="HistoryGrid" Grid.Row="1" ItemsSource="{Binding History}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="When" Binding="{Binding CompletedAt}" Width="140"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding FinalStatus}" Width="90"/>
                            <DataGridTextColumn Header="Engine" Binding="{Binding EngineType}" Width="80"/>
                            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="2*"/>
                            <DataGridTextColumn Header="URL" Binding="{Binding SourceUrl}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Button Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,8"
                            Content="Redownload Selected" Style="{StaticResource SecondaryActionButtonStyle}"
                            Command="{Binding RedownloadHistoryItemCommand}" CommandParameter="{Binding SelectedItem, ElementName=HistoryGrid}"/>
                </Grid>
            </TabItem>

            <TabItem Header="Settings &amp; Scheduler">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="8">
                    <StackPanel>
                        <TextBlock Text="General" Style="{StaticResource PanelHeaderTextStyle}"/>
                        <WrapPanel Margin="0,6,0,0">
                            <CheckBox Content="Auto start on add" IsChecked="{Binding Settings.General.AutoStartOnAdd}" Margin="0,0,16,8"/>
                            <CheckBox Content="Clipboard monitoring" IsChecked="{Binding Settings.General.ClipboardMonitoring}" Margin="0,0,16,8"/>
                            <CheckBox Content="Stage before start" IsChecked="{Binding Settings.General.StageLinksBeforeDownload}" Margin="0,0,16,8"/>
                        </WrapPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding Settings.General.DefaultDownloadFolder}" Padding="6,4"/>
                            <Button Grid.Column="1" Content="Save Settings" Style="{StaticResource SecondaryActionButtonStyle}" Margin="8,0,0,0" Command="{Binding SaveSettingsCommand}"/>
                            <Button Grid.Column="2" Content="Cookie File" Style="{StaticResource SecondaryActionButtonStyle}" Margin="8,0,0,0" Command="{Binding PickCookieFileCommand}"/>
                        </Grid>

                        <TextBlock Text="Queue" Style="{StaticResource PanelHeaderTextStyle}" Margin="0,10,0,0"/>
                        <WrapPanel Margin="0,6,0,0">
                            <StackPanel Margin="0,0,12,8"><TextBlock Text="Max concurrent" Style="{StaticResource MetadataTextStyle}"/><TextBox Width="90" Text="{Binding Settings.Queue.MaxConcurrentDownloads}"/></StackPanel>
                            <StackPanel Margin="0,0,12,8"><TextBlock Text="Max retries" Style="{StaticResource MetadataTextStyle}"/><TextBox Width="90" Text="{Binding Settings.Queue.MaxRetries}"/></StackPanel>
                            <StackPanel Margin="0,0,12,8"><TextBlock Text="Retry delay (s)" Style="{StaticResource MetadataTextStyle}"/><TextBox Width="90" Text="{Binding Settings.Queue.RetryDelaySeconds}"/></StackPanel>
                            <StackPanel Margin="0,0,12,8"><TextBlock Text="Default priority" Style="{StaticResource MetadataTextStyle}"/><TextBox Width="120" Text="{Binding Settings.Queue.DefaultPriority}"/></StackPanel>
                        </WrapPanel>

                        <TextBlock Text="Connections" Style="{StaticResource PanelHeaderTextStyle}" Margin="0,10,0,0"/>
                        <WrapPanel Margin="0,6,0,0">
                            <StackPanel Margin="0,0,12,8"><TextBlock Text="Segments" Style="{StaticResource MetadataTextStyle}"/><TextBox Width="90" Text="{Binding Settings.Connections.SegmentsPerDownload}"/></StackPanel>
                            <StackPanel Margin="0,0,12,8"><TextBlock Text="Segment threshold MB" Style="{StaticResource MetadataTextStyle}"/><TextBox Width="120" Text="{Binding Settings.Connections.SegmentThresholdMb}"/></StackPanel>
                            <StackPanel Margin="0,0,12,8"><TextBlock Text="Timeout (s)" Style="{StaticResource MetadataTextStyle}"/><TextBox Width="90" Text="{Binding Settings.Connections.TimeoutSeconds}"/></StackPanel>
                            <StackPanel Margin="0,0,12,8"><TextBlock Text="Bandwidth KBPS (0=unlimited)" Style="{StaticResource MetadataTextStyle}"/><TextBox Width="170" Text="{Binding Settings.Connections.BandwidthLimitKbps}"/></StackPanel>
                        </WrapPanel>

                        <TextBlock Text="Scan/Crawl" Style="{StaticResource PanelHeaderTextStyle}" Margin="0,10,0,0"/>
                        <WrapPanel Margin="0,6,0,0">
                            <StackPanel Margin="0,0,12,8"><TextBlock Text="Max depth" Style="{StaticResource MetadataTextStyle}"/><TextBox Width="90" Text="{Binding Settings.Scan.MaxDepth}"/></StackPanel>
                            <StackPanel Margin="0,0,12,8"><TextBlock Text="Max pages" Style="{StaticResource MetadataTextStyle}"/><TextBox Width="90" Text="{Binding Settings.Scan.MaxPages}"/></StackPanel>
                            <StackPanel Margin="0,0,12,8"><TextBlock Text="Crawl workers" Style="{StaticResource MetadataTextStyle}"/><TextBox Width="90" Text="{Binding Settings.Scan.CrawlWorkers}"/></StackPanel>
                            <CheckBox Content="Probe content type" IsChecked="{Binding Settings.Scan.ProbeContentType}" Margin="0,20,12,8"/>
                        </WrapPanel>

                        <TextBlock Text="Scheduler" Style="{StaticResource PanelHeaderTextStyle}" Margin="0,10,0,0"/>
                        <TextBlock Text="{Binding SchedulerStatus}" Margin="0,4,0,8" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <DatePicker Grid.Column="0" SelectedDate="{Binding ScheduledStartDate}"/>
                            <TextBox Grid.Column="1" Text="{Binding ScheduledStartTimeText}" Margin="8,0,0,0"/>
                            <Button Grid.Column="2" Content="Schedule Start" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding ScheduleStartCommand}" Margin="8,0,16,0"/>
                            <DatePicker Grid.Column="3" SelectedDate="{Binding ScheduledPauseDate}"/>
                            <TextBox Grid.Column="4" Text="{Binding ScheduledPauseTimeText}" Margin="8,0,0,0"/>
                            <Button Grid.Column="5" Content="Schedule Pause" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding SchedulePauseCommand}" Margin="8,0,0,0"/>
                        </Grid>
                        <WrapPanel Margin="0,8,0,0">
                            <Button Content="Clear Schedule" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding ClearScheduleCommand}" Margin="0,0,8,0"/>
                            <Button Content="Export Diagnostics" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding ExportDiagnosticsCommand}"/>
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Border Grid.Row="3" Style="{StaticResource ToolPanelBorderStyle}" Margin="0,8,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Recent Events" FontWeight="SemiBold" FontSize="14"/>
                <DataGrid Grid.Row="1" ItemsSource="{Binding RecentEvents}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" Margin="0,8,0,8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="150"/>
                        <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="90"/>
                        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
                <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Foreground="{DynamicResource SecondaryTextBrush}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
