<UserControl x:Class="WindowsUtilityPack.Tools.NetworkInternet.Downloader.DownloaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime">
    <UserControl.Resources>
        <Style x:Key="CardBorder" TargetType="Border" BasedOn="{StaticResource ToolPanelBorderStyle}"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="{StaticResource IconDownload}" FontFamily="Segoe MDL2 Assets"
                       FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"
                       Foreground="{DynamicResource AccentBrush}"/>
            <TextBlock Text="Downloader" FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryTextBrush}"/>
        </StackPanel>

        <!-- Input bar -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,10" Padding="12,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="URL:" VerticalAlignment="Center" Margin="0,0,10,0"
                               Foreground="{DynamicResource SecondaryTextBrush}" FontSize="13"/>
                    <TextBox Grid.Column="1" Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                             Padding="8,5" Margin="0,0,8,0" FontSize="13"
                             AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="60"
                             VerticalScrollBarVisibility="Auto"
                             Background="{DynamicResource CardBackgroundBrush}"
                             Foreground="{DynamicResource PrimaryTextBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"/>
                    <Button Grid.Column="2" Content="🔍 Scan" Style="{StaticResource SecondaryActionButtonStyle}"
                            Command="{Binding ScanPageCommand}" Padding="10,7" Margin="0,0,8,0"
                            ToolTip="Scan URL for all downloadable files"/>
                    <Button Grid.Column="3" Content="Add to list" Style="{StaticResource PrimaryActionButtonStyle}"
                            Command="{Binding DownloadCommand}" Padding="18,7"/>
                </Grid>
                <Grid Grid.Row="1" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Save to:" VerticalAlignment="Center" Margin="0,0,10,0"
                               Foreground="{DynamicResource SecondaryTextBrush}" FontSize="13"/>
                    <TextBox Grid.Column="1" Text="{Binding SaveFolder, UpdateSourceTrigger=PropertyChanged}"
                             Padding="8,5" Margin="0,0,8,0" FontSize="13"
                             Background="{DynamicResource CardBackgroundBrush}"
                             Foreground="{DynamicResource PrimaryTextBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"/>
                    <!-- Format ComboBox -->
                    <ComboBox Grid.Column="2" ItemsSource="{Binding FormatLabels}"
                              SelectedItem="{Binding SelectedFormat}" Margin="0,0,6,0"
                              MinWidth="120" Padding="6,4"/>
                    <Button Grid.Column="3" Content="Browse..." Style="{StaticResource SecondaryActionButtonStyle}"
                            Command="{Binding BrowseFolderCommand}" Padding="10,5" Margin="0,0,6,0"/>
                    <Button Grid.Column="4" Content="Cancel" Style="{StaticResource SecondaryActionButtonStyle}"
                            Command="{Binding CancelCommand}" Padding="10,5" Margin="0,0,6,0"
                            Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <Button Grid.Column="5" Content="▶ Download All" Style="{StaticResource PrimaryActionButtonStyle}"
                            Command="{Binding StartAllCommand}" Padding="10,5" Margin="0,0,6,0"/>
                    <Button Grid.Column="6" Content="Clear Completed" Style="{StaticResource SecondaryActionButtonStyle}"
                            Command="{Binding ClearCompletedCommand}" Padding="10,5"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Row A — Tools status bar -->
        <Border Grid.Row="2" Style="{StaticResource ToolPanelBorderStyle}" Padding="10,6" Margin="0,0,0,6">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Install Tools" Style="{StaticResource PrimaryActionButtonStyle}"
                            Command="{Binding InstallToolsCommand}" Padding="10,4" Margin="0,0,6,0"
                            Visibility="{Binding DependenciesReady, Converter={StaticResource InvertedBoolToVisibilityConverter}}"/>
                    <Button Content="Update yt-dlp" Style="{StaticResource SecondaryActionButtonStyle}"
                            Command="{Binding UpdateYtDlpCommand}" Padding="10,4"
                            Visibility="{Binding DependenciesReady, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="12" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Row B — Settings panel (collapsible) -->
        <Border Grid.Row="3" Style="{StaticResource ToolPanelBorderStyle}" Padding="12,8" Margin="0,0,0,6">
            <StackPanel>
                <Button Content="⚙ Settings" Style="{StaticResource SecondaryActionButtonStyle}"
                        Command="{Binding ToggleSettingsCommand}" Padding="8,3"
                        HorizontalAlignment="Left"/>
                <WrapPanel Orientation="Horizontal" Margin="0,8,0,0"
                           Visibility="{Binding ShowSettings, Converter={StaticResource BoolToVisibilityConverter}}">
                    <CheckBox Content="Crawl sub-pages" IsChecked="{Binding CrawlSubdirectories}"
                              Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,16,4"
                              VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,4"
                                Visibility="{Binding CrawlSubdirectories, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Max depth" Foreground="{DynamicResource SecondaryTextBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"/>
                        <TextBox Text="{Binding MaxDepth, UpdateSourceTrigger=PropertyChanged}" Width="40"
                                 Padding="4,3" Background="{DynamicResource CardBackgroundBrush}"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,4"
                                Visibility="{Binding CrawlSubdirectories, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Max pages" Foreground="{DynamicResource SecondaryTextBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"/>
                        <TextBox Text="{Binding MaxPages, UpdateSourceTrigger=PropertyChanged}" Width="50"
                                 Padding="4,3" Background="{DynamicResource CardBackgroundBrush}"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,4">
                        <TextBlock Text="Concurrent" Foreground="{DynamicResource SecondaryTextBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"/>
                        <TextBox Text="{Binding MaxConcurrentDownloads, UpdateSourceTrigger=PropertyChanged}" Width="35"
                                 Padding="4,3" Background="{DynamicResource CardBackgroundBrush}"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
                    </StackPanel>
                    <CheckBox Content="Auto-start on add" IsChecked="{Binding AutoStartOnAdd}"
                              Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,16,4"
                              VerticalAlignment="Center"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Row E — Scraper panel (dynamically shown) -->
        <Border Grid.Row="4" Style="{StaticResource ToolPanelBorderStyle}" Padding="10,8" Margin="0,0,0,6"
                MaxHeight="350"
                Visibility="{Binding ShowScraperPanel, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- Header row with close button -->
                <DockPanel Margin="0,0,0,4">
                    <Button DockPanel.Dock="Right" Content="✕" ToolTip="Close panel"
                            Style="{StaticResource SecondaryActionButtonStyle}" Padding="6,2"
                            Command="{Binding CloseScanPanelCommand}"/>
                    <TextBlock Text="Discoverable Assets" FontWeight="SemiBold" FontSize="14"
                               Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                </DockPanel>
                <!-- Filter/type row -->
                <DockPanel Grid.Row="1" Margin="0,0,0,6">
                    <TextBlock Text="{Binding ScanStatusMessage}" Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox DockPanel.Dock="Right" MinWidth="100" Margin="6,0,0,0" Padding="4,3"
                              SelectedItem="{Binding SelectedTypeFilter}">
                        <sys:String>All</sys:String>
                        <sys:String>Image</sys:String>
                        <sys:String>Video</sys:String>
                        <sys:String>Audio</sys:String>
                        <sys:String>Document</sys:String>
                        <sys:String>Spreadsheet</sys:String>
                        <sys:String>Presentation</sys:String>
                        <sys:String>Archive</sys:String>
                        <sys:String>Executable</sys:String>
                        <sys:String>Font</sys:String>
                        <sys:String>Database</sys:String>
                        <sys:String>Code</sys:String>
                        <sys:String>Text</sys:String>
                        <sys:String>Disk</sys:String>
                        <sys:String>Other</sys:String>
                    </ComboBox>
                    <TextBox DockPanel.Dock="Right" Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                             MinWidth="160" Margin="10,0,0,0" Padding="6,3" FontSize="12"
                             Background="{DynamicResource CardBackgroundBrush}"
                             Foreground="{DynamicResource PrimaryTextBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"/>
                </DockPanel>
                <!-- Asset list -->
                <ListView Grid.Row="2" ItemsSource="{Binding ScrapedAssetsView}"
                          Background="{DynamicResource AppBackgroundBrush}"
                          Foreground="{DynamicResource PrimaryTextBrush}"
                          BorderThickness="0"
                          MinHeight="180"
                          VirtualizingPanel.IsVirtualizing="True">
                    <ListView.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock FontWeight="SemiBold" FontSize="12" Margin="0,4,0,2"
                                               Foreground="{DynamicResource AccentBrush}">
                                        <Run Text="{Binding Name, Mode=OneWay}"/>
                                        <Run Text=" ("/>
                                        <Run Text="{Binding ItemCount, Mode=OneWay}"/>
                                        <Run Text=")"/>
                                    </TextBlock>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListView.GroupStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <Border Background="{DynamicResource AccentBrush}" CornerRadius="3" Padding="4,1"
                                        Margin="0,0,4,0">
                                    <TextBlock Text="{Binding TypeLabel}" FontSize="10" Foreground="White"/>
                                </Border>
                                <Border Background="{DynamicResource SecondaryTextBrush}" CornerRadius="3" Padding="4,1"
                                        Margin="0,0,6,0" Opacity="0.7">
                                    <TextBlock Text="{Binding ExtensionLabel}" FontSize="9" Foreground="White"
                                               FontFamily="Consolas"/>
                                </Border>
                                <TextBlock Text="{Binding FileName}" VerticalAlignment="Center"
                                           Foreground="{DynamicResource PrimaryTextBrush}" FontSize="12"
                                           TextTrimming="CharacterEllipsis" MaxWidth="400"
                                           ToolTip="{Binding Url}"/>
                                <TextBlock Text="{Binding SizeLabel}" Margin="8,0,0,0" FontSize="11"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <!-- Footer -->
                <DockPanel Grid.Row="3" Margin="0,6,0,0">
                    <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"
                               VerticalAlignment="Center">
                        <Run Text="{Binding ScrapedAssets.Count, Mode=OneWay}"/>
                        <Run Text=" assets found"/>
                    </TextBlock>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Select All" Style="{StaticResource SecondaryActionButtonStyle}"
                                Command="{Binding SelectAllScrapedCommand}" Padding="8,3" Margin="0,0,6,0"/>
                        <Button Content="None" Style="{StaticResource SecondaryActionButtonStyle}"
                                Command="{Binding SelectNoneScrapedCommand}" Padding="8,3" Margin="0,0,6,0"/>
                        <Button Content="Download Selected" Style="{StaticResource PrimaryActionButtonStyle}"
                                Command="{Binding DownloadScrapedCommand}" Padding="10,4"/>
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>

        <!-- Downloads list -->
        <ListView Grid.Row="5" ItemsSource="{Binding Downloads}"
                  Background="{DynamicResource AppBackgroundBrush}"
                  Foreground="{DynamicResource PrimaryTextBrush}"
                  BorderThickness="0"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="File" Width="200">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Engine}" FontSize="11"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Size" Width="90" DisplayMemberBinding="{Binding TotalSize}"/>
                    <GridViewColumn Header="Progress" Width="180">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <ProgressBar Value="{Binding Progress}" Maximum="100" Height="14"
                                                 Background="{DynamicResource BorderBrush}"
                                                 Foreground="{DynamicResource AccentBrush}" BorderThickness="0"/>
                                    <TextBlock Text="{Binding Progress, StringFormat={}{0:F0}%}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontSize="10" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                </Grid>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Speed" Width="100" DisplayMemberBinding="{Binding Speed}"/>
                    <GridViewColumn Header="Status" Width="90" DisplayMemberBinding="{Binding Status}"/>
                    <GridViewColumn Header="Actions" Width="80">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="📂" ToolTip="Open file location" Padding="4,2" Margin="0,0,4,0"
                                            Command="{Binding DataContext.OpenFileCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                            CommandParameter="{Binding}"
                                            Visibility="{Binding Status, Converter={StaticResource StringEqualsToVisibilityConverter}, ConverterParameter=Complete}"/>
                                    <Button Content="↺" ToolTip="Retry" Padding="4,2" Margin="0,0,4,0"
                                            Command="{Binding DataContext.RetryItemCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                            CommandParameter="{Binding}"
                                            Visibility="{Binding Status, Converter={StaticResource StringEqualsToVisibilityConverter}, ConverterParameter=Failed}"/>
                                    <Button Content="✕" ToolTip="Cancel" Padding="4,2"
                                            Command="{Binding DataContext.CancelItemCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                            CommandParameter="{Binding}"
                                            Visibility="{Binding Status, Converter={StaticResource StringEqualsToVisibilityConverter}, ConverterParameter=Downloading}"/>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="URL" Width="300">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Url}" TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Url}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>
    </Grid>
</UserControl>
