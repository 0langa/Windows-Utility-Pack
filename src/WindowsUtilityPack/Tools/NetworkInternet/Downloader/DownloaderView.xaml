
<UserControl x:Class="WindowsUtilityPack.Tools.NetworkInternet.Downloader.DownloaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:WindowsUtilityPack.Tools.NetworkInternet.Downloader.Models"
             mc:Ignorable="d"
             d:DesignHeight="920" d:DesignWidth="1380">
    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeroSurfaceStyle}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Downloader Studio" Style="{StaticResource PrimaryHeadingTextStyle}" FontSize="26"/>
                    <TextBlock Margin="0,6,0,0" Text="Mode-correct download manager, media workflow, asset grabber, and crawl workstation" Foreground="{DynamicResource SecondaryTextBrush}"/>
                </StackPanel>
                <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border Style="{StaticResource StatusSurfaceStyle}" Padding="10,8" Margin="0,0,8,0"><TextBlock Text="{Binding QueuedCount, StringFormat=Queued: {0}}"/></Border>
                    <Border Style="{StaticResource StatusSurfaceStyle}" Padding="10,8" Margin="0,0,8,0"><TextBlock Text="{Binding ActiveCount, StringFormat=Active: {0}}"/></Border>
                    <Border Style="{StaticResource StatusSurfaceStyle}" Padding="10,8" Margin="0,0,8,0"><TextBlock Text="{Binding CompletedCount, StringFormat=Completed: {0}}"/></Border>
                    <Border Style="{StaticResource StatusSurfaceStyle}" Padding="10,8" Margin="0,0,8,0"><TextBlock Text="{Binding FailedCount, StringFormat=Failed: {0}}"/></Border>
                    <Button Content="Install Tools" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding InstallToolsCommand}" Margin="10,0,6,0"/>
                    <Button Content="Update yt-dlp" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding UpdateToolsCommand}" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding DependenciesReady, StringFormat=Deps Ready: {0}}" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                </WrapPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1">
            <TabItem Header="Quick Download">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Fast path for direct links and bulk paste." Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8"/>
                    <TextBox Grid.Row="1"
                             Text="{Binding QuickInput, UpdateSourceTrigger=PropertyChanged}"
                             MinHeight="72"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Padding="8,6"/>
                    <WrapPanel Grid.Row="2" Margin="0,8,0,8">
                        <Button Content="Analyze Input" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding AnalyzeQuickInputCommand}" Margin="0,0,6,0"/>
                        <Button Content="Add to Queue" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding AddToQueueCommand}" Margin="0,0,6,0"/>
                        <Button Content="Download Now" Style="{StaticResource PrimaryActionButtonStyle}" Command="{Binding DownloadNowCommand}" Margin="0,0,6,0"/>
                        <Button Content="Paste" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding PasteClipboardCommand}" Margin="0,0,6,0"/>
                        <Button Content="Import List" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding ImportLinksCommand}"/>
                    </WrapPanel>
                    <Border Grid.Row="3" Style="{StaticResource ToolPanelBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Detected Workflow" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding QuickDetectionSummary}" TextWrapping="Wrap"/>
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Text="This tab routes to direct/auto engine resolution. Discovery actions are in Asset Grabber and Site Crawl."/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem Header="Queue Manager">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <WrapPanel Margin="0,0,0,8">
                        <Button Content="Start Queue" Style="{StaticResource PrimaryActionButtonStyle}" Command="{Binding StartQueueCommand}" Margin="0,0,6,0"/>
                        <Button Content="Pause Queue" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding PauseQueueCommand}" Margin="0,0,6,0"/>
                        <Button Content="Stop Queue" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding StopQueueCommand}" Margin="0,0,12,0"/>
                        <Button Content="Start Selected" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding StartSelectedCommand}" Margin="0,0,6,0"/>
                        <Button Content="Pause Selected" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding PauseSelectedCommand}" Margin="0,0,6,0"/>
                        <Button Content="Resume Selected" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding ResumeSelectedCommand}" Margin="0,0,6,0"/>
                        <Button Content="Retry Selected" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding RetrySelectedCommand}" Margin="0,0,6,0"/>
                        <Button Content="Remove Selected" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding RemoveSelectedCommand}" Margin="0,0,12,0"/>
                        <Button Content="Retry Failed" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding RetryFailedCommand}" Margin="0,0,6,0"/>
                        <Button Content="Clear Completed" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding ClearCompletedCommand}" Margin="0,0,6,0"/>
                        <Button Content="Clear Failed" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding ClearFailedCommand}" Margin="0,0,12,0"/>
                        <Button Content="Top" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding MoveSelectedTopCommand}" Margin="0,0,6,0"/>
                        <Button Content="Up" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding MoveSelectedUpCommand}" Margin="0,0,6,0"/>
                        <Button Content="Down" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding MoveSelectedDownCommand}" Margin="0,0,6,0"/>
                        <Button Content="Bottom" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding MoveSelectedBottomCommand}" Margin="0,0,12,0"/>
                        <Button Content="Priority High" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding SetPriorityHighCommand}" Margin="0,0,6,0"/>
                        <Button Content="Priority Normal" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding SetPriorityNormalCommand}" Margin="0,0,6,0"/>
                        <Button Content="Priority Low" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding SetPriorityLowCommand}"/>
                    </WrapPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3.2*"/>
                            <ColumnDefinition Width="1.3*"/>
                        </Grid.ColumnDefinitions>

                        <DataGrid x:Name="QueueGrid"
                                  Grid.Column="0"
                                  ItemsSource="{Binding Jobs}"
                                  SelectedItem="{Binding SelectedJob, Mode=TwoWay}"
                                  SelectionMode="Extended"
                                  SelectionUnit="FullRow"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionChanged="QueueGrid_OnSelectionChanged"
                                  CanUserSortColumns="True">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Start selected" Command="{Binding StartSelectedCommand}"/>
                                    <MenuItem Header="Pause selected" Command="{Binding PauseSelectedCommand}"/>
                                    <MenuItem Header="Resume selected" Command="{Binding ResumeSelectedCommand}"/>
                                    <MenuItem Header="Retry selected" Command="{Binding RetrySelectedCommand}"/>
                                    <Separator/>
                                    <MenuItem Header="Open source URL" Command="{Binding OpenSourceCommand}"/>
                                    <MenuItem Header="Open containing folder" Command="{Binding OpenContainingFolderCommand}"/>
                                    <MenuItem Header="Copy source URL" Command="{Binding CopySourceUrlCommand}"/>
                                    <Separator/>
                                    <MenuItem Header="Remove selected" Command="{Binding RemoveSelectedCommand}"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Title" Binding="{Binding DisplayTitle}" Width="2*"/>
                                <DataGridTextColumn Header="Engine" Binding="{Binding EngineType}" Width="95"/>
                                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="105"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="105"/>
                                <DataGridTemplateColumn Header="Progress" Width="200">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <ProgressBar Minimum="0" Maximum="100" Value="{Binding ProgressPercent}" Height="14"/>
                                                <TextBlock Text="{Binding ProgressPercent, StringFormat={}{0:F0}%}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10"/>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Speed" Binding="{Binding SpeedLabel}" Width="90"/>
                                <DataGridTextColumn Header="ETA" Binding="{Binding EtaLabel}" Width="80"/>
                                <DataGridTextColumn Header="Plan" Binding="{Binding EffectivePlan}" Width="2*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Column="1" Style="{StaticResource ToolPanelBorderStyle}" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Inspector" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBlock Text="Source URL" Style="{StaticResource MetadataTextStyle}"/>
                                <Grid Margin="0,2,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding SelectedJob.SourceUrl}"
                                             IsReadOnly="True"
                                             IsTabStop="True"
                                             TextWrapping="Wrap"
                                             MinHeight="46"
                                             Margin="0,0,6,0"/>
                                    <Button Grid.Column="1"
                                            Content="Copy"
                                            Style="{StaticResource SecondaryActionButtonStyle}"
                                            Command="{Binding CopyInspectorFieldCommand}"
                                            CommandParameter="{Binding SelectedJob.SourceUrl}"/>
                                </Grid>
                                <TextBlock Text="Resolved URL" Style="{StaticResource MetadataTextStyle}"/>
                                <Grid Margin="0,2,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding SelectedJob.ResolvedUrl}"
                                             IsReadOnly="True"
                                             IsTabStop="True"
                                             TextWrapping="Wrap"
                                             MinHeight="46"
                                             Margin="0,0,6,0"/>
                                    <Button Grid.Column="1"
                                            Content="Copy"
                                            Style="{StaticResource SecondaryActionButtonStyle}"
                                            Command="{Binding CopyInspectorFieldCommand}"
                                            CommandParameter="{Binding SelectedJob.ResolvedUrl}"/>
                                </Grid>
                                <TextBlock Text="Output" Style="{StaticResource MetadataTextStyle}"/>
                                <Grid Margin="0,2,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding SelectedJob.OutputFilePath}"
                                             IsReadOnly="True"
                                             IsTabStop="True"
                                             TextWrapping="Wrap"
                                             MinHeight="46"
                                             Margin="0,0,6,0"/>
                                    <Button Grid.Column="1"
                                            Content="Copy"
                                            Style="{StaticResource SecondaryActionButtonStyle}"
                                            Command="{Binding CopyInspectorFieldCommand}"
                                            CommandParameter="{Binding SelectedJob.OutputFilePath}"/>
                                </Grid>
                                <TextBlock Text="Status Message" Style="{StaticResource MetadataTextStyle}"/>
                                <TextBox Text="{Binding SelectedJob.StatusMessage}" IsReadOnly="True" TextWrapping="Wrap" MinHeight="46" Margin="0,2,0,8"/>
                                <TextBlock Text="Error" Style="{StaticResource MetadataTextStyle}"/>
                                <TextBox Text="{Binding SelectedJob.ErrorSummary}" IsReadOnly="True" TextWrapping="Wrap" MinHeight="46" Margin="0,2,0,8"/>
                                <WrapPanel>
                                    <Button Content="Open Source" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding OpenSourceCommand}" Margin="0,0,6,6"/>
                                    <Button Content="Open Folder" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding OpenContainingFolderCommand}" Margin="0,0,6,6"/>
                                    <Button Content="Copy URL" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding CopySourceUrlCommand}" Margin="0,0,6,6"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="Media Download">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Dedicated media workflow. Default behavior is video; audio-only is explicit." Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8"/>
                    <TextBox Grid.Row="1" Text="{Binding MediaInput, UpdateSourceTrigger=PropertyChanged}" Padding="8,6"/>
                    <WrapPanel Grid.Row="2" Margin="0,8,0,8">
                        <TextBlock Text="Output:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox Width="130" ItemsSource="{Binding MediaOutputKinds}" SelectedItem="{Binding SelectedMediaOutputKind}" Margin="0,0,8,0"/>
                        <TextBlock Text="Video Profile:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox Width="220" ItemsSource="{Binding MediaVideoProfiles}" SelectedItem="{Binding SelectedMediaVideoProfile}" Margin="0,0,8,0"/>
                        <TextBlock Text="Container:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox Width="90" ItemsSource="{Binding MediaContainers}" SelectedItem="{Binding SelectedMediaContainer}" Margin="0,0,8,0"/>
                        <TextBlock Text="Audio Format:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox Width="90" ItemsSource="{Binding MediaAudioFormats}" SelectedItem="{Binding SelectedMediaAudioFormat}" Margin="0,0,12,0"/>
                        <Button Content="Analyze Media" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding AnalyzeMediaCommand}" Margin="0,0,6,0"/>
                        <Button Content="Add to Queue" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding AddMediaToQueueCommand}" Margin="0,0,6,0"/>
                        <Button Content="Download Now" Style="{StaticResource PrimaryActionButtonStyle}" Command="{Binding DownloadMediaNowCommand}" Margin="0,0,6,0"/>
                        <Button Content="Reset Defaults" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding ResetMediaDefaultsCommand}"/>
                    </WrapPanel>
                    <Border Grid.Row="3" Style="{StaticResource ToolPanelBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Effective Media Plan" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding MediaAnalysisSummary}" TextWrapping="Wrap"/>
                            <WrapPanel Margin="0,8,0,0">
                                <CheckBox Content="Download Subtitles" IsChecked="{Binding Settings.Media.DownloadSubtitles}" Margin="0,0,16,6"/>
                                <CheckBox Content="Download Thumbnail" IsChecked="{Binding Settings.Media.DownloadThumbnail}" Margin="0,0,16,6"/>
                                <CheckBox Content="Embed Metadata" IsChecked="{Binding Settings.Media.EmbedMetadata}" Margin="0,0,16,6"/>
                                <CheckBox Content="Allow Playlist" IsChecked="{Binding Settings.Media.AllowPlaylist}" Margin="0,0,16,6"/>
                                <CheckBox Content="Save Caption Files" IsChecked="{Binding Settings.Media.SaveCaptionFiles}" Margin="0,0,16,6"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem Header="YouTube Video">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="YouTube-first workflow: paste links, choose exact quality profile, and download to disk quickly." Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8"/>
                    <TextBox Grid.Row="1"
                             Text="{Binding YoutubeInput, UpdateSourceTrigger=PropertyChanged}"
                             MinHeight="64"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Padding="8,6"/>
                    <Grid Grid.Row="2" Margin="0,8,0,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <WrapPanel>
                            <Button Content="Analyze YouTube" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding AnalyzeYoutubeCommand}" Margin="0,0,6,0"/>
                            <Button Content="Add to Queue" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding AddYoutubeToQueueCommand}" Margin="0,0,6,0"/>
                            <Button Content="Download Now" Style="{StaticResource PrimaryActionButtonStyle}" Command="{Binding DownloadYoutubeNowCommand}" Margin="0,0,6,0"/>
                            <Button Content="Reset YouTube Defaults" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding ResetYoutubeDefaultsCommand}"/>
                        </WrapPanel>
                        <UniformGrid Grid.Row="1" Rows="2" Columns="3" Margin="0,8,0,0">
                            <StackPanel Margin="0,0,12,8">
                                <TextBlock Text="Video Quality" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding YoutubeVideoQualities}" SelectedItem="{Binding SelectedYoutubeVideoQuality}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,12,8">
                                <TextBlock Text="Frame Rate" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding YoutubeFrameRates}" SelectedItem="{Binding SelectedYoutubeFrameRate}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,12,8">
                                <TextBlock Text="Video Codec" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding YoutubeVideoCodecs}" SelectedItem="{Binding SelectedYoutubeVideoCodec}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="Audio Quality" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding YoutubeAudioQualities}" SelectedItem="{Binding SelectedYoutubeAudioQuality}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="Audio Codec" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding YoutubeAudioCodecs}" SelectedItem="{Binding SelectedYoutubeAudioCodec}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="Container" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding MediaContainers}" SelectedItem="{Binding SelectedYoutubeContainer}"/>
                            </StackPanel>
                        </UniformGrid>
                        <WrapPanel Grid.Row="2" Margin="0,8,0,0">
                            <CheckBox Content="Download Subtitles" IsChecked="{Binding Settings.Media.DownloadSubtitles}" Margin="0,0,16,6"/>
                            <CheckBox Content="Download Thumbnail" IsChecked="{Binding Settings.Media.DownloadThumbnail}" Margin="0,0,16,6"/>
                            <CheckBox Content="Embed Metadata" IsChecked="{Binding Settings.Media.EmbedMetadata}" Margin="0,0,16,6"/>
                            <CheckBox Content="Allow Playlist" IsChecked="{Binding Settings.Media.AllowPlaylist}" Margin="0,0,16,6"/>
                        </WrapPanel>
                    </Grid>
                    <Border Grid.Row="3" Style="{StaticResource ToolPanelBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="YouTube Execution Plan" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding YoutubeAnalysisSummary}" TextWrapping="Wrap"/>
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Text="This tab accepts only youtube.com/youtu.be links and applies the selected quality profile to every added job."/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Asset Grabber">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding ScanUrl, UpdateSourceTrigger=PropertyChanged}" Padding="8,6"/>
                        <Button Grid.Column="1" Content="Scan Page" Style="{StaticResource PrimaryActionButtonStyle}" Command="{Binding ScanPageCommand}" Margin="8,0,0,0"/>
                    </Grid>
                    <WrapPanel Grid.Row="1" Margin="0,8,0,8">
                        <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox Width="150" ItemsSource="{Binding AssetFilters}" SelectedItem="{Binding SelectedAssetFilter}" Margin="0,0,8,0"/>
                        <TextBox Width="240" Text="{Binding AssetSearchText, UpdateSourceTrigger=PropertyChanged}" Padding="6,4" Margin="0,0,8,0"/>
                        <Button Content="Select All" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding SelectAllAssetsCommand}" Margin="0,0,6,0"/>
                        <Button Content="Select Visible" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding SelectVisibleAssetsCommand}" Margin="0,0,6,0"/>
                        <Button Content="Deselect All" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding DeselectAllAssetsCommand}" Margin="0,0,6,0"/>
                        <Button Content="Invert" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding InvertAssetSelectionCommand}" Margin="0,0,12,0"/>
                        <Button Content="Add Selected to Queue" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding AddSelectedAssetsCommand}" Margin="0,0,6,0"/>
                        <Button Content="Download Selected Now" Style="{StaticResource PrimaryActionButtonStyle}" Command="{Binding DownloadSelectedAssetsNowCommand}" Margin="0,0,6,0"/>
                        <Button Content="Clear Staged" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding ClearDiscoveredAssetsCommand}" Margin="0,0,12,0"/>
                        <TextBlock Text="{Binding ScanStatus}" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </WrapPanel>
                    <DataGrid Grid.Row="2" ItemsSource="{Binding DiscoveredAssetsView}" AutoGenerateColumns="False" SelectionMode="Extended">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Select all" Command="{Binding SelectAllAssetsCommand}"/>
                                <MenuItem Header="Select visible" Command="{Binding SelectVisibleAssetsCommand}"/>
                                <MenuItem Header="Deselect all" Command="{Binding DeselectAllAssetsCommand}"/>
                                <MenuItem Header="Invert selection" Command="{Binding InvertAssetSelectionCommand}"/>
                                <Separator/>
                                <MenuItem Header="Add selected to queue" Command="{Binding AddSelectedAssetsCommand}"/>
                                <MenuItem Header="Download selected now" Command="{Binding DownloadSelectedAssetsNowCommand}"/>
                                <Separator/>
                                <MenuItem Header="Clear staged results" Command="{Binding ClearDiscoveredAssetsCommand}"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="Get" Binding="{Binding IsSelected, Mode=TwoWay}" Width="55"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding TypeLabel}" Width="90"/>
                            <DataGridTextColumn Header="Ext" Binding="{Binding Extension}" Width="70"/>
                            <DataGridTextColumn Header="Size" Binding="{Binding SizeLabel}" Width="90"/>
                            <DataGridTextColumn Header="Source Page" Binding="{Binding SourcePage}" Width="2*"/>
                            <DataGridTextColumn Header="Host" Binding="{Binding Host}" Width="150"/>
                            <DataGridTextColumn Header="Reachable" Binding="{Binding IsReachable}" Width="80"/>
                            <DataGridTextColumn Header="Warning" Binding="{Binding Warning}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Site Crawl">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding CrawlUrl, UpdateSourceTrigger=PropertyChanged}" Padding="8,6"/>
                        <Button Grid.Column="1" Content="Crawl Site" Style="{StaticResource PrimaryActionButtonStyle}" Command="{Binding CrawlSiteCommand}" Margin="8,0,0,0"/>
                    </Grid>
                    <WrapPanel Grid.Row="1" Margin="0,8,0,8">
                        <CheckBox Content="Same domain only" IsChecked="{Binding Settings.Scan.SameDomainOnly}" Margin="0,0,16,6"/>
                        <CheckBox Content="Same subpath only" IsChecked="{Binding Settings.Scan.SameSubPathOnly}" Margin="0,0,16,6"/>
                        <CheckBox Content="Unique assets only" IsChecked="{Binding Settings.Scan.UniqueAssetsOnly}" Margin="0,0,16,6"/>
                        <CheckBox Content="Probe content type" IsChecked="{Binding Settings.Scan.ProbeContentType}" Margin="0,0,16,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,6"><TextBlock Text="Max Depth" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBox Width="50" Text="{Binding Settings.Scan.MaxDepth}"/></StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,6"><TextBlock Text="Max Pages" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBox Width="70" Text="{Binding Settings.Scan.MaxPages}"/></StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,6"><TextBlock Text="Workers" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBox Width="50" Text="{Binding Settings.Scan.CrawlWorkers}"/></StackPanel>
                        <Button Content="Add Selected to Queue" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding AddSelectedAssetsCommand}" Margin="0,0,6,0"/>
                        <Button Content="Download Selected Now" Style="{StaticResource PrimaryActionButtonStyle}" Command="{Binding DownloadSelectedAssetsNowCommand}"/>
                    </WrapPanel>
                    <DataGrid Grid.Row="2" ItemsSource="{Binding DiscoveredAssetsView}" AutoGenerateColumns="False">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Select all" Command="{Binding SelectAllAssetsCommand}"/>
                                <MenuItem Header="Select visible" Command="{Binding SelectVisibleAssetsCommand}"/>
                                <MenuItem Header="Deselect all" Command="{Binding DeselectAllAssetsCommand}"/>
                                <MenuItem Header="Invert selection" Command="{Binding InvertAssetSelectionCommand}"/>
                                <Separator/>
                                <MenuItem Header="Add selected to queue" Command="{Binding AddSelectedAssetsCommand}"/>
                                <MenuItem Header="Download selected now" Command="{Binding DownloadSelectedAssetsNowCommand}"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="Get" Binding="{Binding IsSelected, Mode=TwoWay}" Width="55"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding TypeLabel}" Width="90"/>
                            <DataGridTextColumn Header="Source Page" Binding="{Binding SourcePage}" Width="2*"/>
                            <DataGridTextColumn Header="Host" Binding="{Binding Host}" Width="160"/>
                            <DataGridTextColumn Header="Size" Binding="{Binding SizeLabel}" Width="95"/>
                            <DataGridTextColumn Header="Warning" Binding="{Binding Warning}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="History &amp; Diagnostics">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <WrapPanel Margin="0,0,0,8">
                        <Button Content="Redownload Selected" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding RedownloadHistoryItemCommand}" CommandParameter="{Binding SelectedItem, ElementName=HistoryGrid}" Margin="0,0,6,0"/>
                        <Button Content="Open File" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding OpenHistoryFileCommand}" Margin="0,0,6,0"/>
                        <Button Content="Open Folder" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding OpenHistoryFolderCommand}" Margin="0,0,6,0"/>
                        <Button Content="Open Source URL" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding OpenHistorySourceCommand}" Margin="0,0,6,0"/>
                        <Button Content="Copy URL" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding CopyHistorySourceCommand}" Margin="0,0,12,0"/>
                        <Button Content="Clear History" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding ClearHistoryCommand}"/>
                    </WrapPanel>
                    <DataGrid x:Name="HistoryGrid"
                              Grid.Row="1"
                              ItemsSource="{Binding History}"
                              SelectedItem="{Binding SelectedHistoryEntry, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Redownload selected" Command="{Binding RedownloadHistoryItemCommand}" CommandParameter="{Binding SelectedItem, ElementName=HistoryGrid}"/>
                                <MenuItem Header="Open file" Command="{Binding OpenHistoryFileCommand}"/>
                                <MenuItem Header="Open folder" Command="{Binding OpenHistoryFolderCommand}"/>
                                <MenuItem Header="Open source URL" Command="{Binding OpenHistorySourceCommand}"/>
                                <MenuItem Header="Copy URL" Command="{Binding CopyHistorySourceCommand}"/>
                                <Separator/>
                                <MenuItem Header="Clear history" Command="{Binding ClearHistoryCommand}"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="When" Binding="{Binding CompletedAt}" Width="145"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding FinalStatus}" Width="95"/>
                            <DataGridTextColumn Header="Engine" Binding="{Binding EngineType}" Width="90"/>
                            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="2*"/>
                            <DataGridTextColumn Header="URL" Binding="{Binding SourceUrl}" Width="2*"/>
                            <DataGridTextColumn Header="Error" Binding="{Binding ErrorSummary}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <WrapPanel Grid.Row="2" Margin="0,8,0,8">
                        <TextBlock Text="Recent Event Log" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Button Content="Export Diagnostics" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding ExportDiagnosticsCommand}"/>
                    </WrapPanel>
                    <DataGrid Grid.Row="3" ItemsSource="{Binding RecentEvents}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="150"/>
                            <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="90"/>
                            <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Settings, Rules &amp; Help">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TabControl>
                        <TabItem Header="Settings">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,4,0,0">
                                <StackPanel>
                                    <TextBlock Text="General" Style="{StaticResource PanelHeaderTextStyle}"/>
                                    <WrapPanel Margin="0,6,0,0">
                                        <CheckBox Content="Auto start on add" IsChecked="{Binding Settings.General.AutoStartOnAdd}" Margin="0,0,16,8"/>
                                        <CheckBox Content="Clipboard monitoring" IsChecked="{Binding Settings.General.ClipboardMonitoring}" Margin="0,0,16,8"/>
                                        <CheckBox Content="Stage links before download" IsChecked="{Binding Settings.General.StageLinksBeforeDownload}" Margin="0,0,16,8"/>
                                        <CheckBox Content="Compact density mode" IsChecked="{Binding Settings.General.CompactDensityMode}" Margin="0,0,16,8"/>
                                    </WrapPanel>
                                    <TextBox Text="{Binding Settings.General.DefaultDownloadFolder}" Padding="6,4" Margin="0,4,0,8"/>

                                    <TextBlock Text="Queue" Style="{StaticResource PanelHeaderTextStyle}" Margin="0,10,0,0"/>
                                    <WrapPanel Margin="0,6,0,0">
                                        <StackPanel Margin="0,0,12,8"><TextBlock Text="Max concurrent" Style="{StaticResource MetadataTextStyle}"/><TextBox Width="80" Text="{Binding Settings.Queue.MaxConcurrentDownloads}"/></StackPanel>
                                        <StackPanel Margin="0,0,12,8"><TextBlock Text="Max retries" Style="{StaticResource MetadataTextStyle}"/><TextBox Width="80" Text="{Binding Settings.Queue.MaxRetries}"/></StackPanel>
                                        <StackPanel Margin="0,0,12,8"><TextBlock Text="Retry delay (s)" Style="{StaticResource MetadataTextStyle}"/><TextBox Width="80" Text="{Binding Settings.Queue.RetryDelaySeconds}"/></StackPanel>
                                        <StackPanel Margin="0,0,12,8"><TextBlock Text="Default priority" Style="{StaticResource MetadataTextStyle}"/><TextBox Width="110" Text="{Binding Settings.Queue.DefaultPriority}"/></StackPanel>
                                    </WrapPanel>

                                    <TextBlock Text="Connections" Style="{StaticResource PanelHeaderTextStyle}" Margin="0,10,0,0"/>
                                    <WrapPanel Margin="0,6,0,0">
                                        <StackPanel Margin="0,0,12,8"><TextBlock Text="Segments" Style="{StaticResource MetadataTextStyle}"/><TextBox Width="80" Text="{Binding Settings.Connections.SegmentsPerDownload}"/></StackPanel>
                                        <StackPanel Margin="0,0,12,8"><TextBlock Text="Segment threshold MB" Style="{StaticResource MetadataTextStyle}"/><TextBox Width="110" Text="{Binding Settings.Connections.SegmentThresholdMb}"/></StackPanel>
                                        <StackPanel Margin="0,0,12,8"><TextBlock Text="Timeout (s)" Style="{StaticResource MetadataTextStyle}"/><TextBox Width="80" Text="{Binding Settings.Connections.TimeoutSeconds}"/></StackPanel>
                                        <StackPanel Margin="0,0,12,8"><TextBlock Text="Max redirects" Style="{StaticResource MetadataTextStyle}"/><TextBox Width="80" Text="{Binding Settings.Connections.MaxRedirects}"/></StackPanel>
                                    </WrapPanel>

                                    <TextBlock Text="Scan/Crawl" Style="{StaticResource PanelHeaderTextStyle}" Margin="0,10,0,0"/>
                                    <WrapPanel Margin="0,6,0,0">
                                        <CheckBox Content="Same domain only" IsChecked="{Binding Settings.Scan.SameDomainOnly}" Margin="0,0,16,8"/>
                                        <CheckBox Content="Same subpath only" IsChecked="{Binding Settings.Scan.SameSubPathOnly}" Margin="0,0,16,8"/>
                                        <CheckBox Content="Unique assets only" IsChecked="{Binding Settings.Scan.UniqueAssetsOnly}" Margin="0,0,16,8"/>
                                        <CheckBox Content="Probe content type" IsChecked="{Binding Settings.Scan.ProbeContentType}" Margin="0,0,16,8"/>
                                        <CheckBox Content="Scan scripts/json" IsChecked="{Binding Settings.Scan.ScanScriptsAndJson}" Margin="0,0,16,8"/>
                                    </WrapPanel>

                                    <TextBlock Text="Scheduler" Style="{StaticResource PanelHeaderTextStyle}" Margin="0,10,0,0"/>
                                    <TextBlock Text="{Binding SchedulerStatus}" Margin="0,4,0,8" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <DatePicker Grid.Column="0" SelectedDate="{Binding ScheduledStartDate}"/>
                                        <TextBox Grid.Column="1" Text="{Binding ScheduledStartTimeText}" Margin="8,0,0,0"/>
                                        <Button Grid.Column="2" Content="Schedule Start" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding ScheduleStartCommand}" Margin="8,0,16,0"/>
                                        <DatePicker Grid.Column="3" SelectedDate="{Binding ScheduledPauseDate}"/>
                                        <TextBox Grid.Column="4" Text="{Binding ScheduledPauseTimeText}" Margin="8,0,0,0"/>
                                        <Button Grid.Column="5" Content="Schedule Pause" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding SchedulePauseCommand}" Margin="8,0,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Rules">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <WrapPanel Margin="0,0,0,8">
                                    <Button Content="Add Rule" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding AddCategoryRuleCommand}" Margin="0,0,6,0"/>
                                    <Button Content="Remove Rule" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding RemoveCategoryRuleCommand}" Margin="0,0,6,0"/>
                                    <Button Content="Reset Defaults" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding ResetCategoryRulesCommand}" Margin="0,0,12,0"/>
                                    <Button Content="Cookie File" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding PickCookieFileCommand}" Margin="0,0,12,0"/>
                                    <Button Content="Save Settings" Style="{StaticResource PrimaryActionButtonStyle}" Command="{Binding SaveSettingsCommand}"/>
                                </WrapPanel>
                                <DataGrid Grid.Row="1" ItemsSource="{Binding CategoryRules}" SelectedItem="{Binding SelectedCategoryRule, Mode=TwoWay}" AutoGenerateColumns="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="160"/>
                                        <DataGridTextColumn Header="Default Folder" Binding="{Binding DefaultFolder}" Width="2*"/>
                                        <DataGridTextColumn Header="Extensions" Binding="{Binding Extensions}" Width="2*"/>
                                        <DataGridTextColumn Header="Domain Contains" Binding="{Binding DomainContains}" Width="2*"/>
                                        <DataGridTextColumn Header="Priority" Binding="{Binding PriorityOverride}" Width="100"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Help &amp; Tutorials">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="2.2*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource ToolPanelBorderStyle}" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="How do I..." FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <TextBox Text="{Binding HelpSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="6,4"
                                                 Margin="0,0,0,8"
                                                 ToolTip="Search help topics"/>
                                        <ListBox ItemsSource="{Binding HelpTopicsView}" SelectedItem="{Binding SelectedHelpTopic, Mode=TwoWay}" MinHeight="260"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource ToolPanelBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Guide" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <TextBlock Text="Each topic includes what to click, why, and expected results for verification."
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   Margin="0,0,0,8"
                                                   TextWrapping="Wrap"/>
                                        <TextBox Text="{Binding HelpContent}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" MinHeight="260"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </TabItem>
                    </TabControl>

                    <WrapPanel Grid.Row="1" Margin="0,8,0,0">
                        <Button Content="Save Settings" Style="{StaticResource PrimaryActionButtonStyle}" Command="{Binding SaveSettingsCommand}" Margin="0,0,8,0"/>
                        <Button Content="Clear Schedule" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding ClearScheduleCommand}" Margin="0,0,8,0"/>
                        <TextBlock Text="Changes here control queue, media, crawl, file handling, and diagnostics behavior." VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </WrapPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Style="{StaticResource ToolPanelBorderStyle}" Margin="0,8,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource SecondaryTextBrush}"/>
        </Border>
    </Grid>
</UserControl>
