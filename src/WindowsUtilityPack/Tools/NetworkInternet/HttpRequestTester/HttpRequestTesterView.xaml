<UserControl x:Class="WindowsUtilityPack.Tools.NetworkInternet.HttpRequestTester.HttpRequestTesterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="4" MaxWidth="1120">

            <Border Style="{StaticResource HeroSurfaceStyle}" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="250"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="HTTP Request Tester" Style="{StaticResource PrimaryHeadingTextStyle}" FontSize="24"/>
                        <TextBlock Text="A lightweight API workstation for composing requests, sending them quickly, and inspecting the full response."
                                   Style="{StaticResource MetadataTextStyle}"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="1" Style="{StaticResource StatusSurfaceStyle}" Margin="16,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Use Cases" Style="{StaticResource PanelHeaderTextStyle}"/>
                            <TextBlock Text="Smoke-test APIs, inspect headers, validate payloads, and copy the raw response body."
                                       Style="{StaticResource MetadataTextStyle}"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Style="{StaticResource ElevatedSurfaceStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox ItemsSource="{Binding Methods}"
                                  SelectedItem="{Binding Method}"
                                  Width="120"
                                  Margin="0,0,10,0"
                                  FontWeight="SemiBold"
                                  AutomationProperties.Name="HTTP method"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                                 AutomationProperties.Name="Request URL"/>
                        <Button Grid.Column="2"
                                Content="Send"
                                Command="{Binding SendCommand}"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Margin="10,0,8,0"/>
                        <Button Grid.Column="3"
                                Content="Clear"
                                Command="{Binding ClearCommand}"
                                Style="{StaticResource SecondaryActionButtonStyle}"/>
                    </Grid>

                    <Border Style="{StaticResource StatusSurfaceStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border CornerRadius="10"
                                    Padding="10,6"
                                    Margin="0,0,12,0"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource AccentBrush}">
                                <TextBlock Text="{Binding ResponseStatus}" FontWeight="SemiBold" Foreground="{DynamicResource TextOnAccentBrush}"/>
                            </Border>

                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource SecondaryTextBrush}">
                                <Run Text="{Binding ResponseTimeMs, Mode=OneWay}"/>
                                <Run Text=" ms"/>
                            </TextBlock>

                            <TextBlock Grid.Column="2"
                                       Text="Sending..."
                                       Visibility="{Binding IsSending, Converter={StaticResource BoolToVisibilityConverter}}"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       VerticalAlignment="Center"
                                       Margin="16,0,0,0"/>

                            <Button Grid.Column="3"
                                    Content="Copy Response"
                                    Command="{Binding CopyResponseCommand}"
                                    Style="{StaticResource SecondaryActionButtonStyle}"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="1.5*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource ElevatedSurfaceStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Request Headers" Style="{StaticResource SectionHeadingTextStyle}" FontSize="18"/>
                            <TextBlock Text="Use `Key: Value` pairs, one header per line."
                                       Style="{StaticResource MetadataTextStyle}"
                                       Margin="0,4,0,10"/>
                            <TextBox Text="{Binding RequestHeaders, UpdateSourceTrigger=PropertyChanged}"
                                     MinHeight="120"
                                     MaxHeight="240"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     AutomationProperties.Name="Custom request headers"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ElevatedSurfaceStyle}"
                            Visibility="{Binding ShowRequestBody, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Request Body" Style="{StaticResource SectionHeadingTextStyle}" FontSize="18"/>
                            <TextBlock Text="Shown for methods that typically send a payload."
                                       Style="{StaticResource MetadataTextStyle}"
                                       Margin="0,4,0,10"/>
                            <TextBox Text="{Binding RequestBody, UpdateSourceTrigger=PropertyChanged}"
                                     MinHeight="220"
                                     MaxHeight="420"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     AutomationProperties.Name="Request body"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource ElevatedSurfaceStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Response Headers" Style="{StaticResource SectionHeadingTextStyle}" FontSize="18"/>
                            <TextBox Text="{Binding ResponseHeaders, Mode=OneWay}"
                                     IsReadOnly="True"
                                     MinHeight="120"
                                     MaxHeight="220"
                                     FontFamily="Consolas"
                                     FontSize="11"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ElevatedSurfaceStyle}">
                        <StackPanel>
                            <TextBlock Text="Response Body" Style="{StaticResource SectionHeadingTextStyle}" FontSize="18"/>
                            <TextBox Text="{Binding ResponseBody, Mode=OneWay}"
                                     IsReadOnly="True"
                                     MinHeight="320"
                                     MaxHeight="640"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
