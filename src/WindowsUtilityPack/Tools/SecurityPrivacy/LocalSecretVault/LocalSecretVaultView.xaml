<UserControl x:Class="WindowsUtilityPack.Tools.SecurityPrivacy.LocalSecretVault.LocalSecretVaultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="4" MaxWidth="900">

            <DockPanel Margin="0,0,0,16">
                <Button DockPanel.Dock="Right" Content="Lock Vault"
                        Command="{Binding LockCommand}"
                        Style="{StaticResource SecondaryActionButtonStyle}"
                        Visibility="{Binding IsLocked, Converter={StaticResource InvertedBoolToVisibilityConverter}}"/>
                <TextBlock Text="Local Secret Vault" Style="{StaticResource ToolTitleTextStyle}"/>
            </DockPanel>

            <!-- Security note -->
            <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="12,8" Margin="0,0,0,12"
                    Background="{DynamicResource PanelBackgroundBrush}">
                <TextBlock Text="All data encrypted with AES-256 (PBKDF2 key derivation, 100,000 iterations)"
                           Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- Lock screen -->
            <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="24"
                    Visibility="{Binding IsLocked, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel MaxWidth="400" HorizontalAlignment="Center">
                    <TextBlock Text="Vault Locked" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="Master Password" Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="12" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="MasterPasswordBox"
                                 PasswordChanged="MasterPasswordBox_PasswordChanged"
                                 Padding="8,6" Margin="0,0,0,12"
                                 AutomationProperties.Name="Master password"/>
                    <Button Content="Unlock Vault"
                            Command="{Binding UnlockCommand}"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            HorizontalAlignment="Stretch"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="12" Margin="0,10,0,0"
                               HorizontalAlignment="Center" TextWrapping="Wrap"/>
                    <TextBlock Text="If no vault exists, a new one will be created with this password."
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="11" Margin="0,6,0,0"
                               HorizontalAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Main vault view -->
            <Grid Visibility="{Binding IsLocked, Converter={StaticResource InvertedBoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: search + list + Add button -->
                <StackPanel Margin="0,0,8,0">
                    <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="12" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="8,6" Margin="0,0,0,8"
                                     AutomationProperties.Name="Search secrets"/>
                            <Button Content="+ Add Secret"
                                    Command="{Binding AddSecretCommand}"
                                    Style="{StaticResource PrimaryActionButtonStyle}"
                                    HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource ToolPanelBorderStyle}" Padding="4" MinHeight="300">
                        <ListBox ItemsSource="{Binding Secrets}"
                                 SelectedItem="{Binding SelectedSecret}"
                                 Background="Transparent"
                                 BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="4,6">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <TextBlock Text="{Binding Category}"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   FontSize="11"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </StackPanel>

                <!-- Right: edit panel -->
                <Border Grid.Column="1" Style="{StaticResource ToolPanelBorderStyle}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Secret Details" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,16"/>

                        <TextBlock Text="Name" Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontSize="12" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" Margin="0,0,0,12"
                                 AutomationProperties.Name="Secret name"/>

                        <TextBlock Text="Category" Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontSize="12" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding EditCategory, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" Margin="0,0,0,12"
                                 AutomationProperties.Name="Secret category"/>

                        <DockPanel Margin="0,0,0,4">
                            <Button DockPanel.Dock="Right"
                                    Command="{Binding ToggleVisibilityCommand}"
                                    Padding="8,4" FontSize="11">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
                                        <Setter Property="Content" Value="Show"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsValueVisible}" Value="True">
                                                <Setter Property="Content" Value="Hide"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <TextBlock Text="Value" Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontSize="12" VerticalAlignment="Center"/>
                        </DockPanel>

                        <!-- Visible value -->
                        <TextBox Text="{Binding EditValue, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" Margin="0,0,0,12"
                                 FontFamily="Consolas"
                                 Visibility="{Binding IsValueVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                 AutomationProperties.Name="Secret value (visible)"/>

                        <!-- Masked value -->
                        <PasswordBox x:Name="EditValuePasswordBox"
                                     PasswordChanged="EditValuePasswordBox_PasswordChanged"
                                     Padding="8,6" Margin="0,0,0,12"
                                     FontFamily="Consolas"
                                     Visibility="{Binding IsValueVisible, Converter={StaticResource InvertedBoolToVisibilityConverter}}"
                                     AutomationProperties.Name="Secret value (masked)"/>

                        <TextBlock Text="Notes" Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontSize="12" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding EditNotes, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" Margin="0,0,0,16"
                                 MinHeight="60" MaxHeight="120"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 AutomationProperties.Name="Secret notes"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="Save"
                                    Command="{Binding SaveSecretCommand}"
                                    Style="{StaticResource PrimaryActionButtonStyle}"
                                    Margin="0,0,8,0"/>
                            <Button Content="Delete"
                                    Command="{Binding DeleteSecretCommand}"
                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                    Margin="0,0,8,0"/>
                            <Button Content="Copy Value"
                                    Command="{Binding CopyValueCommand}"
                                    Style="{StaticResource SecondaryActionButtonStyle}"/>
                        </StackPanel>

                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontSize="12" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
