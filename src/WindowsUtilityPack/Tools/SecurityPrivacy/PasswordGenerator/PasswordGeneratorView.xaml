<UserControl x:Class="WindowsUtilityPack.Tools.SecurityPrivacy.PasswordGenerator.PasswordGeneratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8" MaxWidth="600" HorizontalAlignment="Left">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="🔒 Password Generator" FontSize="20" FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,20"/>

        <!-- Generated Password Display -->
        <Border Grid.Row="1" Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="8" Padding="20" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="{Binding GeneratedPassword}" FontSize="22" FontFamily="Consolas"
                           Foreground="{DynamicResource AccentBrush}" TextWrapping="Wrap"
                           Margin="0,0,0,12"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Strength: " Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StrengthLabel}" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Options -->
        <Border Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="8" Padding="20" Margin="0,0,0,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="Length:" Foreground="{DynamicResource SecondaryTextBrush}"
                               VerticalAlignment="Center" Width="80"/>
                    <Slider Value="{Binding Length}" Minimum="4" Maximum="64" Width="200"
                            TickFrequency="4" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Length}" Foreground="{DynamicResource PrimaryTextBrush}"
                               FontWeight="SemiBold" VerticalAlignment="Center" Margin="12,0,0,0" Width="30"/>
                </StackPanel>
                <CheckBox Content="Uppercase (A-Z)" IsChecked="{Binding UseUppercase}"
                          Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,4"/>
                <CheckBox Content="Lowercase (a-z)" IsChecked="{Binding UseLowercase}"
                          Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,4"/>
                <CheckBox Content="Numbers (0-9)" IsChecked="{Binding UseDigits}"
                          Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,4"/>
                <CheckBox Content="Symbols (!@#$...)" IsChecked="{Binding UseSymbols}"
                          Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,4"/>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal">
            <Button Content="⟳ Regenerate" Command="{Binding GenerateCommand}"
                    Padding="16,10" Margin="0,0,12,0"
                    Background="{DynamicResource AccentBrush}" Foreground="White"
                    BorderThickness="0" Cursor="Hand" FontSize="13">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="📋 Copy to Clipboard" Command="{Binding CopyCommand}"
                    Padding="16,10"
                    Background="{DynamicResource NavBarBackgroundBrush}" Foreground="White"
                    BorderThickness="0" Cursor="Hand" FontSize="13">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
