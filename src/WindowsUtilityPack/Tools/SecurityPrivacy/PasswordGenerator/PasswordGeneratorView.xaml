<UserControl x:Class="WindowsUtilityPack.Tools.SecurityPrivacy.PasswordGenerator.PasswordGeneratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="{StaticResource IconPassword}" FontFamily="Segoe MDL2 Assets"
                       FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"
                       Foreground="{DynamicResource AccentBrush}"/>
            <TextBlock Text="Password Generator" Style="{StaticResource ToolTitleTextStyle}"/>
        </StackPanel>

        <!-- Generated Password Display -->
        <Border Grid.Row="1" Style="{StaticResource ToolPanelBorderStyle}"
                Padding="20" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="{Binding GeneratedPassword}" FontSize="22" FontFamily="Consolas"
                           Foreground="{DynamicResource AccentBrush}" TextWrapping="Wrap"
                           Margin="0,0,0,12"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Strength: " Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StrengthLabel}" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Options -->
        <Border Grid.Row="2" Style="{StaticResource ToolPanelBorderStyle}"
                Padding="20" Margin="0,0,0,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="Length:" Foreground="{DynamicResource SecondaryTextBrush}"
                               VerticalAlignment="Center" Width="80"/>
                    <Slider Value="{Binding Length}" Minimum="4" Maximum="64" Width="200"
                            TickFrequency="4" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Length}" Foreground="{DynamicResource PrimaryTextBrush}"
                               FontWeight="SemiBold" VerticalAlignment="Center" Margin="12,0,0,0" Width="30"/>
                </StackPanel>
                <CheckBox Content="Uppercase (A-Z)" IsChecked="{Binding UseUppercase}" Margin="0,4"/>
                <CheckBox Content="Lowercase (a-z)" IsChecked="{Binding UseLowercase}" Margin="0,4"/>
                <CheckBox Content="Numbers (0-9)" IsChecked="{Binding UseDigits}" Margin="0,4"/>
                <CheckBox Content="Symbols (!@#$...)" IsChecked="{Binding UseSymbols}" Margin="0,4"/>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal">
            <Button Content="Regenerate" Command="{Binding GenerateCommand}"
                    Style="{StaticResource PrimaryActionButtonStyle}"
                    Margin="0,0,12,0"
                    AutomationProperties.Name="Generate password"/>
            <Button Content="Copy to Clipboard" Command="{Binding CopyCommand}"
                    Style="{StaticResource SecondaryActionButtonStyle}"
                    AutomationProperties.Name="Copy password to clipboard"/>
        </StackPanel>
    </Grid>
</UserControl>
