<UserControl x:Class="WindowsUtilityPack.Tools.SecurityPrivacy.CertificateInspector.CertificateInspectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Certificate Inspector"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryTextBrush}"
                   Margin="0,0,0,12"/>

        <Border Grid.Row="1" Style="{StaticResource ToolPanelBorderStyle}" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Input Mode:" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <ComboBox Width="120" ItemsSource="{Binding InputModes}" SelectedItem="{Binding InputMode}"/>
                    <Button Content="Browse File"
                            Command="{Binding BrowseFileCommand}"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Margin="12,0,0,0"/>
                    <Button Content="Inspect Certificate"
                            Command="{Binding InspectCommand}"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Margin="8,0,0,0"/>
                    <Button Content="Copy Info"
                            Command="{Binding CopyInfoCommand}"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Margin="8,0,0,0"/>
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="110"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding UrlOrHost}" Visibility="{Binding IsUrlMode, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <TextBox Grid.Column="0" Text="{Binding FilePath}" Visibility="{Binding IsFileMode, Converter={StaticResource BoolToVisibilityConverter}}" IsReadOnly="True"/>
                    <TextBox Grid.Column="1" Text="{Binding Port}" Margin="8,0,0,0" Visibility="{Binding IsUrlMode, Converter={StaticResource BoolToVisibilityConverter}}" />
                </Grid>

                <TextBox Grid.Row="2"
                         Text="{Binding PemText}"
                         Visibility="{Binding IsPemMode, Converter={StaticResource BoolToVisibilityConverter}}"
                         AcceptsReturn="True"
                         MinHeight="80"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource ToolPanelBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Certificate Details" Style="{StaticResource PanelHeaderTextStyle}" Margin="0,0,0,8"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Grid Visibility="{Binding HasCertificate, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Subject"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Certificate.Subject}" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Issuer"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Certificate.Issuer}" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Valid From"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Certificate.ValidFrom}"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Valid To"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Certificate.ValidTo}"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Expiry Status"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Certificate.ExpiryStatus}"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Days Until Expiry"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Certificate.DaysUntilExpiry}"/>
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Thumbprint"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Certificate.Thumbprint}" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="7" Grid.Column="0" Text="Signature Algorithm"/>
                            <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding Certificate.SignatureAlgorithm}"/>
                            <TextBlock Grid.Row="8" Grid.Column="0" Text="Public Key"/>
                            <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding Certificate.PublicKeyAlgorithm}"/>
                            <TextBlock Grid.Row="9" Grid.Column="0" Text="Key Size"/>
                            <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding Certificate.KeySize}"/>
                        </Grid>
                        <TextBlock Text="Subject Alternative Names" FontWeight="SemiBold" Margin="0,10,0,4"/>
                        <ItemsControl ItemsSource="{Binding Certificate.SubjectAlternativeNames}" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource ToolPanelBorderStyle}" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}"/>
        </Border>
    </Grid>
</UserControl>
